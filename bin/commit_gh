#!/usr/bin/env bash
set -euo pipefail

# shellcheck disable=SC2034
VERSION="1.8.3"

supports_color() {
  [[ -t 1 ]] && [[ "${TERM:-}" != "dumb" ]] && [[ -z "${NO_COLOR:-}" ]]
}

init_colors() {
  if supports_color; then
    RED=$'\e[31m'
    GREEN=$'\e[32m'
    YELLOW=$'\e[33m'
    BLUE=$'\e[34m'
    MAGENTA=$'\e[35m'
    CYAN=$'\e[36m'
    BOLD=$'\e[1m'
    DIM=$'\e[2m'
    RESET=$'\e[0m'
  else
    RED=""
    GREEN=""
    YELLOW=""
    BLUE=""
    MAGENTA=""
    CYAN=""
    BOLD=""
    DIM=""
    RESET=""
  fi
}

init_colors

QUIET=0
GENERATE_TREE=0

# Existing flags
BUMP_TYPE=""
PREVIEW_MODE=false
VERIFY_MODE=false

# New flags
INIT_REPO=false
INIT_REMOTE=false
REMOTE_VISIBILITY="private" # private|public
RELEASE_BUMP=""             # patch|minor|major (VERSION-file based release)
VERSION_FILE="VERSION"      # default, override with --version-file
BRANCH=""                   # default detected or "main"
COMMIT_MESSAGE_OVERRIDE=""  # optional improvement
DRY_RUN=false               # optional improvement, safe to keep off by default

msg() { [[ $QUIET -eq 0 ]] && echo "$*"; }
always_msg() { echo "$*"; }
die() {
  printf "%s\n" "${RED}❌${RESET} $*" >&2
  exit 1
}

usage() {
  printf "%s\n" \
    "${BOLD}${CYAN}commit_gh${RESET} ${DIM}v${VERSION}${RESET}" \
    "" \
    "${BOLD}Usage:${RESET} commit_gh [options]" \
    "" \
    "${BOLD}${BLUE}Core behavior (unchanged):${RESET}" \
    "  - Adds/commits/pushes when needed" \
    "  - Stashes local changes before pull --rebase" \
    "  - Detects rebase/merge in progress and exits safely" \
    "  - Optional folder tree regeneration" \
    "  - Optional tag bump from latest git tag (${BOLD}--bump${RESET})" \
    "" \
    "${BOLD}${MAGENTA}New capabilities:${RESET}" \
    "  ${BOLD}--init-repo${RESET}                 Initialize a git repo in the current directory if missing" \
    "  ${BOLD}--init-remote${RESET}               Create 'origin' via GitHub CLI (gh) if missing" \
    "  ${BOLD}--public${RESET}                    When creating remote, make it public (default: private)" \
    "  ${BOLD}--release${RESET} ${YELLOW}patch|minor|major${RESET}  Bump VERSION file, commit, tag, push, create GitHub release" \
    "  ${BOLD}--version-file${RESET} ${YELLOW}<path>${RESET}       Version file to use for --release (default: VERSION)" \
    "  ${BOLD}--branch${RESET} ${YELLOW}<name>${RESET}             Branch to use (default: detected current branch, else main)" \
    "  ${BOLD}--message${RESET} ${YELLOW}\"<msg>\"${RESET}           Override commit message (otherwise timestamp-based)" \
    "  ${BOLD}--dry-run${RESET}                   Show what would happen without making changes" \
    "" \
    "${BOLD}${GREEN}Existing options:${RESET}" \
    "  ${BOLD}--quiet${RESET}, ${BOLD}-q${RESET}                 Suppress most output" \
    "  ${BOLD}--tree${RESET} ${YELLOW}[true|false]${RESET}         Generate folder tree if folder_tree exists" \
    "  ${BOLD}--bump${RESET} ${YELLOW}patch|minor|major${RESET}    Create new git tag based on latest git tag" \
    "  ${BOLD}--preview${RESET}                   Preview next tag for --bump without creating it" \
    "  ${BOLD}--verify${RESET}                    Run verification checks (working tree clean, etc.)" \
    "  ${BOLD}--help${RESET}, ${BOLD}-h${RESET}                  Show this help and exit" \
    "  ${BOLD}--version${RESET}                   Show script version" \
    "" \
    "${BOLD}${BLUE}Examples:${RESET}" \
    "  ${CYAN}commit_gh${RESET} --init-repo --init-remote" \
    "  ${CYAN}commit_gh${RESET} --release patch" \
    "  ${CYAN}commit_gh${RESET} --release minor --init-remote --public" \
    "  ${CYAN}commit_gh${RESET} --message \"chore: sync changes\" --tree true" \
    ""
}

# ----------------------------
# Argument parsing
# ----------------------------
while [[ $# -gt 0 ]]; do
  case "$1" in
  --help | -h)
    usage
    exit 0
    ;;
  --version)
    echo "commit_gh version $VERSION"
    exit 0
    ;;
  --quiet | -q) QUIET=1 ;;
  --dry-run) DRY_RUN=true ;;
  --init-repo) INIT_REPO=true ;;
  --init-remote) INIT_REMOTE=true ;;
  --public) REMOTE_VISIBILITY="public" ;;
  --branch)
    [[ -n "${2:-}" ]] || die "--branch requires a value"
    BRANCH="$2"
    shift
    ;;
  --version-file)
    [[ -n "${2:-}" ]] || die "--version-file requires a value"
    VERSION_FILE="$2"
    shift
    ;;
  --message)
    [[ -n "${2:-}" ]] || die "--message requires a value"
    COMMIT_MESSAGE_OVERRIDE="$2"
    shift
    ;;
  --release)
    case "${2:-}" in patch | minor | major)
      RELEASE_BUMP="$2"
      shift
      ;;
    *) die "Invalid value for --release. Use: patch | minor | major" ;;
    esac
    ;;
  --bump)
    case "${2:-patch}" in patch | minor | major)
      BUMP_TYPE="$2"
      shift
      ;;
    *) die "Invalid value for --bump. Use: patch | minor | major" ;;
    esac
    ;;
  --preview) PREVIEW_MODE=true ;;
  --verify) VERIFY_MODE=true ;;
  --tree)
    if [[ "${2:-}" =~ ^(true|false)$ ]]; then
      [[ "$2" == "true" ]] && GENERATE_TREE=1
      shift
    else
      GENERATE_TREE=1
    fi
    ;;
  *) die "Unknown option: $1" ;;
  esac
  shift
done

# ----------------------------
# Helpers
# ----------------------------
in_git_repo() { git rev-parse --is-inside-work-tree >/dev/null 2>&1; }

ensure_repo() {
  if in_git_repo; then
    cd "$(git rev-parse --show-toplevel)" || exit 1
    return 0
  fi

  if [[ "$INIT_REPO" != true ]]; then
    die "Not inside a git repository. Re-run with --init-repo to initialize one."
  fi

  msg "🧰 Initializing git repository in: $(pwd)"
  if [[ "$DRY_RUN" == true ]]; then
    msg "DRY RUN: git init"
    msg "DRY RUN: git checkout -b main (if needed)"
    return 0
  fi

  git init >/dev/null
  if git show-ref --verify --quiet refs/heads/main; then
    git checkout main >/dev/null
  else
    git checkout -b main >/dev/null
  fi
}

detect_branch() {
  if [[ -n "$BRANCH" ]]; then
    echo "$BRANCH"
    return 0
  fi
  if git rev-parse --verify HEAD >/dev/null 2>&1; then
    git rev-parse --abbrev-ref HEAD
  else
    echo "main"
  fi
}

has_origin_remote() { git remote | grep -q '^origin$'; }

ensure_origin_remote() {
  if has_origin_remote; then
    return 0
  fi

  if [[ "$INIT_REMOTE" != true ]]; then
    msg "⚠️ No 'origin' remote configured. Push and GitHub release creation will be skipped."
    return 1
  fi

  command -v gh >/dev/null 2>&1 || die "GitHub CLI 'gh' is required for --init-remote."

  local repo_root repo_name visibility_flag
  repo_root="$(pwd)"
  repo_name="${GIT_REPO_NAME:-$(basename "$repo_root")}"
  visibility_flag="--private"
  [[ "$REMOTE_VISIBILITY" == "public" ]] && visibility_flag="--public"

  msg "🐙 Creating GitHub repo '$repo_name' via gh and setting origin..."
  if [[ "$DRY_RUN" == true ]]; then
    msg "DRY RUN: gh repo create \"$repo_name\" --source \"$repo_root\" $visibility_flag --push"
    return 0
  fi

  gh repo create "$repo_name" --source "$repo_root" $visibility_flag --push
  msg "✅ Remote created and initial push done."
}

ensure_no_rebase_or_merge() {
  if [ -d ".git/rebase-merge" ] || [ -d ".git/rebase-apply" ]; then
    die "Git rebase is in progress. Resolve and run 'git rebase --continue' first."
  fi
  if [ -f ".git/MERGE_HEAD" ]; then
    die "Git merge is in progress. Resolve and complete the merge first."
  fi
}

ensure_ssh_agent() {
  if [ -z "${SSH_AUTH_SOCK:-}" ]; then
    eval "$(ssh-agent -s)" >/dev/null
    ssh-add -A >/dev/null 2>&1 || true
  fi
}

sync_with_remote_rebase() {
  local branch="$1"
  has_origin_remote || return 0

  if ! git diff --quiet; then
    msg "💾 Stashing unstaged local changes before pull --rebase..."
    if [[ "$DRY_RUN" == true ]]; then
      msg "DRY RUN: git stash -u"
      msg "DRY RUN: git pull --rebase origin \"$branch\""
      msg "DRY RUN: git stash pop"
      return 0
    fi

    git stash -u >/dev/null
    if ! git pull --rebase origin "$branch" >/dev/null 2>&1; then
      die "Pull/rebase failed. Resolve manually."
    fi
    if ! git stash pop >/dev/null 2>&1; then
      die "git stash pop failed after pull --rebase. Resolve the stash manually (git stash list, git stash show -p, git stash apply)."
    fi
  else
    if [[ "$DRY_RUN" == true ]]; then
      msg "DRY RUN: git pull --rebase origin \"$branch\""
      return 0
    fi
    git pull --rebase origin "$branch" >/dev/null 2>&1 || true
  fi
}

# ----------------------------
# VERSION helpers
# ----------------------------
resolve_realpath() {
  local p="$1"
  python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' "$p" 2>/dev/null || echo "$p"
}

update_self_version_constant() {
  local new_version="$1"
  local self_path
  self_path="$(cd -- "$(dirname "${BASH_SOURCE[0]}")" && pwd)/$(basename "${BASH_SOURCE[0]}")"
  self_path="$(resolve_realpath "$self_path")"

  if [[ ! -f "$self_path" ]]; then
    msg "⚠️ Cannot update self VERSION. Not a regular file: $self_path"
    msg "   Tip: run releases from the repo copy: ./bin/commit_gh --release …"
    return 0
  fi

  if [[ ! -w "$self_path" ]]; then
    msg "⚠️ Cannot update self VERSION. File is not writable: $self_path"
    msg "   Tip: run releases from the repo copy: ./bin/commit_gh --release …"
    return 0
  fi

  if grep -qE '^VERSION="[^"]+"' "$self_path"; then
    if [[ "$DRY_RUN" == true ]]; then
      msg "DRY RUN: sed -i '' -E 's/^VERSION=\"[^\"]+\"/VERSION=\"${new_version}\"/' \"$self_path\""
      return 0
    fi
    sed -i '' -E "s/^VERSION=\"[^\"]+\"/VERSION=\"${new_version}\"/" "$self_path"
  fi
}

get_self_version_constant() {
  local self_path
  self_path="$(cd -- "$(dirname "${BASH_SOURCE[0]}")" && pwd)/$(basename "${BASH_SOURCE[0]}")"
  self_path="$(resolve_realpath "$self_path")"

  grep -E '^VERSION="[^"]+"' "$self_path" |
    head -n1 |
    sed -E 's/^VERSION="([^"]+)".*/\1/'
}

read_semver() {
  local v="$1"
  [[ "$v" =~ ^([0-9]+)\.([0-9]+)\.([0-9]+)$ ]] || return 1
  SEMVER_MAJOR="${BASH_REMATCH[1]}"
  SEMVER_MINOR="${BASH_REMATCH[2]}"
  SEMVER_PATCH="${BASH_REMATCH[3]}"
  return 0
}

bump_semver() {
  local bump="$1" major="$2" minor="$3" patch="$4"
  case "$bump" in
  patch) patch=$((patch + 1)) ;;
  minor)
    minor=$((minor + 1))
    patch=0
    ;;
  major)
    major=$((major + 1))
    minor=0
    patch=0
    ;;
  *) die "Unknown bump type: $bump" ;;
  esac
  echo "${major}.${minor}.${patch}"
}

ensure_version_file() {
  local vf="$1"
  if [[ ! -f "$vf" ]]; then
    msg "⚠️ Version file '$vf' not found. Creating with 0.0.0"
    if [[ "$DRY_RUN" == true ]]; then
      msg "DRY RUN: echo 0.0.0 > \"$vf\""
      return 0
    fi
    echo "0.0.0" >"$vf"
  fi
}

create_github_release() {
  local tag="$1"
  command -v gh >/dev/null 2>&1 || {
    msg "⚠️ gh not found. Skipping GitHub release."
    return 0
  }
  has_origin_remote || {
    msg "⚠️ No origin remote. Skipping GitHub release."
    return 0
  }

  if [[ "$DRY_RUN" == true ]]; then
    msg "DRY RUN: gh release view \"$tag\""
    msg "DRY RUN: gh release create \"$tag\" --title \"$tag\" --notes \"Release $tag\""
    return 0
  fi

  if gh release view "$tag" >/dev/null 2>&1; then
    msg "⚠️ GitHub release $tag already exists. Skipping."
    return 0
  fi

  msg "📦 Creating GitHub release $tag..."
  gh release create "$tag" --title "$tag" --notes "Release $tag"
}

# ----------------------------
# Start
# ----------------------------
ensure_repo
ensure_no_rebase_or_merge
ensure_ssh_agent

branch="$(detect_branch)"

# Optional: remove tracked FOLDER_TREE.md if ignored
if in_git_repo && git ls-files --error-unmatch FOLDER_TREE.md &>/dev/null; then
  if [[ -f .gitignore ]] && grep -qF "FOLDER_TREE.md" .gitignore; then
    msg "🧹 Removing FOLDER_TREE.md from Git tracking..."
    if [[ "$DRY_RUN" == true ]]; then
      msg "DRY RUN: git rm --cached FOLDER_TREE.md"
    else
      git rm --cached FOLDER_TREE.md >/dev/null
    fi
  fi
fi

ensure_origin_remote || true

# Decide commit message
if [[ -n "$COMMIT_MESSAGE_OVERRIDE" ]]; then
  COMMIT_MESSAGE="$COMMIT_MESSAGE_OVERRIDE"
else
  DD=$(date +'%d')
  MM=$(date +'%m')
  YYYY=$(date +'%Y')
  COMMIT_MESSAGE="$DD/$MM/$YYYY - Updated configuration and fixed bugs"
fi

# ----------------------------
# RELEASE FLOW (VERSION-file based)
# ----------------------------
if [[ -n "$RELEASE_BUMP" ]]; then
  vf_path="$VERSION_FILE"
  [[ "$vf_path" != /* ]] && vf_path="$(pwd)/$vf_path"

  ensure_version_file "$vf_path"
  current_version="$(<"$vf_path")"
  read_semver "$current_version" || die "Invalid VERSION '$current_version'. Expected X.Y.Z"

  new_version="$(bump_semver "$RELEASE_BUMP" "$SEMVER_MAJOR" "$SEMVER_MINOR" "$SEMVER_PATCH")"
  new_tag="v${new_version}"

  msg "🏷️ Release bump: $RELEASE_BUMP"
  msg "🔎 Current VERSION: $current_version"
  msg "🎯 New VERSION:     $new_version"
  msg "🎯 Tag:             $new_tag"

  # Sync first (avoid stash eating our edits)
  sync_with_remote_rebase "$branch"

  # Update the script's VERSION constant (repo copy)
  update_self_version_constant "$new_version"

  # Guard AFTER the update
  self_version="$(get_self_version_constant)"
  if [[ "$self_version" != "$new_version" ]]; then
    die "Refusing to tag: bin/commit_gh VERSION is $self_version but release version is $new_version"
  fi

  # Update VERSION file
  if [[ "$DRY_RUN" == true ]]; then
    msg "DRY RUN: echo \"$new_version\" > \"$vf_path\""
  else
    echo "$new_version" >"$vf_path"
  fi

  # Stage and commit
  if [[ "$DRY_RUN" == true ]]; then
    msg "DRY RUN: git add \"$vf_path\""
    msg "DRY RUN: git add ."
    msg "DRY RUN: git commit -m \"Release $new_tag\""
  else
    git add "$vf_path" >/dev/null
    git add . >/dev/null
    if git diff --cached --quiet; then
      msg "⚠️ No staged changes to commit. Release flow will still tag if tag does not exist."
    else
      git commit -m "Release $new_tag" >/dev/null
    fi
  fi

  # Tag
  if git rev-parse "$new_tag" >/dev/null 2>&1; then
    die "Tag $new_tag already exists. Aborting to avoid overwriting."
  fi

  if [[ "$DRY_RUN" == true ]]; then
    msg "DRY RUN: git tag -a \"$new_tag\" -m \"Release $new_tag\""
  else
    git tag -a "$new_tag" -m "Release $new_tag" >/dev/null
  fi

  # Push branch and tag
  if has_origin_remote; then
    if [[ "$DRY_RUN" == true ]]; then
      msg "DRY RUN: git push origin \"$branch\""
      msg "DRY RUN: git push origin \"$new_tag\""
    else
      git push origin "$branch" >/dev/null 2>&1 || die "Push branch failed."
      git push origin "$new_tag" >/dev/null 2>&1 || die "Push tag failed."
      msg "🚀 Pushed $branch and $new_tag to origin."
    fi
  else
    msg "⚠️ No origin remote. Skipping push and GitHub release."
  fi

  create_github_release "$new_tag"
  msg "✅ Release complete: $new_tag"
fi

# ----------------------------
# ORIGINAL COMMIT FLOW (kept)
# ----------------------------
if [[ "$DRY_RUN" == true ]]; then
  msg "DRY RUN: git add ."
else
  git add . >/dev/null
fi

DID_COMMIT=0
if ! git diff --cached --quiet; then
  msg "📦 Committing staged changes..."
  if [[ "$DRY_RUN" == true ]]; then
    msg "DRY RUN: git commit -m \"$COMMIT_MESSAGE\""
  else
    git commit -m "$COMMIT_MESSAGE" >/dev/null
  fi
  DID_COMMIT=1
fi

sync_with_remote_rebase "$branch"

if [[ "$DRY_RUN" == true ]]; then
  msg "DRY RUN: git add ."
else
  git add . >/dev/null
fi

if ! git diff --cached --quiet; then
  msg "📦 Committing new staged changes..."
  if [[ "$DRY_RUN" == true ]]; then
    msg "DRY RUN: git commit -m \"$COMMIT_MESSAGE\""
  else
    git commit -m "$COMMIT_MESSAGE" >/dev/null
  fi
  DID_COMMIT=1
fi

# Smart push logic
DID_PUSH=0
try_push() {
  local max_attempts=2
  local attempt=1

  if ! has_origin_remote; then
    msg "⚠️ No origin remote. Skipping push."
    return 0
  fi

  while [[ $attempt -le $max_attempts ]]; do
    if [[ $(git log "origin/$branch..HEAD" --oneline 2>/dev/null | wc -l | tr -d ' ') -gt 0 ]]; then
      if [[ "$DRY_RUN" == true ]]; then
        msg "DRY RUN: git push origin \"$branch\""
        DID_PUSH=1
        return 0
      fi

      if git push origin "$branch" >/dev/null 2>&1; then
        DID_PUSH=1
        msg "🚀 Successfully pushed to origin/$branch."
        return 0
      else
        msg "⚠️ Push failed. Trying pull --rebase and re-push..."
        if ! git pull --rebase origin "$branch" >/dev/null 2>&1; then
          die "Pull/rebase failed. Resolve manually."
        fi
        ((attempt++))
      fi
    else
      return 0
    fi
  done

  die "Push failed after retry. Resolve manually."
}
try_push

# Verification layer
if [[ "$VERIFY_MODE" == true ]]; then
  msg "🧪 Running commit_gh verification..."

  if ! git diff --quiet || ! git diff --cached --quiet; then
    die "Working tree is dirty."
  fi
  msg "✅ Working tree is clean."

  current_branch="$(git rev-parse --abbrev-ref HEAD)"
  if [[ "$current_branch" != "$branch" ]]; then
    die "Not on '$branch' branch (current: $current_branch)"
  fi
  msg "✅ On branch: $branch"

  if [[ ! -f .version ]]; then
    latest_tag=$(git tag --sort=-v:refname | grep -E '^v[0-9]+\.[0-9]+\.[0-9]+$' | head -n1 || echo "v0.0.0")
    if [[ "$DRY_RUN" == true ]]; then
      msg "DRY RUN: echo \"$latest_tag\" > .version"
    else
      echo "$latest_tag" >.version
    fi
    version_file="$latest_tag"
    msg "🆕 .version file created with: $latest_tag"
  else
    version_file=$(<.version)
    msg "✅ .version file found: $version_file"
  fi

  latest_tag=$(git tag --sort=-v:refname | grep -E '^v[0-9]+\.[0-9]+\.[0-9]+$' | head -n1 || echo "v0.0.0")
  if [[ "$version_file" != "$latest_tag" ]]; then
    die ".version ($version_file) does not match latest tag ($latest_tag)"
  fi
  msg "🎯 All verification checks passed."
fi

if [[ $DID_COMMIT -eq 0 && $DID_PUSH -eq 0 ]]; then
  current_branch="$(git rev-parse --abbrev-ref HEAD)"
  always_msg "✅ Current branch $current_branch is up to date."
  always_msg "🟢 No changes to commit."
fi

if [[ -f .github/dependabot.yml ]]; then
  msg "🔐 Dependabot is enabled. Base image CVEs will be monitored automatically by GitHub."
fi

if [[ $GENERATE_TREE -eq 1 ]]; then
  if command -v folder_tree &>/dev/null; then
    msg "🌳 Generating updated folder tree..."
    if [[ "$DRY_RUN" == true ]]; then
      msg "DRY RUN: folder_tree --preset terraform,github --output markdown"
    else
      folder_tree --preset terraform,github --output markdown >/dev/null
    fi
  else
    msg "⚠️ 'folder_tree' command not found. Skipping tree update."
  fi
fi

# Existing tag bump behavior
if [[ -n "$BUMP_TYPE" || "$PREVIEW_MODE" == true ]]; then
  latest_tag=$(git tag --sort=-v:refname | grep -E '^v[0-9]+\.[0-9]+\.[0-9]+$' | head -n1 || echo "v0.0.0")
  IFS='.' read -r major minor patch <<<"${latest_tag#v}"

  msg "🔍 Latest tag: $latest_tag"

  if [[ -z "$BUMP_TYPE" ]]; then
    msg "🕵️ No bump type specified."
    exit 0
  fi

  case "$BUMP_TYPE" in
  patch) ((patch++)) ;;
  minor)
    ((minor++))
    patch=0
    ;;
  major)
    ((major++))
    minor=0
    patch=0
    ;;
  esac

  new_tag="v$major.$minor.$patch"

  if [[ "$PREVIEW_MODE" == true ]]; then
    msg "🔼 Requested bump: $BUMP_TYPE"
    msg "🎯 Next tag would be: $new_tag"
    exit 0
  fi

  if git rev-parse "$new_tag" >/dev/null 2>&1; then
    die "Tag $new_tag already exists. Aborting."
  fi

  msg "🏷️ Creating new tag: $new_tag"
  if [[ "$DRY_RUN" == true ]]; then
    msg "DRY RUN: git tag -a \"$new_tag\" -m \"Release $new_tag\""
    msg "DRY RUN: git push origin \"$new_tag\""
    msg "DRY RUN: echo \"$new_tag\" > .version"
  else
    git tag -a "$new_tag" -m "Release $new_tag" >/dev/null
    if has_origin_remote; then
      git push origin "$new_tag" >/dev/null
      msg "✅ Pushed tag $new_tag successfully."
    else
      msg "⚠️ No origin remote. Tag exists only locally."
    fi
    echo "$new_tag" >.version
    msg "📝 Wrote version to .version"
  fi
fi
always_msg "🎉 Done."
