  local checklist="docs/release-checklist.md"
  if [[ -f "$checklist" ]]; then
    msg "✅ $checklist already exists. Skipping."
    return 0
  fi
  msg "📋 Writing $checklist..."
  if [[ "$DRY_RUN" == true ]]; then
    msg "DRY RUN: write $checklist"
