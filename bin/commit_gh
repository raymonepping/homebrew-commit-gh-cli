#!/usr/bin/env bash
set -euo pipefail

# shellcheck disable=SC2034
VERSION="2.8.1"

supports_color() {
  [[ -t 1 ]] && [[ "${TERM:-}" != "dumb" ]] && [[ -z "${NO_COLOR:-}" ]]
}

init_colors() {
  if supports_color; then
    RED=$'\e[31m'
    GREEN=$'\e[32m'
    YELLOW=$'\e[33m'
    BLUE=$'\e[34m'
    MAGENTA=$'\e[35m'
    CYAN=$'\e[36m'
    BOLD=$'\e[1m'
    DIM=$'\e[2m'
    RESET=$'\e[0m'
  else
    RED=""
    GREEN=""
    YELLOW=""
    BLUE=""
    MAGENTA=""
    CYAN=""
    BOLD=""
    DIM=""
    RESET=""
  fi
}

init_colors

QUIET=0
GENERATE_TREE=0

# Existing flags
BUMP_TYPE=""
PREVIEW_MODE=false
VERIFY_MODE=false

# v1.x flags
INIT_REPO=false
INIT_REMOTE=false
REMOTE_VISIBILITY="private"
RELEASE_BUMP=""
VERSION_FILE="VERSION"
BRANCH=""
COMMIT_MESSAGE_OVERRIDE=""
DRY_RUN=false

# v2.0 security flags
SCAN_MODE=false         # --scan: run standalone gitleaks scan and exit
NO_SCAN=false           # --no-scan: skip auto staged scan before commit
NO_HOOK=false           # --no-hook: skip pre-commit hook installation during --init-repo
ENABLE_SECRET_SCANNING=false  # --secret-scanning: enable GitHub secret scanning on remote
AUDIT_MODE=false        # --audit: check which guardrails are present/missing
HARDEN_MODE=false       # --harden: install missing guardrails in existing repo

# v2.1 release flags
RELEASE_FORCE=false         # --force: overwrite existing tag + GitHub release
RELEASE_NO_RELEASE=false    # --no-release: tag+push only, skip GitHub release
RELEASE_GENERATE_NOTES=false # --generate-notes: auto-generate release notes via gh
READ_VERSION_ONLY=false     # --read-version-only: print version inventory and exit

# v2.2 flags
PROTECT_MODE=false          # --protect: set branch protection rules on remote
DOCTOR_MODE=false           # --doctor: check developer environment

# v2.3 flags
ROLLBACK_TAG=""             # --rollback [tag]: delete a release tag + GitHub release
SIGN_MODE=false             # --sign: configure GPG/SSH commit signing
LABELS_MODE=false           # --labels: create standard GitHub issue labels

# v2.5 flags
CHANGELOG_PREVIEW_BUMP=""   # --changelog [patch|minor|major|x.y.z]: preview next release entry
MILESTONE_BUMP=""           # --milestone [patch|minor|major|x.y.z]: create GitHub milestone
CONTRIBUTORS_MODE=false     # --contributors: generate/update CONTRIBUTORS.md from git history

# v2.6 flags
PR_MODE=false               # --pr: create a pull request after commit+push
PR_DRAFT=false              # --draft: open the PR as a draft (use with --pr)

# v2.7 flags
HISTORY_MODE=false          # --history: show release + commit history
JSON_OUTPUT=false           # --json: output --history as JSON (use with --history)

# v2.9 flags
PUBLISH_IMAGE=false         # --publish-image: build + push a container image on --release
IMAGE_CONTEXT="."           # --image-context <dir>: Docker build context (default: repo root)
IMAGE_NAME=""               # --image-name <name>: image name (default: repo name)
IMAGE_REGISTRY="ghcr.io"    # --registry <host>: container registry (default: GHCR)

msg() { [[ $QUIET -eq 0 ]] && echo "$*"; }
always_msg() { echo "$*"; }
die() {
  printf "%s\n" "${RED}❌${RESET} $*" >&2
  exit 1
}

usage() {
  local sep="${DIM}────────────────────────────────────────────────────${RESET}"
  printf "%s\n" \
    "" \
    "  ${BOLD}${CYAN}commit_gh${RESET}  ${DIM}v${VERSION}${RESET}" \
    "  ${DIM}Secure git commits, releases, and repository hardening${RESET}" \
    "" \
    "  $sep" \
    "" \
    "  ${BOLD}Quick start${RESET}" \
    "  ${CYAN}commit_gh${RESET} ${DIM}--init-repo --init-remote --public --secret-scanning${RESET}  ${DIM}# new repo${RESET}" \
    "  ${CYAN}commit_gh${RESET} ${DIM}--harden --audit${RESET}                                      ${DIM}# secure existing repo${RESET}" \
    "  ${CYAN}commit_gh${RESET} ${DIM}--release patch${RESET}                                       ${DIM}# ship a release${RESET}" \
    "" \
    "  $sep" \
    "" \
    "  ${BOLD}${BLUE}Setup${RESET}" \
    "  ${BOLD}--init-repo${RESET}              Initialize a git repo in the current directory" \
    "  ${BOLD}--init-remote${RESET}            Create origin remote via gh CLI" \
    "  ${BOLD}--public${RESET} / ${BOLD}--private${RESET}     Visibility for --init-remote  ${DIM}(default: private)${RESET}" \
    "" \
    "  ${BOLD}${RED}Security${RESET}" \
    "  ${BOLD}--harden${RESET}                 Install missing guardrails  ${DIM}(idempotent — safe to re-run)${RESET}" \
    "  ${BOLD}--audit${RESET}                  Report which guardrails are present / missing  ${DIM}(exit 1 if any missing)${RESET}" \
    "  ${BOLD}--scan${RESET}                   Run Gitleaks on full working tree and exit" \
    "  ${BOLD}--no-scan${RESET}                Skip staged scan before commit" \
    "  ${BOLD}--no-hook${RESET}                Skip pre-commit hook installation" \
    "  ${BOLD}--secret-scanning${RESET}        Enable GitHub secret scanning + push protection on remote" \
    "" \
    "  ${DIM}--init-repo and --harden both install:${RESET}" \
    "    ${DIM}·${RESET} ${CYAN}.gitignore${RESET}                          secrets, OS, editor, build, *.jsonl, input/, output/" \
    "    ${DIM}·${RESET} ${CYAN}.env.example${RESET}                        credential template (commit this, never .env)" \
    "    ${DIM}·${RESET} ${CYAN}.gitleaks.toml${RESET}                      Gitleaks config with CHANGELOG allowlist" \
    "    ${DIM}·${RESET} ${CYAN}.git/hooks/pre-commit${RESET}               blocks sensitive filenames + scans staged files" \
    "    ${DIM}·${RESET} ${CYAN}.github/workflows/gitleaks.yml${RESET}      CI scan, SHA-pinned, permissions: read-all" \
    "    ${DIM}·${RESET} ${CYAN}.github/workflows/release.yml${RESET}       automated GitHub release on tag push" \
    "    ${DIM}·${RESET} ${CYAN}.github/dependabot.yml${RESET}              weekly GitHub Actions updates" \
    "    ${DIM}·${RESET} ${CYAN}CHANGELOG.md  LICENSE  README.md  CONTRIBUTING.md${RESET}" \
    "    ${DIM}·${RESET} ${CYAN}.github/ISSUE_TEMPLATE/  pull_request_template.md  CODEOWNERS${RESET}" \
    "    ${DIM}·${RESET} ${CYAN}.editorconfig  docs/release-checklist.md${RESET}" \
    "" \
    "  ${BOLD}${MAGENTA}Release${RESET}" \
    "  ${BOLD}--release${RESET} ${YELLOW}patch|minor|major|x.y.z${RESET}  Bump VERSION, commit, tag, push, GitHub release" \
    "  ${BOLD}--force${RESET}                  Overwrite existing tag and release  ${DIM}(use with --release)${RESET}" \
    "  ${BOLD}--no-release${RESET}             Tag and push only — skip GitHub release creation" \
    "  ${BOLD}--generate-notes${RESET}         Auto-generate release notes from pull requests" \
    "  ${BOLD}--read-version-only${RESET}      Print version inventory (VERSION file, script, tag) and exit" \
    "  ${BOLD}--version-file${RESET} ${YELLOW}<path>${RESET}     Version file for --release  ${DIM}(default: VERSION)${RESET}" \
    "  ${BOLD}--publish-image${RESET}          Build + push a container image  ${DIM}(use with --release)${RESET}" \
    "  ${BOLD}--image-context${RESET} ${YELLOW}<dir>${RESET}     Docker build context  ${DIM}(default: .)${RESET}" \
    "  ${BOLD}--image-name${RESET} ${YELLOW}<name>${RESET}       Image name  ${DIM}(default: repo name)${RESET}" \
    "  ${BOLD}--registry${RESET} ${YELLOW}<host>${RESET}         Container registry  ${DIM}(default: ghcr.io)${RESET}" \
    "" \
    "  ${BOLD}${GREEN}Commit${RESET}" \
    "  ${BOLD}--branch${RESET} ${YELLOW}<name>${RESET}           Branch for commit and push  ${DIM}(default: current, else main)${RESET}" \
    "  ${BOLD}--message${RESET} ${YELLOW}\"<text>\"${RESET}        Override commit message" \
    "  ${BOLD}--pr${RESET}                     Create a pull request after commit and push" \
    "  ${BOLD}--draft${RESET}                  Open the PR as a draft  ${DIM}(use with --pr)${RESET}" \
    "  ${BOLD}--dry-run${RESET}                Show what would happen without making changes" \
    "  ${BOLD}--quiet${RESET}, ${BOLD}-q${RESET}               Suppress most output" \
    "  ${BOLD}--tree${RESET} ${YELLOW}[true|false]${RESET}       Regenerate folder tree before committing" \
    "" \
    "  ${BOLD}Utilities${RESET}" \
    "  ${BOLD}--protect${RESET}                Set branch protection on remote  ${DIM}(1 review required, no force-push)${RESET}" \
    "  ${BOLD}--doctor${RESET}                 Check developer environment  ${DIM}(bash, git, gitleaks, gh, SSH)${RESET}" \
    "  ${BOLD}--rollback${RESET} ${YELLOW}[tag]${RESET}          Delete a GitHub release and its tag  ${DIM}(default: latest tag)${RESET}" \
    "  ${BOLD}--sign${RESET}                   Enable GPG or SSH commit signing  ${DIM}(global config + CI workflow)${RESET}" \
    "  ${BOLD}--labels${RESET}                 Create standard GitHub issue labels on remote  ${DIM}(idempotent)${RESET}" \
    "  ${BOLD}--changelog${RESET} ${YELLOW}[bump]${RESET}        Preview next CHANGELOG entry without writing anything  ${DIM}(default: patch)${RESET}" \
    "  ${BOLD}--milestone${RESET} ${YELLOW}[bump]${RESET}        Create a GitHub milestone for the next version  ${DIM}(default: patch)${RESET}" \
    "  ${BOLD}--contributors${RESET}           Generate or update CONTRIBUTORS.md from git history" \
    "  ${BOLD}--history${RESET}                Show release and commit history in descending order" \
    "  ${BOLD}--json${RESET}                   Output --history as JSON  ${DIM}(use with --history)${RESET}" \
    "  ${BOLD}--bump${RESET} ${YELLOW}patch|minor|major${RESET}  Create a git tag from latest tag  ${DIM}(no file changes)${RESET}" \
    "  ${BOLD}--preview${RESET}                Preview next --bump tag without creating it" \
    "  ${BOLD}--verify${RESET}                 Run verification checks (clean tree, branch, version)" \
    "  ${BOLD}--help${RESET}, ${BOLD}-h${RESET}               Show this help and exit" \
    "  ${BOLD}--version${RESET}                Show script version" \
    "" \
    "  $sep" \
    "" \
    "  ${BOLD}${BLUE}Examples${RESET}" \
    "  ${CYAN}commit_gh${RESET} --init-repo --init-remote --public --secret-scanning --protect" \
    "  ${CYAN}commit_gh${RESET} --harden --audit" \
    "  ${CYAN}commit_gh${RESET} --doctor" \
    "  ${CYAN}commit_gh${RESET}" \
    "  ${CYAN}commit_gh${RESET} --message \"feat: add login endpoint\"" \
    "  ${CYAN}commit_gh${RESET} --release patch" \
    "  ${CYAN}commit_gh${RESET} --release 2.1.0 --generate-notes" \
    "  ${CYAN}commit_gh${RESET} --release patch --force" \
    "  ${CYAN}commit_gh${RESET} --release patch --publish-image --image-context home --image-name vault-reference-portal" \
    "  ${CYAN}commit_gh${RESET} --scan" \
    "  ${CYAN}commit_gh${RESET} --read-version-only" \
    "  ${CYAN}commit_gh${RESET} --release minor --dry-run" \
    "  ${CYAN}commit_gh${RESET} --rollback v2.3.0" \
    "  ${CYAN}commit_gh${RESET} --sign" \
    "  ${CYAN}commit_gh${RESET} --labels" \
    "  ${CYAN}commit_gh${RESET} --changelog" \
    "  ${CYAN}commit_gh${RESET} --changelog minor" \
    "  ${CYAN}commit_gh${RESET} --milestone" \
    "  ${CYAN}commit_gh${RESET} --contributors" \
    "  ${CYAN}commit_gh${RESET} --branch feature/auth --message \"feat: add OAuth login\" --pr" \
    "  ${CYAN}commit_gh${RESET} --pr --draft" \
    "  ${CYAN}commit_gh${RESET} --history" \
    "  ${CYAN}commit_gh${RESET} --history --json" \
    "" \
    "  $sep" \
    "  ${DIM}Full documentation:  man commit_gh${RESET}" \
    "  ${DIM}Source & issues:     https://github.com/raymonepping/homebrew-commit-gh-cli${RESET}" \
    ""
}

# ----------------------------
# Argument parsing
# ----------------------------
while [[ $# -gt 0 ]]; do
  case "$1" in
  --help | -h)
    usage
    exit 0
    ;;
  --version)
    echo "commit_gh version $VERSION"
    exit 0
    ;;
  --quiet | -q) QUIET=1 ;;
  --dry-run) DRY_RUN=true ;;
  --init-repo) INIT_REPO=true ;;
  --init-remote) INIT_REMOTE=true ;;
  --public) REMOTE_VISIBILITY="public" ;;
  --private) REMOTE_VISIBILITY="private" ;;
  --audit) AUDIT_MODE=true ;;
  --harden) HARDEN_MODE=true ;;
  --scan) SCAN_MODE=true ;;
  --no-scan) NO_SCAN=true ;;
  --no-hook) NO_HOOK=true ;;
  --secret-scanning) ENABLE_SECRET_SCANNING=true ;;
  --protect) PROTECT_MODE=true ;;
  --doctor)  DOCTOR_MODE=true ;;
  --rollback)
    if [[ "${2:-}" =~ ^v?[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
      ROLLBACK_TAG="$2"
      shift
    else
      ROLLBACK_TAG="latest"
    fi
    ;;
  --sign) SIGN_MODE=true ;;
  --labels) LABELS_MODE=true ;;
  --changelog)
    if [[ "${2:-}" =~ ^(patch|minor|major)$ ]]; then
      CHANGELOG_PREVIEW_BUMP="$2"; shift
    elif [[ "${2:-}" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
      CHANGELOG_PREVIEW_BUMP="$2"; shift
    else
      CHANGELOG_PREVIEW_BUMP="patch"
    fi
    ;;
  --milestone)
    if [[ "${2:-}" =~ ^(patch|minor|major)$ ]]; then
      MILESTONE_BUMP="$2"; shift
    elif [[ "${2:-}" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
      MILESTONE_BUMP="$2"; shift
    else
      MILESTONE_BUMP="patch"
    fi
    ;;
  --contributors) CONTRIBUTORS_MODE=true ;;
  --history) HISTORY_MODE=true ;;
  --json) JSON_OUTPUT=true ;;
  --pr) PR_MODE=true ;;
  --draft) PR_DRAFT=true ;;
  --force) RELEASE_FORCE=true ;;
  --no-release) RELEASE_NO_RELEASE=true ;;
  --generate-notes) RELEASE_GENERATE_NOTES=true ;;
  --read-version-only) READ_VERSION_ONLY=true ;;
  --branch)
    [[ -n "${2:-}" ]] || die "--branch requires a value"
    BRANCH="$2"
    shift
    ;;
  --version-file)
    [[ -n "${2:-}" ]] || die "--version-file requires a value"
    VERSION_FILE="$2"
    shift
    ;;
  --message)
    [[ -n "${2:-}" ]] || die "--message requires a value"
    COMMIT_MESSAGE_OVERRIDE="$2"
    shift
    ;;
  --release)
    if [[ "${2:-}" =~ ^(patch|minor|major)$ ]]; then
      RELEASE_BUMP="$2"
      shift
    elif [[ "${2:-}" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
      RELEASE_BUMP="$2"
      shift
    else
      die "--release requires: patch | minor | major | x.y.z  (got: '${2:-}')"
    fi
    ;;
  --bump)
    case "${2:-patch}" in patch | minor | major)
      BUMP_TYPE="$2"
      shift
      ;;
    *) die "Invalid value for --bump. Use: patch | minor | major" ;;
    esac
    ;;
  --preview) PREVIEW_MODE=true ;;
  --verify) VERIFY_MODE=true ;;
  --publish-image) PUBLISH_IMAGE=true ;;
  --image-context)
    [[ -n "${2:-}" ]] || die "--image-context requires a value"
    IMAGE_CONTEXT="$2"
    shift
    ;;
  --image-name)
    [[ -n "${2:-}" ]] || die "--image-name requires a value"
    IMAGE_NAME="$2"
    shift
    ;;
  --registry)
    [[ -n "${2:-}" ]] || die "--registry requires a value"
    IMAGE_REGISTRY="$2"
    shift
    ;;
  --tree)
    if [[ "${2:-}" =~ ^(true|false)$ ]]; then
      [[ "$2" == "true" ]] && GENERATE_TREE=1
      shift
    else
      GENERATE_TREE=1
    fi
    ;;
  *) die "Unknown option: $1" ;;
  esac
  shift
done

# ----------------------------
# Helpers
# ----------------------------
in_git_repo() { git rev-parse --is-inside-work-tree >/dev/null 2>&1; }

# ----------------------------
# Security helpers
# ----------------------------
gitleaks_available() { command -v gitleaks >/dev/null 2>&1; }

COMMIT_BLOCKED_PATTERN='\.(env|pem|key|p12|pfx|cer|crt|der|vault)$|^(id_rsa|id_dsa|id_ecdsa|id_ed25519)$|_(rsa|dsa|ecdsa|ed25519)$|^\.vault\.'

unstage_gitignored_files() {
  local ignored
  ignored="$(git ls-files --cached --ignored --exclude-standard 2>/dev/null || true)"
  [[ -z "$ignored" ]] && return 0
  msg "⚠️ Removing gitignored files from staging area (already indexed, now excluded):"
  while IFS= read -r f; do
    msg "   🗑️ $f"
    git rm --cached "$f" >/dev/null 2>&1 || true
  done <<< "$ignored"
}

unstage_blocked_files() {
  local blocked
  # --diff-filter=ACMR: only Added/Copied/Modified/Renamed — skip Deletions.
  # Deletions are already staged by unstage_gitignored_files and must stay staged
  # so they get committed (removing the file from tracking). Restoring them would
  # undo that deletion and cause the warning to repeat on every subsequent run.
  blocked="$(git diff --cached --name-only --diff-filter=ACMR 2>/dev/null \
    | grep -E "$COMMIT_BLOCKED_PATTERN" \
    | grep -v '\.env\.example$' \
    | grep -v '\.env\.sample$' \
    || true)"
  [[ -z "$blocked" ]] && return 0
  msg "⚠️ Unstaging sensitive file(s) — add to .gitignore to prevent restaging:"
  while IFS= read -r f; do
    msg "   🚫 $f"
    git rm --cached "$f" >/dev/null 2>&1 \
      || msg "   ⚠️ Could not unstage $f — run: git rm --cached \"$f\""
  done <<< "$blocked"
}

write_gitignore() {
  local gi_path=".gitignore"
  if [[ -f "$gi_path" ]]; then
    local _has_env _has_star_env _has_vault _has_jsonl _has_input _has_output _missing=() _did_append=false
    grep -qE '^\.env$|^\.env\b' "$gi_path" 2>/dev/null && _has_env=true || _has_env=false
    grep -qE '^\*\.env$' "$gi_path" 2>/dev/null && _has_star_env=true || _has_star_env=false
    grep -qE '^\.vault\.\*$' "$gi_path" 2>/dev/null && _has_vault=true || _has_vault=false
    grep -qE '^\*\.jsonl$' "$gi_path" 2>/dev/null && _has_jsonl=true || _has_jsonl=false
    grep -qE '^input/' "$gi_path" 2>/dev/null && _has_input=true || _has_input=false
    grep -qE '^output/' "$gi_path" 2>/dev/null && _has_output=true || _has_output=false

    if [[ "$_has_env" == false ]]; then
      msg "⚠️ .gitignore exists but missing .env coverage — appending secrets block..."
      if [[ "$DRY_RUN" == true ]]; then
        msg "DRY RUN: append secrets block to .gitignore"
      else
        cat >>"$gi_path" <<'EOF'

# ── Secrets & credentials (added by commit_gh --harden) ────────
.env
.env.*
*.env
!.env.example
!.env.sample
.vault.*
*.vault
*.pem
*.key
*.p12
*.pfx
*.cer
*.crt
*.der
id_rsa
id_dsa
id_ecdsa
id_ed25519
*_rsa
*_dsa
*_ecdsa
*_ed25519
EOF
      fi
      _did_append=true
      _has_star_env=true
      _has_vault=true
    fi

    # Collect any individually missing patterns
    [[ "$_has_star_env" == false ]] && _missing+=("*.env")
    [[ "$_has_vault" == false ]] && _missing+=(".vault.*" "*.vault")
    [[ "$_has_jsonl" == false ]] && _missing+=("*.jsonl")
    [[ "$_has_input" == false ]] && _missing+=("input/*" "!input/.gitkeep")
    [[ "$_has_output" == false ]] && _missing+=("output/*" "!output/.gitkeep")

    if [[ ${#_missing[@]} -eq 0 ]]; then
      [[ "$_did_append" == false ]] && msg "✅ .gitignore already exists. Skipping."
      return 0
    fi

    msg "⚠️ .gitignore missing patterns (${_missing[*]}) — appending..."
    if [[ "$DRY_RUN" == true ]]; then
      msg "DRY RUN: append ${_missing[*]} to .gitignore"
      return 0
    fi
    printf '\n# ── Added by commit_gh --harden ─────────────────────────────\n' >>"$gi_path"
    for _p in "${_missing[@]}"; do
      printf '%s\n' "$_p" >>"$gi_path"
    done
    msg "✅ Appended to .gitignore: ${_missing[*]}"
    return 0
  fi
  msg "📄 Writing .gitignore..."
  if [[ "$DRY_RUN" == true ]]; then
    msg "DRY RUN: write .gitignore (secrets, OS, editor, build patterns)"
    return 0
  fi
  cat >"$gi_path" <<'EOF'
# ── Secrets & credentials ──────────────────────────────────────
.env
.env.*
*.env
!.env.example
!.env.sample
.vault.*
*.vault
*.pem
*.key
*.p12
*.pfx
*.cer
*.crt
*.der
id_rsa
id_dsa
id_ecdsa
id_ed25519
*_rsa
*_dsa
*_ecdsa
*_ed25519

# ── OS ────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
desktop.ini

# ── Editor ────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
*.orig

# ── Build artifacts ───────────────────────────────────────────
dist/
build/
out/
*.o
*.a
*.so
*.dylib

# ── Input / output data (keep dirs via .gitkeep, never content)
input/*
!input/.gitkeep
output/*
!output/.gitkeep

# ── Dependencies ──────────────────────────────────────────────
node_modules/
vendor/
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# ── Logs & generated output ───────────────────────────────────
*.log
*.jsonl
logs/
tmp/
temp/
.tmp/

# ── Coverage & test output ────────────────────────────────────
.coverage
coverage/
htmlcov/
.pytest_cache/
*.lcov
EOF
  msg "✅ .gitignore created."
}

write_env_example() {
  if [[ -f ".env.example" ]]; then
    msg "✅ .env.example already exists. Skipping."
    return 0
  fi
  msg "📄 Writing .env.example..."
  if [[ "$DRY_RUN" == true ]]; then
    msg "DRY RUN: write .env.example"
    return 0
  fi
  cat >".env.example" <<'EOF'
# Copy this file to .env and fill in your values.
# NEVER commit .env — it is listed in .gitignore.

# Example:
# DATABASE_URL=postgres://user:password@localhost:5432/mydb
# API_KEY=your_api_key_here
# SECRET_TOKEN=your_secret_here
EOF
  msg "✅ .env.example created."
}

write_gitleaks_toml() {
  local toml_path=".gitleaks.toml"
  if [[ -f "$toml_path" ]]; then
    msg "✅ .gitleaks.toml already exists. Skipping."
    return 0
  fi
  msg "🔒 Writing .gitleaks.toml..."
  if [[ "$DRY_RUN" == true ]]; then
    msg "DRY RUN: write .gitleaks.toml (useDefault = true, allowlist: CHANGELOG.md)"
    return 0
  fi
  cat >.gitleaks.toml <<'EOF'
[extend]
useDefault = true

[allowlist]
description = "global allowlist"
paths = [
  "CHANGELOG.md",
  ".gitleaks.toml",
]
EOF
  msg "✅ .gitleaks.toml created."
}

install_pre_commit_hook() {
  if [[ "$NO_HOOK" == true ]]; then
    msg "⏭️ Skipping pre-commit hook installation (--no-hook)."
    return 0
  fi
  local hook_path=".git/hooks/pre-commit"
  if [[ -f "$hook_path" ]]; then
    msg "✅ Pre-commit hook already exists. Skipping."
    return 0
  fi
  msg "🔗 Installing Gitleaks pre-commit hook..."
  if [[ "$DRY_RUN" == true ]]; then
    msg "DRY RUN: write .git/hooks/pre-commit (gitleaks detect --staged --redact)"
    return 0
  fi
  mkdir -p .git/hooks
  cat >.git/hooks/pre-commit <<'EOF'
#!/usr/bin/env bash
# Block sensitive filenames from being staged
BLOCKED_PATTERN='\.(env|pem|key|p12|pfx|cer|crt|der|vault)$|^(id_rsa|id_dsa|id_ecdsa|id_ed25519)$|_(rsa|dsa|ecdsa|ed25519)$|^\.vault\.'
STAGED_FILES=$(git diff --cached --name-only 2>/dev/null)
BLOCKED=$(echo "$STAGED_FILES" | grep -E "$BLOCKED_PATTERN" | grep -v '\.env\.example$' | grep -v '\.env\.sample$' || true)
if [[ -n "$BLOCKED" ]]; then
  echo "❌ Commit blocked: sensitive file(s) staged:"
  echo "$BLOCKED" | sed 's/^/   /'
  echo "   Remove them with: git restore --staged <file>"
  exit 1
fi

# Gitleaks secret scan on staged content
if command -v gitleaks &>/dev/null; then
  if ! gitleaks protect --staged --redact -v 2>&1; then
    echo "❌ Gitleaks detected secrets in staged files. Commit blocked."
    echo "   Fix the file shown above, then re-stage and commit."
    echo "   False positive? Add an allowlist entry to .gitleaks.toml"
    exit 1
  fi
fi
EOF
  chmod +x "$hook_path"
  msg "✅ Pre-commit hook installed at $hook_path"
}

write_github_actions_workflow() {
  local workflow_dir=".github/workflows"
  local workflow_file="$workflow_dir/gitleaks.yml"
  if [[ -f "$workflow_file" ]]; then
    if grep -q "permissions:" "$workflow_file" 2>/dev/null; then
      msg "✅ $workflow_file already exists. Skipping."
      return 0
    fi
    msg "⚠️ $workflow_file missing permissions: block — regenerating..."
  else
    msg "⚙️ Adding GitHub Actions Gitleaks workflow..."
  fi
  if [[ "$DRY_RUN" == true ]]; then
    msg "DRY RUN: write $workflow_file (gitleaks-action@v2 on push + PR)"
    return 0
  fi
  mkdir -p "$workflow_dir"
  cat >"$workflow_file" <<'EOF'
name: Gitleaks Secret Scanner
on:
  push:
    branches: ["**"]
  pull_request:
    branches: ["**"]
permissions:
  read-all
jobs:
  gitleaks:
    name: Detect secrets
    runs-on: ubuntu-latest
    permissions:
      contents: read
      security-events: write
    steps:
      - uses: actions/checkout@34e114876b0b11c390a56381ad16ebd13914f8d5  # v4.3.1
        with:
          fetch-depth: 0
      - uses: gitleaks/gitleaks-action@ff98106e4c7b2bc287b24eaf42907196329070c7  # v2
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
EOF
  msg "✅ $workflow_file created."
}

write_release_workflow() {
  local workflow_dir=".github/workflows"
  local workflow_file="$workflow_dir/release.yml"
  if [[ -f "$workflow_file" ]]; then
    msg "✅ $workflow_file already exists. Skipping."
    return 0
  fi
  msg "⚙️ Adding GitHub Actions release workflow..."
  if [[ "$DRY_RUN" == true ]]; then
    msg "DRY RUN: write $workflow_file (gh release create on v* tag push)"
    return 0
  fi
  mkdir -p "$workflow_dir"
  cat >"$workflow_file" <<'EOF'
name: Release

on:
  push:
    tags:
      - 'v*'

permissions:
  contents: write

jobs:
  release:
    name: Create GitHub release
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@34e114876b0b11c390a56381ad16ebd13914f8d5  # v4.3.1
        with:
          fetch-depth: 0
      - name: Create release
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        run: |
          if gh release view "${GITHUB_REF_NAME}" > /dev/null 2>&1; then
            echo "Release ${GITHUB_REF_NAME} already exists — skipping."
          else
            gh release create "${GITHUB_REF_NAME}" \
              --title "${GITHUB_REF_NAME}" \
              --generate-notes
          fi
EOF
  msg "✅ $workflow_file created."
}

