#!/usr/bin/env bash
set -euo pipefail

# shellcheck disable=SC2034
VERSION="2.0.21"

supports_color() {
  [[ -t 1 ]] && [[ "${TERM:-}" != "dumb" ]] && [[ -z "${NO_COLOR:-}" ]]
}

init_colors() {
  if supports_color; then
    RED=$'\e[31m'
    GREEN=$'\e[32m'
    YELLOW=$'\e[33m'
    BLUE=$'\e[34m'
    MAGENTA=$'\e[35m'
    CYAN=$'\e[36m'
    BOLD=$'\e[1m'
    DIM=$'\e[2m'
    RESET=$'\e[0m'
  else
    RED=""
    GREEN=""
    YELLOW=""
    BLUE=""
    MAGENTA=""
    CYAN=""
    BOLD=""
    DIM=""
    RESET=""
  fi
}

init_colors

QUIET=0
GENERATE_TREE=0

# Existing flags
BUMP_TYPE=""
PREVIEW_MODE=false
VERIFY_MODE=false

# v1.x flags
INIT_REPO=false
INIT_REMOTE=false
REMOTE_VISIBILITY="private"
RELEASE_BUMP=""
VERSION_FILE="VERSION"
BRANCH=""
COMMIT_MESSAGE_OVERRIDE=""
DRY_RUN=false

# v2.0 security flags
SCAN_MODE=false         # --scan: run standalone gitleaks scan and exit
NO_SCAN=false           # --no-scan: skip auto staged scan before commit
NO_HOOK=false           # --no-hook: skip pre-commit hook installation during --init-repo
ENABLE_SECRET_SCANNING=false  # --secret-scanning: enable GitHub secret scanning on remote
AUDIT_MODE=false        # --audit: check which guardrails are present/missing
HARDEN_MODE=false       # --harden: install missing guardrails in existing repo

# v2.1 release flags
RELEASE_FORCE=false         # --force: overwrite existing tag + GitHub release
RELEASE_NO_RELEASE=false    # --no-release: tag+push only, skip GitHub release
RELEASE_GENERATE_NOTES=false # --generate-notes: auto-generate release notes via gh
READ_VERSION_ONLY=false     # --read-version-only: print version inventory and exit

msg() { [[ $QUIET -eq 0 ]] && echo "$*"; }
always_msg() { echo "$*"; }
die() {
  printf "%s\n" "${RED}❌${RESET} $*" >&2
  exit 1
}

usage() {
  printf "%s\n" \
    "${BOLD}${CYAN}commit_gh${RESET} ${DIM}v${VERSION}${RESET}" \
    "" \
    "${BOLD}Usage:${RESET} commit_gh [options]" \
    "" \
    "${BOLD}${BLUE}Core behavior (unchanged):${RESET}" \
    "  - Adds/commits/pushes when needed" \
    "  - Stashes local changes before pull --rebase" \
    "  - Detects rebase/merge in progress and exits safely" \
    "  - Optional folder tree regeneration" \
    "  - Optional tag bump from latest git tag (${BOLD}--bump${RESET})" \
    "" \
    "${BOLD}${MAGENTA}New capabilities:${RESET}" \
    "  ${BOLD}--init-repo${RESET}                 Initialize a git repo in the current directory if missing" \
    "  ${BOLD}--init-remote${RESET}               Create 'origin' via GitHub CLI (gh) if missing" \
    "  ${BOLD}--public${RESET}                    When creating remote, make it public" \
    "  ${BOLD}--private${RESET}                   When creating remote, make it private (default)" \
    "  ${BOLD}--release${RESET} ${YELLOW}patch|minor|major|x.y.z${RESET}  Bump VERSION, commit, tag, push, GitHub release" \
    "  ${BOLD}--force${RESET}                     Overwrite existing tag and GitHub release (use with --release)" \
    "  ${BOLD}--no-release${RESET}                Tag and push only; skip GitHub release creation" \
    "  ${BOLD}--generate-notes${RESET}            Auto-generate GitHub release notes (default: static message)" \
    "  ${BOLD}--read-version-only${RESET}         Print version inventory (VERSION file, script, tag) and exit" \
    "  ${BOLD}--version-file${RESET} ${YELLOW}<path>${RESET}       Version file to use for --release (default: VERSION)" \
    "  ${BOLD}--branch${RESET} ${YELLOW}<name>${RESET}             Branch to use (default: detected current branch, else main)" \
    "  ${BOLD}--message${RESET} ${YELLOW}\"<msg>\"${RESET}           Override commit message (default: chore: release vX.Y.Z)" \
    "  ${BOLD}--dry-run${RESET}                   Show what would happen without making changes" \
    "" \
    "${BOLD}${RED}Security (v2.0):${RESET}" \
    "  ${BOLD}--audit${RESET}                     Check which security guardrails are present/missing" \
    "  ${BOLD}--harden${RESET}                    Install missing guardrails in an existing repo" \
    "  ${BOLD}--scan${RESET}                      Run Gitleaks secret scan on full working tree and exit" \
    "  ${BOLD}--no-scan${RESET}                   Skip automatic Gitleaks staged scan before commit" \
    "  ${BOLD}--no-hook${RESET}                   Skip pre-commit hook installation during --init-repo" \
    "  ${BOLD}--secret-scanning${RESET}           Enable GitHub secret scanning + push protection on remote" \
    "" \
    "  ${DIM}--init-repo and --harden both install:${RESET}" \
    "    ${DIM}·${RESET} ${CYAN}.gitignore${RESET}               Strong defaults (secrets, OS, editor, build)" \
    "    ${DIM}·${RESET} ${CYAN}.env.example${RESET}             Template — commit this, never .env" \
    "    ${DIM}·${RESET} ${CYAN}.gitleaks.toml${RESET}           Gitleaks config (allowlist CHANGELOG, etc.)" \
    "    ${DIM}·${RESET} ${CYAN}.git/hooks/pre-commit${RESET}    Blocks sensitive filenames + secret content" \
    "    ${DIM}·${RESET} ${CYAN}.github/workflows/gitleaks.yml${RESET}  CI scan (SHA-pinned, permissions: read-all)" \
    "" \
    "${BOLD}${GREEN}Existing options:${RESET}" \
    "  ${BOLD}--quiet${RESET}, ${BOLD}-q${RESET}                 Suppress most output" \
    "  ${BOLD}--tree${RESET} ${YELLOW}[true|false]${RESET}         Generate folder tree if folder_tree exists" \
    "  ${BOLD}--bump${RESET} ${YELLOW}patch|minor|major${RESET}    Create new git tag based on latest git tag" \
    "  ${BOLD}--preview${RESET}                   Preview next tag for --bump without creating it" \
    "  ${BOLD}--verify${RESET}                    Run verification checks (working tree clean, etc.)" \
    "  ${BOLD}--help${RESET}, ${BOLD}-h${RESET}                  Show this help and exit" \
    "  ${BOLD}--version${RESET}                   Show script version" \
    "" \
    "${BOLD}${BLUE}Examples:${RESET}" \
    "  ${CYAN}commit_gh${RESET} --init-repo --init-remote" \
    "  ${CYAN}commit_gh${RESET} --init-repo --init-remote --public --secret-scanning" \
    "  ${CYAN}commit_gh${RESET} --scan" \
    "  ${CYAN}commit_gh${RESET} --release patch" \
    "  ${CYAN}commit_gh${RESET} --release 2.1.0 --generate-notes" \
    "  ${CYAN}commit_gh${RESET} --release patch --force" \
    "  ${CYAN}commit_gh${RESET} --release minor --no-release" \
    "  ${CYAN}commit_gh${RESET} --read-version-only" \
    "  ${CYAN}commit_gh${RESET} --message \"chore: sync changes\" --tree true" \
    ""
}

# ----------------------------
# Argument parsing
# ----------------------------
while [[ $# -gt 0 ]]; do
  case "$1" in
  --help | -h)
    usage
    exit 0
    ;;
  --version)
    echo "commit_gh version $VERSION"
    exit 0
    ;;
  --quiet | -q) QUIET=1 ;;
  --dry-run) DRY_RUN=true ;;
  --init-repo) INIT_REPO=true ;;
  --init-remote) INIT_REMOTE=true ;;
  --public) REMOTE_VISIBILITY="public" ;;
  --private) REMOTE_VISIBILITY="private" ;;
  --audit) AUDIT_MODE=true ;;
  --harden) HARDEN_MODE=true ;;
  --scan) SCAN_MODE=true ;;
  --no-scan) NO_SCAN=true ;;
  --no-hook) NO_HOOK=true ;;
  --secret-scanning) ENABLE_SECRET_SCANNING=true ;;
  --force) RELEASE_FORCE=true ;;
  --no-release) RELEASE_NO_RELEASE=true ;;
  --generate-notes) RELEASE_GENERATE_NOTES=true ;;
  --read-version-only) READ_VERSION_ONLY=true ;;
  --branch)
    [[ -n "${2:-}" ]] || die "--branch requires a value"
    BRANCH="$2"
    shift
    ;;
  --version-file)
    [[ -n "${2:-}" ]] || die "--version-file requires a value"
    VERSION_FILE="$2"
    shift
    ;;
  --message)
    [[ -n "${2:-}" ]] || die "--message requires a value"
    COMMIT_MESSAGE_OVERRIDE="$2"
    shift
    ;;
  --release)
    if [[ "${2:-}" =~ ^(patch|minor|major)$ ]]; then
      RELEASE_BUMP="$2"
      shift
    elif [[ "${2:-}" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
      RELEASE_BUMP="$2"
      shift
    else
      die "--release requires: patch | minor | major | x.y.z  (got: '${2:-}')"
    fi
    ;;
  --bump)
    case "${2:-patch}" in patch | minor | major)
      BUMP_TYPE="$2"
      shift
      ;;
    *) die "Invalid value for --bump. Use: patch | minor | major" ;;
    esac
    ;;
  --preview) PREVIEW_MODE=true ;;
  --verify) VERIFY_MODE=true ;;
  --tree)
    if [[ "${2:-}" =~ ^(true|false)$ ]]; then
      [[ "$2" == "true" ]] && GENERATE_TREE=1
      shift
    else
      GENERATE_TREE=1
    fi
    ;;
  *) die "Unknown option: $1" ;;
  esac
  shift
done

# ----------------------------
# Helpers
# ----------------------------
in_git_repo() { git rev-parse --is-inside-work-tree >/dev/null 2>&1; }

# ----------------------------
# Security helpers
# ----------------------------
gitleaks_available() { command -v gitleaks >/dev/null 2>&1; }

COMMIT_BLOCKED_PATTERN='\.(env|pem|key|p12|pfx|cer|crt|der|vault)$|^(id_rsa|id_dsa|id_ecdsa|id_ed25519)$|_(rsa|dsa|ecdsa|ed25519)$|^\.vault\.'

unstage_blocked_files() {
  local blocked
  blocked="$(git diff --cached --name-only 2>/dev/null \
    | grep -E "$COMMIT_BLOCKED_PATTERN" \
    | grep -v '\.env\.example$' \
    | grep -v '\.env\.sample$' \
    || true)"
  [[ -z "$blocked" ]] && return 0
  msg "⚠️ Unstaging sensitive file(s) — add to .gitignore to prevent restaging:"
  while IFS= read -r f; do
    msg "   🚫 $f"
    # git restore --staged requires HEAD; use git rm --cached for new/empty-repo files
    if git rev-parse HEAD >/dev/null 2>&1 && git cat-file -e "HEAD:$f" 2>/dev/null; then
      git restore --staged "$f" >/dev/null 2>&1 \
        || msg "   ⚠️ Could not unstage $f — run: git restore --staged \"$f\""
    else
      git rm --cached "$f" >/dev/null 2>&1 \
        || msg "   ⚠️ Could not unstage $f — run: git rm --cached \"$f\""
    fi
  done <<< "$blocked"
}

write_gitignore() {
  local gi_path=".gitignore"
  if [[ -f "$gi_path" ]]; then
    local _has_env _has_star_env _has_vault _missing=()
    grep -qE '^\.env$|^\.env\b' "$gi_path" 2>/dev/null && _has_env=true || _has_env=false
    grep -qE '^\*\.env$' "$gi_path" 2>/dev/null && _has_star_env=true || _has_star_env=false
    grep -qE '^\.vault\.\*$' "$gi_path" 2>/dev/null && _has_vault=true || _has_vault=false

    if [[ "$_has_env" == false ]]; then
      msg "⚠️ .gitignore exists but missing .env coverage — appending secrets block..."
      if [[ "$DRY_RUN" == true ]]; then
        msg "DRY RUN: append secrets block to .gitignore"
        return 0
      fi
      cat >>"$gi_path" <<'EOF'

# ── Secrets & credentials (added by commit_gh --harden) ────────
.env
.env.*
*.env
!.env.example
!.env.sample
.vault.*
*.vault
*.pem
*.key
*.p12
*.pfx
*.cer
*.crt
*.der
id_rsa
id_dsa
id_ecdsa
id_ed25519
*_rsa
*_dsa
*_ecdsa
*_ed25519
EOF
      msg "✅ Secrets block appended to .gitignore."
      return 0
    fi

    # Check for individual missing patterns and append each
    [[ "$_has_star_env" == false ]] && _missing+=("*.env")
    [[ "$_has_vault" == false ]] && _missing+=(".vault.*" "*.vault")

    if [[ ${#_missing[@]} -eq 0 ]]; then
      msg "✅ .gitignore already exists. Skipping."
      return 0
    fi

    msg "⚠️ .gitignore missing patterns (${_missing[*]}) — appending..."
    if [[ "$DRY_RUN" == true ]]; then
      msg "DRY RUN: append ${_missing[*]} to .gitignore"
      return 0
    fi
    printf '\n# ── Added by commit_gh --harden ─────────────────────────────\n' >>"$gi_path"
    for _p in "${_missing[@]}"; do
      printf '%s\n' "$_p" >>"$gi_path"
    done
    msg "✅ Appended to .gitignore: ${_missing[*]}"
    return 0
  fi
  msg "📄 Writing .gitignore..."
  if [[ "$DRY_RUN" == true ]]; then
    msg "DRY RUN: write .gitignore (secrets, OS, editor, build patterns)"
    return 0
  fi
  cat >"$gi_path" <<'EOF'
# ── Secrets & credentials ──────────────────────────────────────
.env
.env.*
*.env
!.env.example
!.env.sample
.vault.*
*.vault
*.pem
*.key
*.p12
*.pfx
*.cer
*.crt
*.der
id_rsa
id_dsa
id_ecdsa
id_ed25519
*_rsa
*_dsa
*_ecdsa
*_ed25519

# ── OS ────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
desktop.ini

# ── Editor ────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
*.orig

# ── Build artifacts ───────────────────────────────────────────
dist/
build/
out/
*.o
*.a
*.so
*.dylib

# ── Dependencies ──────────────────────────────────────────────
node_modules/
vendor/
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# ── Logs & temp ───────────────────────────────────────────────
*.log
logs/
tmp/
temp/
.tmp/

# ── Coverage & test output ────────────────────────────────────
.coverage
coverage/
htmlcov/
.pytest_cache/
*.lcov
EOF
  msg "✅ .gitignore created."
}

write_env_example() {
  if [[ -f ".env.example" ]]; then
    msg "✅ .env.example already exists. Skipping."
    return 0
  fi
  msg "📄 Writing .env.example..."
  if [[ "$DRY_RUN" == true ]]; then
    msg "DRY RUN: write .env.example"
    return 0
  fi
  cat >".env.example" <<'EOF'
# Copy this file to .env and fill in your values.
# NEVER commit .env — it is listed in .gitignore.

# Example:
# DATABASE_URL=postgres://user:password@localhost:5432/mydb
# API_KEY=your_api_key_here
# SECRET_TOKEN=your_secret_here
EOF
  msg "✅ .env.example created."
}

write_gitleaks_toml() {
  local toml_path=".gitleaks.toml"
  if [[ -f "$toml_path" ]]; then
    msg "✅ .gitleaks.toml already exists. Skipping."
    return 0
  fi
  msg "🔒 Writing .gitleaks.toml..."
  if [[ "$DRY_RUN" == true ]]; then
    msg "DRY RUN: write .gitleaks.toml (useDefault = true, allowlist: CHANGELOG.md)"
    return 0
  fi
  cat >.gitleaks.toml <<'EOF'
[extend]
useDefault = true

[allowlist]
description = "global allowlist"
paths = [
  "CHANGELOG.md",
  ".gitleaks.toml",
]
EOF
  msg "✅ .gitleaks.toml created."
}

install_pre_commit_hook() {
  if [[ "$NO_HOOK" == true ]]; then
    msg "⏭️ Skipping pre-commit hook installation (--no-hook)."
    return 0
  fi
  local hook_path=".git/hooks/pre-commit"
  if [[ -f "$hook_path" ]]; then
    msg "✅ Pre-commit hook already exists. Skipping."
    return 0
  fi
  msg "🔗 Installing Gitleaks pre-commit hook..."
  if [[ "$DRY_RUN" == true ]]; then
    msg "DRY RUN: write .git/hooks/pre-commit (gitleaks detect --staged --redact)"
    return 0
  fi
  mkdir -p .git/hooks
  cat >.git/hooks/pre-commit <<'EOF'
#!/usr/bin/env bash
# Block sensitive filenames from being staged
BLOCKED_PATTERN='\.(env|pem|key|p12|pfx|cer|crt|der|vault)$|^(id_rsa|id_dsa|id_ecdsa|id_ed25519)$|_(rsa|dsa|ecdsa|ed25519)$|^\.vault\.'
STAGED_FILES=$(git diff --cached --name-only 2>/dev/null)
BLOCKED=$(echo "$STAGED_FILES" | grep -E "$BLOCKED_PATTERN" | grep -v '\.env\.example$' | grep -v '\.env\.sample$' || true)
if [[ -n "$BLOCKED" ]]; then
  echo "❌ Commit blocked: sensitive file(s) staged:"
  echo "$BLOCKED" | sed 's/^/   /'
  echo "   Remove them with: git restore --staged <file>"
  exit 1
fi

# Gitleaks secret scan on staged content
if command -v gitleaks &>/dev/null; then
  if ! gitleaks protect --staged --redact -v 2>&1; then
    echo "❌ Gitleaks detected secrets in staged files. Commit blocked."
    echo "   Fix the file shown above, then re-stage and commit."
    echo "   False positive? Add an allowlist entry to .gitleaks.toml"
    exit 1
  fi
fi
EOF
  chmod +x "$hook_path"
  msg "✅ Pre-commit hook installed at $hook_path"
}

write_github_actions_workflow() {
  local workflow_dir=".github/workflows"
  local workflow_file="$workflow_dir/gitleaks.yml"
  if [[ -f "$workflow_file" ]]; then
    if grep -q "permissions:" "$workflow_file" 2>/dev/null; then
      msg "✅ $workflow_file already exists. Skipping."
      return 0
    fi
    msg "⚠️ $workflow_file missing permissions: block — regenerating..."
  else
    msg "⚙️ Adding GitHub Actions Gitleaks workflow..."
  fi
  if [[ "$DRY_RUN" == true ]]; then
    msg "DRY RUN: write $workflow_file (gitleaks-action@v2 on push + PR)"
    return 0
  fi
  mkdir -p "$workflow_dir"
  cat >"$workflow_file" <<'EOF'
name: Gitleaks Secret Scanner
on:
  push:
    branches: ["**"]
  pull_request:
    branches: ["**"]
permissions:
  read-all
jobs:
  gitleaks:
    name: Detect secrets
    runs-on: ubuntu-latest
    permissions:
      contents: read
      security-events: write
    steps:
      - uses: actions/checkout@34e114876b0b11c390a56381ad16ebd13914f8d5  # v4.3.1
        with:
          fetch-depth: 0
      - uses: gitleaks/gitleaks-action@ff98106e4c7b2bc287b24eaf42907196329070c7  # v2
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
EOF
  msg "✅ $workflow_file created."
}

write_release_workflow() {
  local workflow_dir=".github/workflows"
  local workflow_file="$workflow_dir/release.yml"
  if [[ -f "$workflow_file" ]]; then
    msg "✅ $workflow_file already exists. Skipping."
    return 0
  fi
  msg "⚙️ Adding GitHub Actions release workflow..."
  if [[ "$DRY_RUN" == true ]]; then
    msg "DRY RUN: write $workflow_file (gh release create on v* tag push)"
    return 0
  fi
  mkdir -p "$workflow_dir"
  cat >"$workflow_file" <<'EOF'
name: Release

on:
  push:
    tags:
      - 'v*'

permissions:
  contents: write

jobs:
  release:
    name: Create GitHub release
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@34e114876b0b11c390a56381ad16ebd13914f8d5  # v4.3.1
        with:
          fetch-depth: 0
      - name: Create release
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        run: |
          if gh release view "${GITHUB_REF_NAME}" > /dev/null 2>&1; then
            echo "Release ${GITHUB_REF_NAME} already exists — skipping."
          else
            gh release create "${GITHUB_REF_NAME}" \
              --title "${GITHUB_REF_NAME}" \
              --generate-notes
          fi
EOF
  msg "✅ $workflow_file created."
}

write_changelog() {
  if [[ -f "CHANGELOG.md" ]]; then
    msg "✅ CHANGELOG.md already exists. Skipping."
    return 0
  fi
  msg "📄 Writing CHANGELOG.md..."
  if [[ "$DRY_RUN" == true ]]; then
    msg "DRY RUN: write CHANGELOG.md (Keep a Changelog format)"
    return 0
  fi
  cat >"CHANGELOG.md" <<'EOF'
# Changelog

All notable changes to this project will be documented in this file.

The format is based on [Keep a Changelog](https://keepachangelog.com/en/1.1.0/),
and this project adheres to [Semantic Versioning](https://semver.org/spec/v2.0.0.html).

## [Unreleased]

### Added
### Changed
### Deprecated
### Removed
### Fixed
### Security
EOF
  msg "✅ CHANGELOG.md created."
}

write_license() {
  if [[ -f "LICENSE" ]]; then
    msg "✅ LICENSE already exists. Skipping."
    return 0
  fi
  msg "📄 Writing LICENSE (MIT)..."
  if [[ "$DRY_RUN" == true ]]; then
    msg "DRY RUN: write LICENSE (MIT, current year, git user.name)"
    return 0
  fi
  local year author
  year="$(date +%Y)"
  author="$(git config user.name 2>/dev/null || echo "The Authors")"
  cat >"LICENSE" <<EOF
MIT License

Copyright (c) ${year} ${author}

Permission is hereby granted, free of charge, to any person obtaining a copy
of this software and associated documentation files (the "Software"), to deal
in the Software without restriction, including without limitation the rights
to use, copy, modify, merge, publish, distribute, sublicense, and/or sell
copies of the Software, and to permit persons to whom the Software is
furnished to do so, subject to the following conditions:

The above copyright notice and this permission notice shall be included in all
copies or substantial portions of the Software.

THE SOFTWARE IS PROVIDED "AS IS", WITHOUT WARRANTY OF ANY KIND, EXPRESS OR
IMPLIED, INCLUDING BUT NOT LIMITED TO THE WARRANTIES OF MERCHANTABILITY,
FITNESS FOR A PARTICULAR PURPOSE AND NONINFRINGEMENT. IN NO EVENT SHALL THE
AUTHORS OR COPYRIGHT HOLDERS BE LIABLE FOR ANY CLAIM, DAMAGES OR OTHER
LIABILITY, WHETHER IN AN ACTION OF CONTRACT, TORT OR OTHERWISE, ARISING FROM,
OUT OF OR IN CONNECTION WITH THE SOFTWARE OR THE USE OR OTHER DEALINGS IN THE
SOFTWARE.
EOF
  msg "✅ LICENSE created."
}

write_readme() {
  if [[ -f "README.md" ]]; then
    msg "✅ README.md already exists. Skipping."
    return 0
  fi
  msg "📄 Writing README.md..."
  if [[ "$DRY_RUN" == true ]]; then
    msg "DRY RUN: write README.md (starter template)"
    return 0
  fi
  local repo_name
  repo_name="$(basename "$(git rev-parse --show-toplevel 2>/dev/null || pwd)")"
  cat >"README.md" <<EOF
# ${repo_name}

> Short description of what this project does.

## Getting started

\`\`\`bash
git clone <repo-url>
cd ${repo_name}
cp .env.example .env
\`\`\`

## Usage

<!-- describe usage here -->

## Contributing

See [CONTRIBUTING.md](CONTRIBUTING.md).

## License

[MIT](LICENSE)
EOF
  msg "✅ README.md created."
}

write_contributing() {
  if [[ -f "CONTRIBUTING.md" ]]; then
    msg "✅ CONTRIBUTING.md already exists. Skipping."
    return 0
  fi
  msg "📄 Writing CONTRIBUTING.md..."
  if [[ "$DRY_RUN" == true ]]; then
    msg "DRY RUN: write CONTRIBUTING.md"
    return 0
  fi
  cat >"CONTRIBUTING.md" <<'EOF'
# Contributing

Thank you for considering contributing to this project!

## Workflow

1. Fork the repository and create a feature branch from \`main\`.
2. Make your changes, following the code style of the project.
3. Commit using clear, conventional commit messages (\`feat:\`, \`fix:\`, \`chore:\`, etc.).
4. Open a pull request against \`main\` with a description of what changed and why.

## Commit messages

Use [Conventional Commits](https://www.conventionalcommits.org/):

\`\`\`
feat: add new feature
fix: correct a bug
chore: update dependencies
docs: improve README
\`\`\`

## Secrets & security

- Never commit secrets, credentials, or \`.env\` files.
- The pre-commit hook will block sensitive filenames and run Gitleaks automatically.
- Report security vulnerabilities privately rather than opening a public issue.

## Code review

All pull requests require at least one approval before merging.
EOF
  msg "✅ CONTRIBUTING.md created."
}

write_dependabot() {
  local dep_file=".github/dependabot.yml"
  if [[ -f "$dep_file" ]]; then
    msg "✅ $dep_file already exists. Skipping."
    return 0
  fi
  msg "🤖 Writing $dep_file (github-actions weekly)..."
  if [[ "$DRY_RUN" == true ]]; then
    msg "DRY RUN: write $dep_file"
    return 0
  fi
  mkdir -p .github
  cat >"$dep_file" <<'EOF'
version: 2
updates:
  - package-ecosystem: "github-actions"
    directory: "/"
    schedule:
      interval: "weekly"
EOF
  msg "✅ $dep_file created."
}

write_issue_templates() {
  local tpl_dir=".github/ISSUE_TEMPLATE"
  if [[ -f "$tpl_dir/bug_report.md" ]] && [[ -f "$tpl_dir/feature_request.md" ]]; then
    msg "✅ Issue templates already exist. Skipping."
    return 0
  fi
  msg "📋 Writing issue templates..."
  if [[ "$DRY_RUN" == true ]]; then
    msg "DRY RUN: write $tpl_dir/bug_report.md + feature_request.md"
    return 0
  fi
  mkdir -p "$tpl_dir"
  cat >"$tpl_dir/bug_report.md" <<'EOF'
---
name: Bug report
about: Something isn't working
labels: bug
---

**Describe the bug**
A clear description of what the bug is.

**To reproduce**
Steps to reproduce the behaviour.

**Expected behaviour**
What you expected to happen.

**Environment**
- OS:
- Version:
EOF
  cat >"$tpl_dir/feature_request.md" <<'EOF'
---
name: Feature request
about: Suggest an idea
labels: enhancement
---

**Problem / motivation**
A clear description of the problem or gap.

**Proposed solution**
What you'd like to see added or changed.

**Alternatives considered**
Any alternative approaches you've looked at.
EOF
  msg "✅ Issue templates created."
}

write_pr_template() {
  local pr_file=".github/pull_request_template.md"
  if [[ -f "$pr_file" ]]; then
    msg "✅ $pr_file already exists. Skipping."
    return 0
  fi
  msg "📋 Writing $pr_file..."
  if [[ "$DRY_RUN" == true ]]; then
    msg "DRY RUN: write $pr_file"
    return 0
  fi
  mkdir -p .github
  cat >"$pr_file" <<'EOF'
## Summary

<!-- What does this PR do and why? -->

## Changes

-

## Test plan

- [ ] Tested locally
- [ ] No secrets or credentials introduced
- [ ] CHANGELOG.md updated (if applicable)

## Related issues

Closes #
EOF
  msg "✅ $pr_file created."
}

write_codeowners() {
  local co_file=".github/CODEOWNERS"
  if [[ -f "$co_file" ]]; then
    msg "✅ $co_file already exists. Skipping."
    return 0
  fi
  msg "👤 Writing $co_file..."
  if [[ "$DRY_RUN" == true ]]; then
    msg "DRY RUN: write $co_file (owner from git config user.name)"
    return 0
  fi
  local gh_user
  gh_user="$(gh api user --jq '.login' 2>/dev/null || git config user.name 2>/dev/null || echo "you")"
  mkdir -p .github
  cat >"$co_file" <<EOF
# Default owner for all files — update per directory as needed
* @${gh_user}
EOF
  msg "✅ $co_file created (owner: @${gh_user})."
}

write_editorconfig() {
  if [[ -f ".editorconfig" ]]; then
    msg "✅ .editorconfig already exists. Skipping."
    return 0
  fi
  msg "📄 Writing .editorconfig..."
  if [[ "$DRY_RUN" == true ]]; then
    msg "DRY RUN: write .editorconfig"
    return 0
  fi
  cat >".editorconfig" <<'EOF'
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
EOF
  msg "✅ .editorconfig created."
}

write_release_checklist() {
  local checklist="docs/release-checklist.md"
  if [[ -f "$checklist" ]]; then
    msg "✅ $checklist already exists. Skipping."
    return 0
  fi
  msg "📋 Writing $checklist..."
  if [[ "$DRY_RUN" == true ]]; then
    msg "DRY RUN: write $checklist"
    return 0
  fi
  mkdir -p docs
  cat >"$checklist" <<'EOF'
# Release checklist

## Before tagging

- [ ] All changes merged to `main`
- [ ] CHANGELOG.md updated — move items from `[Unreleased]` to a new version section
- [ ] Version bump decided (patch / minor / major)

## Tag and release

- [ ] Run `commit_gh --release <patch|minor|major>` (or `--release x.y.z` for explicit version)
- [ ] Confirm GitHub release created and release workflow passed in Actions

## After release

- [ ] Announce if applicable
- [ ] Open a fresh `[Unreleased]` section in CHANGELOG.md
EOF
  msg "✅ $checklist created."
}

enable_github_secret_scanning() {
  command -v gh >/dev/null 2>&1 || {
    msg "⚠️ gh not found. Skipping secret scanning enablement."
    return 0
  }
  has_origin_remote || {
    msg "⚠️ No origin remote. Skipping secret scanning enablement."
    return 0
  }

  local remote_url repo_slug
  remote_url="$(git remote get-url origin 2>/dev/null || echo "")"
  repo_slug="$(echo "$remote_url" | sed -E 's|.*github\.com[:/]([^/]+/[^/.]+)(\.git)?$|\1|')"

  if [[ -z "$repo_slug" || "$repo_slug" == "$remote_url" ]]; then
    msg "⚠️ Could not determine GitHub repo slug from origin. Skipping secret scanning."
    return 0
  fi

  msg "🔐 Enabling GitHub secret scanning + push protection on $repo_slug..."
  if [[ "$DRY_RUN" == true ]]; then
    msg "DRY RUN: gh api PATCH /repos/$repo_slug → secret_scanning=enabled"
    msg "DRY RUN: gh api PATCH /repos/$repo_slug → secret_scanning_push_protection=enabled"
    return 0
  fi

  if gh api --method PATCH "/repos/$repo_slug" \
    -f "security_and_analysis[secret_scanning][status]=enabled" \
    -f "security_and_analysis[secret_scanning_push_protection][status]=enabled" \
    >/dev/null 2>&1; then
    msg "✅ GitHub secret scanning and push protection enabled."
  else
    msg "⚠️ Could not enable secret scanning (requires GitHub Advanced Security or public repo). Skipping."
  fi
}

run_gitleaks_scan() {
  local mode="${1:-source}"  # "source" = full tree, "staged" = only staged files
  if ! gitleaks_available; then
    return 0  # silent skip — commit_gh --audit will surface this gap
  fi
  if [[ "$mode" == "staged" ]]; then
    msg "🔍 Gitleaks: scanning staged files..."
    if [[ "$DRY_RUN" == true ]]; then
      msg "DRY RUN: gitleaks protect --staged --redact"
      return 0
    fi
    if ! gitleaks protect --staged --redact -v 2>&1; then
      die "Gitleaks detected secrets in staged files. Commit blocked. Review output above."
    fi
    msg "✅ Gitleaks staged scan clean."
  else
    msg "🔍 Gitleaks: scanning full working tree..."
    if [[ "$DRY_RUN" == true ]]; then
      msg "DRY RUN: gitleaks detect --source . --redact"
      return 0
    fi
    if ! gitleaks detect --source . --redact --exit-code 1 2>&1; then
      die "Gitleaks detected secrets. Review output above and remove before committing."
    fi
    msg "✅ Gitleaks scan clean."
  fi
}

setup_security_files() {
  write_gitignore
  write_env_example
  write_gitleaks_toml
  install_pre_commit_hook
  write_github_actions_workflow
  write_release_workflow
  write_dependabot
  write_changelog
  write_license
  write_readme
  write_contributing
  write_issue_templates
  write_pr_template
  write_codeowners
  write_editorconfig
  write_release_checklist
}

run_audit() {
  local repo_name issues=0

  in_git_repo || die "Not inside a git repository."
  cd "$(git rev-parse --show-toplevel)" || exit 1
  repo_name="$(basename "$(pwd)")"

  local sep="${DIM}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"

  always_msg "${BOLD}🔍 Security audit:${RESET} ${CYAN}${repo_name}${RESET}"
  always_msg "$sep"

  # gitleaks binary
  if gitleaks_available; then
    always_msg "  ${GREEN}✅${RESET}  gitleaks binary          $(command -v gitleaks)"
  else
    always_msg "  ${RED}❌${RESET}  gitleaks binary          not installed  ${DIM}→ brew install gitleaks${RESET}"
    issues=$((issues + 1))
  fi

  # .gitleaks.toml
  if [[ -f ".gitleaks.toml" ]]; then
    always_msg "  ${GREEN}✅${RESET}  .gitleaks.toml           present"
  else
    always_msg "  ${RED}❌${RESET}  .gitleaks.toml           missing        ${DIM}→ commit_gh --harden${RESET}"
    issues=$((issues + 1))
  fi

  # pre-commit hook
  if [[ -f ".git/hooks/pre-commit" ]] && grep -q "gitleaks" ".git/hooks/pre-commit" 2>/dev/null; then
    always_msg "  ${GREEN}✅${RESET}  .git/hooks/pre-commit    gitleaks hook present"
  elif [[ -f ".git/hooks/pre-commit" ]]; then
    always_msg "  ${YELLOW}⚠️${RESET}   .git/hooks/pre-commit    exists but no gitleaks call  ${DIM}→ commit_gh --harden --no-hook skips; edit manually${RESET}"
    issues=$((issues + 1))
  else
    always_msg "  ${RED}❌${RESET}  .git/hooks/pre-commit    missing        ${DIM}→ commit_gh --harden${RESET}"
    issues=$((issues + 1))
  fi

  # GitHub Actions workflow
  if [[ -f ".github/workflows/gitleaks.yml" ]]; then
    if grep -q "permissions:" ".github/workflows/gitleaks.yml" 2>/dev/null; then
      always_msg "  ${GREEN}✅${RESET}  .github/workflows/gitleaks.yml   present (permissions set)"
    else
      always_msg "  ${YELLOW}⚠️${RESET}   .github/workflows/gitleaks.yml   present but missing permissions: block  ${DIM}→ commit_gh --harden regenerates${RESET}"
      issues=$((issues + 1))
    fi
  else
    always_msg "  ${RED}❌${RESET}  .github/workflows/gitleaks.yml   missing  ${DIM}→ commit_gh --harden${RESET}"
    issues=$((issues + 1))
  fi

  # release workflow
  if [[ -f ".github/workflows/release.yml" ]]; then
    always_msg "  ${GREEN}✅${RESET}  .github/workflows/release.yml    present"
  else
    always_msg "  ${YELLOW}⚠️${RESET}   .github/workflows/release.yml    missing  ${DIM}→ commit_gh --harden${RESET}"
    issues=$((issues + 1))
  fi

  # .gitignore with .env and .vault.* coverage
  if [[ -f ".gitignore" ]]; then
    local _gi_missing=()
    grep -qE '^\.env$|^\.env\b|^\*\.env$' ".gitignore" 2>/dev/null || _gi_missing+=(".env")
    grep -qE '^\.vault\.\*$' ".gitignore" 2>/dev/null || _gi_missing+=(".vault.*")
    if [[ ${#_gi_missing[@]} -eq 0 ]]; then
      always_msg "  ${GREEN}✅${RESET}  .gitignore                       present (.env and .vault.* covered)"
    else
      always_msg "  ${YELLOW}⚠️${RESET}   .gitignore                       missing: ${_gi_missing[*]}  ${DIM}→ commit_gh --harden${RESET}"
      issues=$((issues + 1))
    fi
  else
    always_msg "  ${RED}❌${RESET}  .gitignore                       missing  ${DIM}→ commit_gh --harden${RESET}"
    issues=$((issues + 1))
  fi

  # .env.example
  if [[ -f ".env.example" ]] || [[ -f ".env.sample" ]]; then
    always_msg "  ${GREEN}✅${RESET}  .env.example                     present"
  else
    always_msg "  ${YELLOW}⚠️${RESET}   .env.example                     missing  ${DIM}→ commit_gh --harden${RESET}"
    issues=$((issues + 1))
  fi

  # CHANGELOG.md
  if [[ -f "CHANGELOG.md" ]]; then
    always_msg "  ${GREEN}✅${RESET}  CHANGELOG.md                     present"
  else
    always_msg "  ${YELLOW}⚠️${RESET}   CHANGELOG.md                     missing  ${DIM}→ commit_gh --harden${RESET}"
    issues=$((issues + 1))
  fi

  # LICENSE
  if [[ -f "LICENSE" ]]; then
    always_msg "  ${GREEN}✅${RESET}  LICENSE                          present"
  else
    always_msg "  ${YELLOW}⚠️${RESET}   LICENSE                          missing  ${DIM}→ commit_gh --harden${RESET}"
    issues=$((issues + 1))
  fi

  # README.md
  if [[ -f "README.md" ]]; then
    always_msg "  ${GREEN}✅${RESET}  README.md                        present"
  else
    always_msg "  ${YELLOW}⚠️${RESET}   README.md                        missing  ${DIM}→ commit_gh --harden${RESET}"
    issues=$((issues + 1))
  fi

  # CONTRIBUTING.md
  if [[ -f "CONTRIBUTING.md" ]]; then
    always_msg "  ${GREEN}✅${RESET}  CONTRIBUTING.md                  present"
  else
    always_msg "  ${YELLOW}⚠️${RESET}   CONTRIBUTING.md                  missing  ${DIM}→ commit_gh --harden${RESET}"
    issues=$((issues + 1))
  fi

  # dependabot
  if [[ -f ".github/dependabot.yml" ]]; then
    always_msg "  ${GREEN}✅${RESET}  .github/dependabot.yml           present"
  else
    always_msg "  ${YELLOW}⚠️${RESET}   .github/dependabot.yml           missing  ${DIM}→ commit_gh --harden${RESET}"
    issues=$((issues + 1))
  fi

  # issue templates
  if [[ -f ".github/ISSUE_TEMPLATE/bug_report.md" ]] || [[ -d ".github/ISSUE_TEMPLATE" ]]; then
    always_msg "  ${GREEN}✅${RESET}  .github/ISSUE_TEMPLATE/          present"
  else
    always_msg "  ${YELLOW}⚠️${RESET}   .github/ISSUE_TEMPLATE/          missing  ${DIM}→ commit_gh --harden${RESET}"
    issues=$((issues + 1))
  fi

  # PR template
  if [[ -f ".github/pull_request_template.md" ]]; then
    always_msg "  ${GREEN}✅${RESET}  .github/pull_request_template.md present"
  else
    always_msg "  ${YELLOW}⚠️${RESET}   .github/pull_request_template.md missing  ${DIM}→ commit_gh --harden${RESET}"
    issues=$((issues + 1))
  fi

  # CODEOWNERS
  if [[ -f ".github/CODEOWNERS" ]]; then
    always_msg "  ${GREEN}✅${RESET}  .github/CODEOWNERS               present"
  else
    always_msg "  ${YELLOW}⚠️${RESET}   .github/CODEOWNERS               missing  ${DIM}→ commit_gh --harden${RESET}"
    issues=$((issues + 1))
  fi

  # .editorconfig
  if [[ -f ".editorconfig" ]]; then
    always_msg "  ${GREEN}✅${RESET}  .editorconfig                    present"
  else
    always_msg "  ${YELLOW}⚠️${RESET}   .editorconfig                    missing  ${DIM}→ commit_gh --harden${RESET}"
    issues=$((issues + 1))
  fi

  # release checklist
  if [[ -f "docs/release-checklist.md" ]]; then
    always_msg "  ${GREEN}✅${RESET}  docs/release-checklist.md        present"
  else
    always_msg "  ${YELLOW}⚠️${RESET}   docs/release-checklist.md        missing  ${DIM}→ commit_gh --harden${RESET}"
    issues=$((issues + 1))
  fi

  always_msg "$sep"
  if [[ $issues -eq 0 ]]; then
    always_msg "  ${GREEN}${BOLD}All guardrails in place.${RESET} 🔒"
  else
    always_msg "  ${YELLOW}${BOLD}${issues} guardrail(s) missing.${RESET}  Run: ${CYAN}commit_gh --harden${RESET}"
  fi
  always_msg ""

  [[ $issues -eq 0 ]]  # exit 0 = clean, exit 1 = issues found
}

# ----------------------------
# Repo helpers
# ----------------------------
ensure_repo() {
  if in_git_repo; then
    cd "$(git rev-parse --show-toplevel)" || exit 1
    if [[ "$INIT_REPO" == true ]]; then
      # Already initialised — idempotently apply any missing security files
      setup_security_files
    fi
    return 0
  fi

  if [[ "$INIT_REPO" != true ]]; then
    die "Not inside a git repository. Re-run with --init-repo to initialize one."
  fi

  msg "🧰 Initializing git repository in: $(pwd)"
  if [[ "$DRY_RUN" == true ]]; then
    msg "DRY RUN: git init"
    msg "DRY RUN: git checkout -b main"
    msg "DRY RUN: setup_security_files (.gitleaks.toml, pre-commit hook, gitleaks.yml)"
    return 0
  fi

  git init >/dev/null
  if git show-ref --verify --quiet refs/heads/main; then
    git checkout main >/dev/null
  else
    git checkout -b main >/dev/null
  fi
  setup_security_files

  # Commit scaffold files now so gh repo create --push has commits to push
  # and sets the local origin remote correctly.
  git add . >/dev/null
  if ! git diff --cached --quiet; then
    git commit -m "chore: initial scaffold" >/dev/null
    msg "✅ Initial commit created."
  fi
}

detect_branch() {
  if [[ -n "$BRANCH" ]]; then
    echo "$BRANCH"
    return 0
  fi
  if git rev-parse --verify HEAD >/dev/null 2>&1; then
    git rev-parse --abbrev-ref HEAD
  else
    echo "main"
  fi
}

has_origin_remote() { git remote | grep -q '^origin$'; }

ensure_origin_remote() {
  if has_origin_remote; then
    return 0
  fi

  if [[ "$INIT_REMOTE" != true ]]; then
    msg "⚠️ No 'origin' remote configured. Push and GitHub release creation will be skipped."
    return 1
  fi

  command -v gh >/dev/null 2>&1 || die "GitHub CLI 'gh' is required for --init-remote."

  local repo_root repo_name visibility_flag
  repo_root="$(pwd)"
  repo_name="${GIT_REPO_NAME:-$(basename "$repo_root")}"
  visibility_flag="--private"
  [[ "$REMOTE_VISIBILITY" == "public" ]] && visibility_flag="--public"

  msg "🐙 Creating GitHub repo '$repo_name' via gh and setting origin..."
  if [[ "$DRY_RUN" == true ]]; then
    msg "DRY RUN: gh repo create \"$repo_name\" --source \"$repo_root\" $visibility_flag --push"
    return 0
  fi

  gh repo create "$repo_name" --source "$repo_root" $visibility_flag --push || true

  # gh --push exits non-zero when no commits exist; repo is created on GitHub but
  # origin may not be set locally — add it manually so try_push() can handle it.
  if has_origin_remote; then
    msg "✅ Remote created and initial push done."
  else
    local gh_user
    gh_user="$(gh api user --jq '.login' 2>/dev/null || echo "")"
    if [[ -n "$gh_user" ]]; then
      git remote add origin "git@github.com:${gh_user}/${repo_name}.git"
      msg "✅ GitHub repo created. Origin set — will push after commit."
    else
      msg "⚠️ GitHub repo created but could not set origin. Run: git remote add origin <url>"
    fi
  fi
}

ensure_no_rebase_or_merge() {
  if [ -d ".git/rebase-merge" ] || [ -d ".git/rebase-apply" ]; then
    die "Git rebase is in progress. Resolve and run 'git rebase --continue' first."
  fi
  if [ -f ".git/MERGE_HEAD" ]; then
    die "Git merge is in progress. Resolve and complete the merge first."
  fi
}

ensure_ssh_agent() {
  if [ -z "${SSH_AUTH_SOCK:-}" ]; then
    eval "$(ssh-agent -s)" >/dev/null
    ssh-add -A >/dev/null 2>&1 || true
  fi
}

sync_with_remote_rebase() {
  local branch="$1"
  has_origin_remote || return 0

  if ! git diff --quiet; then
    msg "💾 Stashing unstaged local changes before pull --rebase..."
    if [[ "$DRY_RUN" == true ]]; then
      msg "DRY RUN: git stash -u"
      msg "DRY RUN: git pull --rebase origin \"$branch\""
      msg "DRY RUN: git stash pop"
      return 0
    fi

    git stash -u >/dev/null
    if ! git pull --rebase origin "$branch" >/dev/null 2>&1; then
      die "Pull/rebase failed. Resolve manually."
    fi
    if ! git stash pop >/dev/null 2>&1; then
      die "git stash pop failed after pull --rebase. Resolve the stash manually (git stash list, git stash show -p, git stash apply)."
    fi
  else
    if [[ "$DRY_RUN" == true ]]; then
      msg "DRY RUN: git pull --rebase origin \"$branch\""
      return 0
    fi
    git pull --rebase origin "$branch" >/dev/null 2>&1 || true
  fi
}

# ----------------------------
# VERSION helpers
# ----------------------------
resolve_realpath() {
  local p="$1"
  python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' "$p" 2>/dev/null || echo "$p"
}

# Returns the writable repo copy of this script (bin/commit_gh in the current
# git repo root) if one exists, otherwise falls back to the running script path.
# This lets the globally-installed Homebrew binary correctly update the repo
# copy rather than trying to write to the read-only Cellar.
resolve_script_target() {
  local repo_root
  if repo_root="$(git rev-parse --show-toplevel 2>/dev/null)"; then
    local candidate="$repo_root/bin/commit_gh"
    if [[ -f "$candidate" ]]; then
      resolve_realpath "$candidate"
      return 0
    fi
  fi
  local self_path
  self_path="$(cd -- "$(dirname "${BASH_SOURCE[0]}")" && pwd)/$(basename "${BASH_SOURCE[0]}")"
  resolve_realpath "$self_path"
}

update_self_version_constant() {
  local new_version="$1"
  local target_path
  target_path="$(resolve_script_target)"

  # Not in the commit_gh_cli repo — skip silently. The VERSION constant only
  # needs updating when releasing commit_gh itself.
  if [[ ! -f "$target_path" ]] || [[ ! -w "$target_path" ]]; then
    return 0
  fi

  if grep -qE '^VERSION="[^"]+"' "$target_path"; then
    if [[ "$DRY_RUN" == true ]]; then
      msg "DRY RUN: sed VERSION → $new_version in $target_path"
      return 0
    fi
    sed -i '' -E "s/^VERSION=\"[^\"]+\"/VERSION=\"${new_version}\"/" "$target_path"
    msg "✅ Updated VERSION constant in $(basename "$target_path") to $new_version"
  fi
}

get_self_version_constant() {
  local target_path
  target_path="$(resolve_script_target)"

  grep -E '^VERSION="[^"]+"' "$target_path" |
    head -n1 |
    sed -E 's/^VERSION="([^"]+)".*/\1/'
}

read_semver() {
  local v="$1"
  [[ "$v" =~ ^([0-9]+)\.([0-9]+)\.([0-9]+)$ ]] || return 1
  SEMVER_MAJOR="${BASH_REMATCH[1]}"
  SEMVER_MINOR="${BASH_REMATCH[2]}"
  SEMVER_PATCH="${BASH_REMATCH[3]}"
  return 0
}

bump_semver() {
  local bump="$1" major="$2" minor="$3" patch="$4"
  case "$bump" in
  patch) patch=$((patch + 1)) ;;
  minor)
    minor=$((minor + 1))
    patch=0
    ;;
  major)
    major=$((major + 1))
    minor=0
    patch=0
    ;;
  *) die "Unknown bump type: $bump" ;;
  esac
  echo "${major}.${minor}.${patch}"
}

ensure_version_file() {
  local vf="$1"
  if [[ ! -f "$vf" ]]; then
    msg "⚠️ Version file '$vf' not found. Creating with 0.0.0"
    if [[ "$DRY_RUN" == true ]]; then
      msg "DRY RUN: echo 0.0.0 > \"$vf\""
      return 0
    fi
    echo "0.0.0" >"$vf"
  fi
}

create_github_release() {
  local tag="$1"
  command -v gh >/dev/null 2>&1 || {
    msg "⚠️ gh not found. Skipping GitHub release."
    return 0
  }
  has_origin_remote || {
    msg "⚠️ No origin remote. Skipping GitHub release."
    return 0
  }

  local notes_flag="--notes \"Release $tag\""
  [[ "$RELEASE_GENERATE_NOTES" == true ]] && notes_flag="--generate-notes"

  if [[ "$DRY_RUN" == true ]]; then
    msg "DRY RUN: gh release create \"$tag\" --title \"$tag\" $notes_flag"
    return 0
  fi

  if gh release view "$tag" >/dev/null 2>&1; then
    if [[ "$RELEASE_FORCE" == true ]]; then
      msg "🗑️ Deleting existing GitHub release $tag (--force)..."
      gh release delete "$tag" --yes >/dev/null 2>&1 || true
    else
      msg "⚠️ GitHub release $tag already exists. Use --force to overwrite."
      return 0
    fi
  fi

  msg "📦 Creating GitHub release $tag..."
  if [[ "$RELEASE_GENERATE_NOTES" == true ]]; then
    gh release create "$tag" --title "$tag" --generate-notes
  else
    gh release create "$tag" --title "$tag" --notes "Release $tag"
  fi
}

run_read_version() {
  in_git_repo || die "Not inside a git repository."
  cd "$(git rev-parse --show-toplevel)" || exit 1

  local repo_name vf_version script_version latest_tag tag_version consistent=true
  repo_name="$(basename "$(pwd)")"

  vf_version="$([ -f "$VERSION_FILE" ] && cat "$VERSION_FILE" || echo "missing")"
  script_version="n/a"
  if [[ -f "bin/commit_gh" ]]; then
    script_version="$(grep -E '^VERSION="[^"]+"' "bin/commit_gh" | head -n1 | sed -E 's/^VERSION="([^"]+)".*/\1/')"
  fi
  latest_tag="$(git tag --sort=-v:refname | grep -E '^v[0-9]+\.[0-9]+\.[0-9]+$' | head -n1 || true)"
  [[ -z "$latest_tag" ]] && latest_tag="none"
  tag_version="${latest_tag#v}"
  [[ "$latest_tag" == "none" ]] && tag_version="none"

  always_msg ""
  always_msg "${BOLD}${CYAN}── Version inventory: ${repo_name}${RESET}"
  always_msg "${DIM}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
  printf "  %-30s ${BOLD}%s${RESET}\n" "$VERSION_FILE" "$vf_version"
  [[ "$script_version" != "n/a" ]] && printf "  %-30s ${BOLD}%s${RESET}\n" "bin/commit_gh VERSION=" "$script_version"
  printf "  %-30s ${BOLD}%s${RESET}\n" "Latest git tag" "$latest_tag"
  always_msg "${DIM}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"

  if [[ "$vf_version" == "missing" ]]; then
    always_msg "  ${RED}✗ $VERSION_FILE not found${RESET}"
    consistent=false
  elif [[ "$latest_tag" == "none" ]]; then
    always_msg "  ${YELLOW}⚠ No tags yet — next release will create v$vf_version${RESET}"
  elif [[ "$vf_version" != "$tag_version" ]]; then
    always_msg "  ${RED}✗ VERSION ($vf_version) does not match latest tag ($latest_tag)${RESET}"
    consistent=false
  else
    always_msg "  ${GREEN}✓ VERSION and latest tag aligned at $vf_version${RESET}"
  fi

  if [[ "$script_version" != "n/a" && "$script_version" != "$vf_version" ]]; then
    always_msg "  ${YELLOW}⚠ bin/commit_gh VERSION= ($script_version) ≠ VERSION file ($vf_version)${RESET}"
    consistent=false
  fi

  always_msg ""
  if [[ "$consistent" == true ]]; then
    always_msg "  ${GREEN}${BOLD}✓ Version sources consistent.${RESET}"
  else
    always_msg "  ${RED}${BOLD}✗ Version sources inconsistent.${RESET}"
    exit 1
  fi
  always_msg ""
}

# ----------------------------
# Standalone modes (harden → audit → scan — all exit after running)
# Run harden before audit so --harden --audit hardens first, then reports.
# ----------------------------
if [[ "$HARDEN_MODE" == true ]]; then
  in_git_repo || die "Not inside a git repository. --harden requires an existing repo."
  cd "$(git rev-parse --show-toplevel)" || exit 1
  msg "🛡️ Hardening repo: $(basename "$(pwd)")"
  setup_security_files
  if [[ "$AUDIT_MODE" != true ]]; then
    always_msg "🎉 Done. Run ${CYAN}commit_gh --audit${RESET} to verify."
    exit 0
  fi
fi

if [[ "$AUDIT_MODE" == true ]]; then
  run_audit
  exit $?
fi

if [[ "$READ_VERSION_ONLY" == true ]]; then
  run_read_version
  exit 0
fi

if [[ "$SCAN_MODE" == true ]]; then
  if ! gitleaks_available; then
    die "gitleaks not found. Install with: brew install gitleaks"
  fi
  run_gitleaks_scan "source"
  always_msg "🎉 Done."
  exit 0
fi

# ----------------------------
# Start
# ----------------------------
ensure_repo
ensure_no_rebase_or_merge
ensure_ssh_agent

branch="$(detect_branch)"

# Optional: remove tracked FOLDER_TREE.md if ignored
if in_git_repo && git ls-files --error-unmatch FOLDER_TREE.md &>/dev/null; then
  if [[ -f .gitignore ]] && grep -qF "FOLDER_TREE.md" .gitignore; then
    msg "🧹 Removing FOLDER_TREE.md from Git tracking..."
    if [[ "$DRY_RUN" == true ]]; then
      msg "DRY RUN: git rm --cached FOLDER_TREE.md"
    else
      git rm --cached FOLDER_TREE.md >/dev/null
    fi
  fi
fi

ensure_origin_remote || true

# Enable GitHub secret scanning if requested (after remote exists)
if [[ "$ENABLE_SECRET_SCANNING" == true ]]; then
  enable_github_secret_scanning
fi

# Decide commit message
if [[ -n "$COMMIT_MESSAGE_OVERRIDE" ]]; then
  COMMIT_MESSAGE="$COMMIT_MESSAGE_OVERRIDE"
else
  DD=$(date +'%d')
  MM=$(date +'%m')
  YYYY=$(date +'%Y')
  COMMIT_MESSAGE="$DD/$MM/$YYYY - Updated configuration and fixed bugs"
fi

# ----------------------------
# RELEASE FLOW (VERSION-file based)
# ----------------------------
if [[ -n "$RELEASE_BUMP" ]]; then
  vf_path="$VERSION_FILE"
  [[ "$vf_path" != /* ]] && vf_path="$(pwd)/$vf_path"

  ensure_version_file "$vf_path"
  current_version="$(<"$vf_path")"
  read_semver "$current_version" || die "Invalid VERSION '$current_version'. Expected X.Y.Z"

  # Explicit x.y.z or bump type
  if [[ "$RELEASE_BUMP" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
    new_version="$RELEASE_BUMP"
  else
    new_version="$(bump_semver "$RELEASE_BUMP" "$SEMVER_MAJOR" "$SEMVER_MINOR" "$SEMVER_PATCH")"
  fi
  new_tag="v${new_version}"

  # Default commit message
  release_commit_msg="${COMMIT_MESSAGE_OVERRIDE:-chore: release ${new_tag}}"

  # ── Pre-flight checks ──────────────────────────────────────────
  msg ""
  msg "${BOLD}── Pre-flight checks ────────────────────────────────────────────${RESET}"
  in_git_repo && msg "  ${GREEN}✓${RESET} git repository" || die "Not inside a git repository."
  if has_origin_remote; then
    msg "  ${GREEN}✓${RESET} origin remote: $(git remote get-url origin)"
  else
    msg "  ${YELLOW}⚠${RESET} no origin remote — push and GitHub release will be skipped"
  fi
  if command -v gh >/dev/null 2>&1; then
    msg "  ${GREEN}✓${RESET} gh CLI available"
  else
    msg "  ${YELLOW}⚠${RESET} gh CLI not found — GitHub release will be skipped"
  fi
  if [[ "$RELEASE_FORCE" != true ]] && git rev-parse "$new_tag" >/dev/null 2>&1; then
    die "Tag $new_tag already exists. Use --force to overwrite."
  fi
  msg ""

  # ── Release plan ───────────────────────────────────────────────
  msg "${BOLD}── Release plan ─────────────────────────────────────────────────${RESET}"
  msg "  Version       : ${BOLD}$current_version → $new_version${RESET}"
  msg "  Tag           : ${BOLD}$new_tag${RESET}"
  msg "  Branch        : $branch"
  msg "  Commit msg    : $release_commit_msg"
  msg "  GitHub release: $([ "$RELEASE_NO_RELEASE" = true ] && echo "skipped (--no-release)" || ([ "$RELEASE_GENERATE_NOTES" = true ] && echo "yes (--generate-notes)" || echo "yes"))"
  msg "  Force         : $([ "$RELEASE_FORCE" = true ] && echo "${YELLOW}yes — will overwrite existing tag + release${RESET}" || echo "no")"
  if [[ "$DRY_RUN" == true ]]; then
    msg ""
    msg "  ${YELLOW}${BOLD}DRY RUN — no changes will be made${RESET}"
    msg ""
  fi
  msg ""

  # Sync first (avoid stash eating our edits)
  sync_with_remote_rebase "$branch"

  # Update the script's VERSION constant (repo copy); dies if target not writable
  update_self_version_constant "$new_version"

  # Guard: only when releasing commit_gh itself (target is writable repo copy)
  _guard_target="$(resolve_script_target)"
  if [[ "$DRY_RUN" != true ]] && [[ -f "$_guard_target" ]] && [[ -w "$_guard_target" ]]; then
    self_version="$(get_self_version_constant)"
    if [[ "$self_version" != "$new_version" ]]; then
      die "Refusing to tag: bin/commit_gh VERSION is $self_version but release version is $new_version"
    fi
  fi

  # ── 1/4 Update VERSION file ────────────────────────────────────
  msg "${BOLD}── 1/4  Update VERSION file ─────────────────────────────────────${RESET}"
  if [[ "$DRY_RUN" == true ]]; then
    msg "  DRY RUN: echo \"$new_version\" > \"$vf_path\""
  else
    echo "$new_version" >"$vf_path"
    msg "  ${GREEN}✓${RESET} $VERSION_FILE → $new_version"
  fi

  # ── 2/4 Commit ────────────────────────────────────────────────
  msg "${BOLD}── 2/4  Commit ──────────────────────────────────────────────────${RESET}"
  if [[ "$DRY_RUN" == true ]]; then
    msg "  DRY RUN: git add . && git commit -m \"$release_commit_msg\""
  else
    git add "$vf_path" >/dev/null
    git add . >/dev/null
    if git diff --cached --quiet; then
      msg "  ${YELLOW}⚠${RESET} Nothing to commit (working tree already clean)"
    else
      git commit -m "$release_commit_msg" >/dev/null
      msg "  ${GREEN}✓${RESET} Committed: $release_commit_msg"
    fi
  fi

  # ── 3/4 Tag ───────────────────────────────────────────────────
  msg "${BOLD}── 3/4  Tag ─────────────────────────────────────────────────────${RESET}"
  if git rev-parse "$new_tag" >/dev/null 2>&1 && [[ "$RELEASE_FORCE" == true ]]; then
    if [[ "$DRY_RUN" != true ]]; then
      git tag -d "$new_tag" >/dev/null
      git push origin ":refs/tags/$new_tag" >/dev/null 2>&1 || true
      msg "  ${YELLOW}⚠${RESET} Deleted existing tag $new_tag (--force)"
    fi
  fi
  if [[ "$DRY_RUN" == true ]]; then
    msg "  DRY RUN: git tag -a \"$new_tag\" -m \"$release_commit_msg\""
  else
    git tag -a "$new_tag" -m "$release_commit_msg" >/dev/null
    msg "  ${GREEN}✓${RESET} Tagged $new_tag"
  fi

  # Push branch and tag
  if has_origin_remote; then
    if [[ "$DRY_RUN" == true ]]; then
      msg "  DRY RUN: git push origin \"$branch\" && git push origin \"$new_tag\""
    else
      git push origin "$branch" >/dev/null 2>&1 || die "Push branch failed."
      git push origin "$new_tag" >/dev/null 2>&1 || die "Push tag failed."
      msg "  ${GREEN}✓${RESET} Pushed $branch and $new_tag to origin"
    fi
  else
    msg "  ${YELLOW}⚠${RESET} No origin remote — push skipped"
  fi

  # ── 4/4 GitHub release ────────────────────────────────────────
  msg "${BOLD}── 4/4  GitHub release ──────────────────────────────────────────${RESET}"
  if [[ "$RELEASE_NO_RELEASE" == true ]]; then
    msg "  ${YELLOW}⚠${RESET} Skipped (--no-release)"
  else
    create_github_release "$new_tag"
  fi

  msg ""
  msg "${GREEN}${BOLD}✅ Release complete: $new_tag${RESET}"
  msg ""
fi

# ----------------------------
# ORIGINAL COMMIT FLOW (kept)
# ----------------------------
if [[ "$DRY_RUN" == true ]]; then
  msg "DRY RUN: git add ."
else
  git add . >/dev/null
fi

# Auto-unstage sensitive filenames before secret scan
if [[ "$DRY_RUN" != true ]]; then
  unstage_blocked_files
fi

# Gitleaks staged scan before commit (skippable with --no-scan)
if [[ "$NO_SCAN" != true ]]; then
  run_gitleaks_scan "staged"
fi

DID_COMMIT=0
if ! git diff --cached --quiet; then
  msg "📦 Committing staged changes..."
  if [[ "$DRY_RUN" == true ]]; then
    msg "DRY RUN: git commit -m \"$COMMIT_MESSAGE\""
  else
    git commit -m "$COMMIT_MESSAGE" >/dev/null
  fi
  DID_COMMIT=1
fi

sync_with_remote_rebase "$branch"

if [[ "$DRY_RUN" == true ]]; then
  msg "DRY RUN: git add ."
else
  git add . >/dev/null
fi

if ! git diff --cached --quiet; then
  msg "📦 Committing new staged changes..."
  if [[ "$DRY_RUN" == true ]]; then
    msg "DRY RUN: git commit -m \"$COMMIT_MESSAGE\""
  else
    git commit -m "$COMMIT_MESSAGE" >/dev/null
  fi
  DID_COMMIT=1
fi

# Smart push logic
DID_PUSH=0
try_push() {
  local max_attempts=2
  local attempt=1

  if ! has_origin_remote; then
    msg "⚠️ No origin remote. Skipping push."
    return 0
  fi

  while [[ $attempt -le $max_attempts ]]; do
    if [[ $(git log "origin/$branch..HEAD" --oneline 2>/dev/null | wc -l | tr -d ' ') -gt 0 ]]; then
      if [[ "$DRY_RUN" == true ]]; then
        msg "DRY RUN: git push origin \"$branch\""
        DID_PUSH=1
        return 0
      fi

      if git push origin "$branch" >/dev/null 2>&1; then
        DID_PUSH=1
        msg "🚀 Successfully pushed to origin/$branch."
        return 0
      else
        msg "⚠️ Push failed. Trying pull --rebase and re-push..."
        if ! git pull --rebase origin "$branch" >/dev/null 2>&1; then
          die "Pull/rebase failed. Resolve manually."
        fi
        attempt=$((attempt + 1))
      fi
    else
      return 0
    fi
  done

  die "Push failed after retry. Resolve manually."
}
try_push

# Verification layer
if [[ "$VERIFY_MODE" == true ]]; then
  msg "🧪 Running commit_gh verification..."

  if ! git diff --quiet || ! git diff --cached --quiet; then
    die "Working tree is dirty."
  fi
  msg "✅ Working tree is clean."

  current_branch="$(git rev-parse --abbrev-ref HEAD)"
  if [[ "$current_branch" != "$branch" ]]; then
    die "Not on '$branch' branch (current: $current_branch)"
  fi
  msg "✅ On branch: $branch"

  if [[ ! -f .version ]]; then
    latest_tag=$(git tag --sort=-v:refname | grep -E '^v[0-9]+\.[0-9]+\.[0-9]+$' | head -n1 || echo "v0.0.0")
    if [[ "$DRY_RUN" == true ]]; then
      msg "DRY RUN: echo \"$latest_tag\" > .version"
    else
      echo "$latest_tag" >.version
    fi
    version_file="$latest_tag"
    msg "🆕 .version file created with: $latest_tag"
  else
    version_file=$(<.version)
    msg "✅ .version file found: $version_file"
  fi

  latest_tag=$(git tag --sort=-v:refname | grep -E '^v[0-9]+\.[0-9]+\.[0-9]+$' | head -n1 || echo "v0.0.0")
  if [[ "$version_file" != "$latest_tag" ]]; then
    die ".version ($version_file) does not match latest tag ($latest_tag)"
  fi
  msg "🎯 All verification checks passed."
fi

if [[ $DID_COMMIT -eq 0 && $DID_PUSH -eq 0 ]]; then
  current_branch="$(git rev-parse --abbrev-ref HEAD)"
  always_msg "✅ Current branch $current_branch is up to date."
  always_msg "🟢 No changes to commit."
fi

if [[ -f .github/dependabot.yml ]]; then
  msg "🔐 Dependabot is enabled. Base image CVEs will be monitored automatically by GitHub."
fi

if [[ $GENERATE_TREE -eq 1 ]]; then
  if command -v folder_tree &>/dev/null; then
    msg "🌳 Generating updated folder tree..."
    if [[ "$DRY_RUN" == true ]]; then
      msg "DRY RUN: folder_tree --preset terraform,github --output markdown"
    else
      folder_tree --preset terraform,github --output markdown >/dev/null
    fi
  else
    msg "⚠️ 'folder_tree' command not found. Skipping tree update."
  fi
fi

# Existing tag bump behavior
if [[ -n "$BUMP_TYPE" || "$PREVIEW_MODE" == true ]]; then
  latest_tag=$(git tag --sort=-v:refname | grep -E '^v[0-9]+\.[0-9]+\.[0-9]+$' | head -n1 || echo "v0.0.0")
  IFS='.' read -r major minor patch <<<"${latest_tag#v}"

  msg "🔍 Latest tag: $latest_tag"

  if [[ -z "$BUMP_TYPE" ]]; then
    msg "🕵️ No bump type specified."
    exit 0
  fi

  case "$BUMP_TYPE" in
  patch) ((patch++)) ;;
  minor)
    ((minor++))
    patch=0
    ;;
  major)
    ((major++))
    minor=0
    patch=0
    ;;
  esac

  new_tag="v$major.$minor.$patch"

  if [[ "$PREVIEW_MODE" == true ]]; then
    msg "🔼 Requested bump: $BUMP_TYPE"
    msg "🎯 Next tag would be: $new_tag"
    exit 0
  fi

  if git rev-parse "$new_tag" >/dev/null 2>&1; then
    die "Tag $new_tag already exists. Aborting."
  fi

  msg "🏷️ Creating new tag: $new_tag"
  if [[ "$DRY_RUN" == true ]]; then
    msg "DRY RUN: git tag -a \"$new_tag\" -m \"Release $new_tag\""
    msg "DRY RUN: git push origin \"$new_tag\""
    msg "DRY RUN: echo \"$new_tag\" > .version"
  else
    git tag -a "$new_tag" -m "Release $new_tag" >/dev/null
    if has_origin_remote; then
      git push origin "$new_tag" >/dev/null
      msg "✅ Pushed tag $new_tag successfully."
    else
      msg "⚠️ No origin remote. Tag exists only locally."
    fi
    echo "$new_tag" >.version
    msg "📝 Wrote version to .version"
  fi
fi
always_msg "🎉 Done."
