EOF
  msg "✅ $checklist created."
}

populate_changelog() {
  local new_version="$1"
  [[ -f "CHANGELOG.md" ]] || return 0
  grep -q '## \[Unreleased\]' CHANGELOG.md || return 0

  local date_str prev_tag log_range
  date_str="$(date +%Y-%m-%d)"
  prev_tag="$(git tag --sort=-v:refname | grep -E '^v[0-9]+\.[0-9]+\.[0-9]+$' | head -n1 2>/dev/null || true)"
  [[ -n "$prev_tag" ]] && log_range="${prev_tag}..HEAD" || log_range="HEAD"

  if [[ "$DRY_RUN" == true ]]; then
    msg "DRY RUN: populate CHANGELOG.md with v${new_version} entries from git log"
    return 0
  fi

  # ── Collect conventional-commit entries from git log ──────────
  local -a _added=() _fixed=() _changed=() _security=()
  while IFS= read -r _subj; do
    [[ -z "$_subj" ]] && continue
    [[ "$_subj" =~ ^Merge[[:space:]] ]] && continue
    [[ "$_subj" =~ ^chore:[[:space:]]release ]] && continue
    case "$_subj" in
      feat:*|feat\(*\):*)     _added+=("${_subj#*: }") ;;
      fix:*|fix\(*\):*)       _fixed+=("${_subj#*: }") ;;
      security:*)             _security+=("${_subj#*: }") ;;
      chore:*|refactor:*|perf:*|build:*|ci:*|docs:*)
                              _changed+=("${_subj#*: }") ;;
    esac
  done < <(git log --pretty=format:"%s" $log_range 2>/dev/null || true)

  [[ ${#_added[@]} -eq 0 && ${#_fixed[@]} -eq 0 && \
     ${#_changed[@]} -eq 0 && ${#_security[@]} -eq 0 ]] && return 0

  # ── Build the new version section ─────────────────────────────
  local _section _out
  _section="$(mktemp)"
  _out="$(mktemp)"

  {
    printf '## [%s] - %s\n' "$new_version" "$date_str"
    [[ ${#_added[@]} -gt 0 ]]    && { printf '\n### Added\n\n';    printf '%s\n' "${_added[@]/#/- }"; }
    [[ ${#_fixed[@]} -gt 0 ]]    && { printf '\n### Fixed\n\n';    printf '%s\n' "${_fixed[@]/#/- }"; }
    [[ ${#_changed[@]} -gt 0 ]]  && { printf '\n### Changed\n\n';  printf '%s\n' "${_changed[@]/#/- }"; }
    [[ ${#_security[@]} -gt 0 ]] && { printf '\n### Security\n\n'; printf '%s\n' "${_security[@]/#/- }"; }
  } > "$_section"

  # ── Rewrite CHANGELOG: insert new section after [Unreleased] ──
  # Existing [Unreleased] content is replaced by the auto-generated block.
  local _in_ur=false _done=false _line
  while IFS= read -r _line || [[ -n "$_line" ]]; do
    if [[ "$_done" == false && "$_line" == "## [Unreleased]" ]]; then
      printf '%s\n\n' "$_line" >> "$_out"
      _in_ur=true
      continue
    fi
    if [[ "$_in_ur" == true ]]; then
      if [[ "$_line" =~ ^##[[:space:]] ]]; then
        cat "$_section" >> "$_out"
        printf '\n%s\n' "$_line" >> "$_out"
        _in_ur=false
        _done=true
      fi
      continue   # discard old [Unreleased] content (empty headers)
    fi
    printf '%s\n' "$_line" >> "$_out"
  done < CHANGELOG.md

  # [Unreleased] was the last section — append at end
  if [[ "$_in_ur" == true || "$_done" == false ]]; then
    cat "$_section" >> "$_out"
  fi

  rm -f "$_section"
  mv "$_out" CHANGELOG.md
  msg "  ${GREEN}✓${RESET} CHANGELOG.md updated for v${new_version}"
}

enable_dependabot_alerts() {
  command -v gh >/dev/null 2>&1 || {
    msg "⚠️ gh not found. Skipping Dependabot alerts enablement."
    return 0
  }
  has_origin_remote || {
    msg "⚠️ No origin remote. Skipping Dependabot alerts enablement."
    return 0
  }

  local remote_url repo_slug
  remote_url="$(git remote get-url origin 2>/dev/null || echo "")"
  repo_slug="$(echo "$remote_url" | sed -E 's|.*github\.com[:/]([^/]+/[^/.]+)(\.git)?$|\1|')"

  if [[ -z "$repo_slug" || "$repo_slug" == "$remote_url" ]]; then
    msg "⚠️ Could not determine GitHub repo slug. Skipping Dependabot alerts."
    return 0
  fi

  msg "🔔 Enabling Dependabot vulnerability alerts on $repo_slug..."
  if [[ "$DRY_RUN" == true ]]; then
    msg "DRY RUN: gh api PUT /repos/$repo_slug/vulnerability-alerts"
    return 0
  fi

  if gh api --method PUT "/repos/$repo_slug/vulnerability-alerts" >/dev/null 2>&1; then
    msg "✅ Dependabot alerts enabled."
  else
    msg "⚠️ Could not enable Dependabot alerts (requires admin access). Skipping."
  fi
}

enable_github_secret_scanning() {
  command -v gh >/dev/null 2>&1 || {
    msg "⚠️ gh not found. Skipping secret scanning enablement."
    return 0
  }
  has_origin_remote || {
    msg "⚠️ No origin remote. Skipping secret scanning enablement."
    return 0
  }

  local remote_url repo_slug
  remote_url="$(git remote get-url origin 2>/dev/null || echo "")"
  repo_slug="$(echo "$remote_url" | sed -E 's|.*github\.com[:/]([^/]+/[^/.]+)(\.git)?$|\1|')"

  if [[ -z "$repo_slug" || "$repo_slug" == "$remote_url" ]]; then
    msg "⚠️ Could not determine GitHub repo slug from origin. Skipping secret scanning."
    return 0
  fi

  msg "🔐 Enabling GitHub secret scanning + push protection on $repo_slug..."
  if [[ "$DRY_RUN" == true ]]; then
    msg "DRY RUN: gh api PATCH /repos/$repo_slug → secret_scanning=enabled"
    msg "DRY RUN: gh api PATCH /repos/$repo_slug → secret_scanning_push_protection=enabled"
    return 0
  fi

  if gh api --method PATCH "/repos/$repo_slug" \
    -f "security_and_analysis[secret_scanning][status]=enabled" \
    -f "security_and_analysis[secret_scanning_push_protection][status]=enabled" \
    >/dev/null 2>&1; then
    msg "✅ GitHub secret scanning and push protection enabled."
  else
    msg "⚠️ Could not enable secret scanning (requires GitHub Advanced Security or public repo). Skipping."
  fi
}

enable_branch_protection() {
  local branch="${1:-main}"
  command -v gh >/dev/null 2>&1 || {
    msg "⚠️ gh not found. Skipping branch protection."
    return 0
  }
  has_origin_remote || {
    msg "⚠️ No origin remote. Skipping branch protection."
    return 0
  }

  local remote_url repo_slug
  remote_url="$(git remote get-url origin 2>/dev/null || echo "")"
  repo_slug="$(echo "$remote_url" | sed -E 's|.*github\.com[:/]([^/]+/[^/.]+)(\.git)?$|\1|')"

  if [[ -z "$repo_slug" || "$repo_slug" == "$remote_url" ]]; then
    msg "⚠️ Could not determine repo slug. Skipping branch protection."
    return 0
  fi

  msg "🛡️ Enabling branch protection on ${repo_slug}:${branch}..."
  if [[ "$DRY_RUN" == true ]]; then
    msg "DRY RUN: gh api PUT /repos/$repo_slug/branches/$branch/protection"
    return 0
  fi

  if gh api --method PUT "/repos/$repo_slug/branches/$branch/protection" \
    --input - >/dev/null 2>&1 <<'PROTECTION_JSON'
{
  "required_status_checks": null,
  "enforce_admins": false,
  "required_pull_request_reviews": {
    "required_approving_review_count": 1,
    "dismiss_stale_reviews": true
  },
  "restrictions": null,
  "allow_force_pushes": false,
  "allow_deletions": false
}
PROTECTION_JSON
  then
    msg "✅ Branch protection enabled on ${branch} (1 review required, no force-push, no deletion)."
  else
    msg "⚠️ Could not enable branch protection (requires admin access; private repos need GitHub Pro/Team). Skipping."
  fi
}

run_gitleaks_scan() {
  local mode="${1:-source}"  # "source" = full tree, "staged" = only staged files
  if ! gitleaks_available; then
    return 0  # silent skip — commit_gh --audit will surface this gap
  fi
  if [[ "$mode" == "staged" ]]; then
    msg "🔍 Gitleaks: scanning staged files..."
    if [[ "$DRY_RUN" == true ]]; then
      msg "DRY RUN: gitleaks protect --staged --redact"
      return 0
    fi
    if ! gitleaks protect --staged --redact -v 2>&1; then
      die "Gitleaks detected secrets in staged files. Commit blocked. Review output above."
    fi
    msg "✅ Gitleaks staged scan clean."
  else
    msg "🔍 Gitleaks: scanning full working tree..."
    if [[ "$DRY_RUN" == true ]]; then
      msg "DRY RUN: gitleaks detect --source . --redact"
      return 0
    fi
    if ! gitleaks detect --source . --redact --exit-code 1 2>&1; then
      die "Gitleaks detected secrets. Review output above and remove before committing."
    fi
    msg "✅ Gitleaks scan clean."
  fi
}

setup_security_files() {
  write_gitignore
  write_env_example
  write_gitleaks_toml
  install_pre_commit_hook
  write_github_actions_workflow
  write_release_workflow
  write_dependabot
  write_changelog
  write_license
  write_readme
  write_contributing
  write_issue_templates
  write_pr_template
  write_codeowners
  write_editorconfig
  write_release_checklist
  write_io_gitkeeps
}

run_audit() {
  local repo_name issues=0

  in_git_repo || die "Not inside a git repository."
  cd "$(git rev-parse --show-toplevel)" || exit 1
  repo_name="$(basename "$(pwd)")"

  local sep="${DIM}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"

  always_msg "${BOLD}🔍 Security audit:${RESET} ${CYAN}${repo_name}${RESET}"
  always_msg "$sep"

  # gitleaks binary
  if gitleaks_available; then
    always_msg "  ${GREEN}✅${RESET}  gitleaks binary          $(command -v gitleaks)"
  else
    always_msg "  ${RED}❌${RESET}  gitleaks binary          not installed  ${DIM}→ brew install gitleaks${RESET}"
    issues=$((issues + 1))
  fi

  # .gitleaks.toml
  if [[ -f ".gitleaks.toml" ]]; then
    always_msg "  ${GREEN}✅${RESET}  .gitleaks.toml           present"
  else
    always_msg "  ${RED}❌${RESET}  .gitleaks.toml           missing        ${DIM}→ commit_gh --harden${RESET}"
    issues=$((issues + 1))
  fi

  # pre-commit hook
  if [[ -f ".git/hooks/pre-commit" ]] && grep -q "gitleaks" ".git/hooks/pre-commit" 2>/dev/null; then
    always_msg "  ${GREEN}✅${RESET}  .git/hooks/pre-commit    gitleaks hook present"
  elif [[ -f ".git/hooks/pre-commit" ]]; then
    always_msg "  ${YELLOW}⚠️${RESET}   .git/hooks/pre-commit    exists but no gitleaks call  ${DIM}→ commit_gh --harden --no-hook skips; edit manually${RESET}"
    issues=$((issues + 1))
  else
    always_msg "  ${RED}❌${RESET}  .git/hooks/pre-commit    missing        ${DIM}→ commit_gh --harden${RESET}"
    issues=$((issues + 1))
  fi

  # GitHub Actions workflow
  if [[ -f ".github/workflows/gitleaks.yml" ]]; then
    if grep -q "permissions:" ".github/workflows/gitleaks.yml" 2>/dev/null; then
      always_msg "  ${GREEN}✅${RESET}  .github/workflows/gitleaks.yml   present (permissions set)"
    else
      always_msg "  ${YELLOW}⚠️${RESET}   .github/workflows/gitleaks.yml   present but missing permissions: block  ${DIM}→ commit_gh --harden regenerates${RESET}"
      issues=$((issues + 1))
    fi
  else
    always_msg "  ${RED}❌${RESET}  .github/workflows/gitleaks.yml   missing  ${DIM}→ commit_gh --harden${RESET}"
    issues=$((issues + 1))
  fi

  # release workflow
  if [[ -f ".github/workflows/release.yml" ]]; then
    always_msg "  ${GREEN}✅${RESET}  .github/workflows/release.yml    present"
  else
    always_msg "  ${YELLOW}⚠️${RESET}   .github/workflows/release.yml    missing  ${DIM}→ commit_gh --harden${RESET}"
    issues=$((issues + 1))
  fi

  # .gitignore with .env and .vault.* coverage
  if [[ -f ".gitignore" ]]; then
    local _gi_missing=()
    grep -qE '^\.env$|^\.env\b|^\*\.env$' ".gitignore" 2>/dev/null || _gi_missing+=(".env")
    grep -qE '^\.vault\.\*$' ".gitignore" 2>/dev/null || _gi_missing+=(".vault.*")
    if [[ ${#_gi_missing[@]} -eq 0 ]]; then
      always_msg "  ${GREEN}✅${RESET}  .gitignore                       present (.env and .vault.* covered)"
    else
      always_msg "  ${YELLOW}⚠️${RESET}   .gitignore                       missing: ${_gi_missing[*]}  ${DIM}→ commit_gh --harden${RESET}"
      issues=$((issues + 1))
    fi
  else
    always_msg "  ${RED}❌${RESET}  .gitignore                       missing  ${DIM}→ commit_gh --harden${RESET}"
    issues=$((issues + 1))
  fi

  # .env.example
  if [[ -f ".env.example" ]] || [[ -f ".env.sample" ]]; then
    always_msg "  ${GREEN}✅${RESET}  .env.example                     present"
  else
    always_msg "  ${YELLOW}⚠️${RESET}   .env.example                     missing  ${DIM}→ commit_gh --harden${RESET}"
    issues=$((issues + 1))
  fi

  # CHANGELOG.md
  if [[ -f "CHANGELOG.md" ]]; then
    always_msg "  ${GREEN}✅${RESET}  CHANGELOG.md                     present"
  else
    always_msg "  ${YELLOW}⚠️${RESET}   CHANGELOG.md                     missing  ${DIM}→ commit_gh --harden${RESET}"
    issues=$((issues + 1))
  fi

  # LICENSE
  if [[ -f "LICENSE" ]]; then
    always_msg "  ${GREEN}✅${RESET}  LICENSE                          present"
  else
    always_msg "  ${YELLOW}⚠️${RESET}   LICENSE                          missing  ${DIM}→ commit_gh --harden${RESET}"
    issues=$((issues + 1))
  fi

  # README.md
  if [[ -f "README.md" ]]; then
    always_msg "  ${GREEN}✅${RESET}  README.md                        present"
  else
    always_msg "  ${YELLOW}⚠️${RESET}   README.md                        missing  ${DIM}→ commit_gh --harden${RESET}"
    issues=$((issues + 1))
  fi

  # CONTRIBUTING.md
  if [[ -f "CONTRIBUTING.md" ]]; then
    always_msg "  ${GREEN}✅${RESET}  CONTRIBUTING.md                  present"
  else
    always_msg "  ${YELLOW}⚠️${RESET}   CONTRIBUTING.md                  missing  ${DIM}→ commit_gh --harden${RESET}"
    issues=$((issues + 1))
  fi

  # dependabot
  if [[ -f ".github/dependabot.yml" ]]; then
    always_msg "  ${GREEN}✅${RESET}  .github/dependabot.yml           present"
  else
    always_msg "  ${YELLOW}⚠️${RESET}   .github/dependabot.yml           missing  ${DIM}→ commit_gh --harden${RESET}"
    issues=$((issues + 1))
  fi

  # issue templates
  if [[ -f ".github/ISSUE_TEMPLATE/bug_report.md" ]] || [[ -d ".github/ISSUE_TEMPLATE" ]]; then
    always_msg "  ${GREEN}✅${RESET}  .github/ISSUE_TEMPLATE/          present"
  else
    always_msg "  ${YELLOW}⚠️${RESET}   .github/ISSUE_TEMPLATE/          missing  ${DIM}→ commit_gh --harden${RESET}"
    issues=$((issues + 1))
  fi

  # PR template
  if [[ -f ".github/pull_request_template.md" ]]; then
    always_msg "  ${GREEN}✅${RESET}  .github/pull_request_template.md present"
  else
    always_msg "  ${YELLOW}⚠️${RESET}   .github/pull_request_template.md missing  ${DIM}→ commit_gh --harden${RESET}"
    issues=$((issues + 1))
  fi

  # CODEOWNERS
  if [[ -f ".github/CODEOWNERS" ]]; then
    always_msg "  ${GREEN}✅${RESET}  .github/CODEOWNERS               present"
  else
    always_msg "  ${YELLOW}⚠️${RESET}   .github/CODEOWNERS               missing  ${DIM}→ commit_gh --harden${RESET}"
    issues=$((issues + 1))
  fi

  # .editorconfig
  if [[ -f ".editorconfig" ]]; then
    always_msg "  ${GREEN}✅${RESET}  .editorconfig                    present"
  else
    always_msg "  ${YELLOW}⚠️${RESET}   .editorconfig                    missing  ${DIM}→ commit_gh --harden${RESET}"
    issues=$((issues + 1))
  fi

  # release checklist
  if [[ -f "docs/release-checklist.md" ]]; then
    always_msg "  ${GREEN}✅${RESET}  docs/release-checklist.md        present"
  else
    always_msg "  ${YELLOW}⚠️${RESET}   docs/release-checklist.md        missing  ${DIM}→ commit_gh --harden${RESET}"
    issues=$((issues + 1))
  fi

  always_msg "$sep"
  if [[ $issues -eq 0 ]]; then
    always_msg "  ${GREEN}${BOLD}All guardrails in place.${RESET} 🔒"
  else
    always_msg "  ${YELLOW}${BOLD}${issues} guardrail(s) missing.${RESET}  Run: ${CYAN}commit_gh --harden${RESET}"
  fi
  always_msg ""

  [[ $issues -eq 0 ]]  # exit 0 = clean, exit 1 = issues found
}

# ----------------------------
# Repo helpers
# ----------------------------
ensure_repo() {
  if in_git_repo; then
    cd "$(git rev-parse --show-toplevel)" || exit 1
    if [[ "$INIT_REPO" == true ]]; then
      # Already initialised — idempotently apply any missing security files
      setup_security_files
    fi
    return 0
  fi

  if [[ "$INIT_REPO" != true ]]; then
    die "Not inside a git repository. Re-run with --init-repo to initialize one."
  fi

  msg "🧰 Initializing git repository in: $(pwd)"
  if [[ "$DRY_RUN" == true ]]; then
    msg "DRY RUN: git init"
    msg "DRY RUN: git checkout -b main"
    msg "DRY RUN: setup_security_files (.gitleaks.toml, pre-commit hook, gitleaks.yml)"
    return 0
  fi

  git init >/dev/null
  if git show-ref --verify --quiet refs/heads/main; then
    git checkout main >/dev/null
  else
    git checkout -b main >/dev/null
  fi
  setup_security_files

  # Commit scaffold files now so gh repo create --push has commits to push
  # and sets the local origin remote correctly.
  git add . >/dev/null
  if ! git diff --cached --quiet; then
    git commit -m "chore: initial scaffold" >/dev/null
    msg "✅ Initial commit created."
  fi
}

detect_branch() {
  if [[ -n "$BRANCH" ]]; then
    echo "$BRANCH"
    return 0
  fi
  if git rev-parse --verify HEAD >/dev/null 2>&1; then
    git rev-parse --abbrev-ref HEAD
  else
    echo "main"
  fi
}

has_origin_remote() { git remote | grep -q '^origin$'; }

ensure_origin_remote() {
  if has_origin_remote; then
    return 0
  fi

  if [[ "$INIT_REMOTE" != true ]]; then
    msg "⚠️ No 'origin' remote configured. Push and GitHub release creation will be skipped."
    return 1
  fi

  command -v gh >/dev/null 2>&1 || die "GitHub CLI 'gh' is required for --init-remote."

  local repo_root repo_name visibility_flag
  repo_root="$(pwd)"
  repo_name="${GIT_REPO_NAME:-$(basename "$repo_root")}"
  visibility_flag="--private"
  [[ "$REMOTE_VISIBILITY" == "public" ]] && visibility_flag="--public"

  msg "🐙 Creating GitHub repo '$repo_name' via gh and setting origin..."
  if [[ "$DRY_RUN" == true ]]; then
    msg "DRY RUN: gh repo create \"$repo_name\" --source \"$repo_root\" $visibility_flag --push"
    return 0
  fi

  gh repo create "$repo_name" --source "$repo_root" $visibility_flag --push || true

  # gh --push exits non-zero when no commits exist; repo is created on GitHub but
  # origin may not be set locally — add it manually so try_push() can handle it.
  if has_origin_remote; then
    msg "✅ Remote created and initial push done."
  else
    local gh_user
    gh_user="$(gh api user --jq '.login' 2>/dev/null || echo "")"
    if [[ -n "$gh_user" ]]; then
      git remote add origin "git@github.com:${gh_user}/${repo_name}.git"
      msg "✅ GitHub repo created. Origin set — will push after commit."
    else
      msg "⚠️ GitHub repo created but could not set origin. Run: git remote add origin <url>"
    fi
  fi
}

ensure_no_rebase_or_merge() {
  if [ -d ".git/rebase-merge" ] || [ -d ".git/rebase-apply" ]; then
    die "Git rebase is in progress. Resolve and run 'git rebase --continue' first."
  fi
  if [ -f ".git/MERGE_HEAD" ]; then
    die "Git merge is in progress. Resolve and complete the merge first."
  fi
}

ensure_ssh_agent() {
  if [ -z "${SSH_AUTH_SOCK:-}" ]; then
    eval "$(ssh-agent -s)" >/dev/null
    ssh-add -A >/dev/null 2>&1 || true
  fi
}

sync_with_remote_rebase() {
  local branch="$1"
  has_origin_remote || return 0

  if ! git diff --quiet; then
    msg "💾 Stashing unstaged local changes before pull --rebase..."
    if [[ "$DRY_RUN" == true ]]; then
      msg "DRY RUN: git stash -u"
      msg "DRY RUN: git pull --rebase origin \"$branch\""
      msg "DRY RUN: git stash pop"
      return 0
    fi

    git stash -u >/dev/null
    if ! git pull --rebase origin "$branch" >/dev/null 2>&1; then
      die "Pull/rebase failed. Resolve manually."
    fi
    if ! git stash pop >/dev/null 2>&1; then
      die "git stash pop failed after pull --rebase. Resolve the stash manually (git stash list, git stash show -p, git stash apply)."
    fi
  else
    if [[ "$DRY_RUN" == true ]]; then
      msg "DRY RUN: git pull --rebase origin \"$branch\""
      return 0
    fi
    git pull --rebase origin "$branch" >/dev/null 2>&1 || true
  fi
}

# ----------------------------
# VERSION helpers
# ----------------------------
resolve_realpath() {
  local p="$1"
  python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' "$p" 2>/dev/null || echo "$p"
}

# Returns the writable repo copy of this script (bin/commit_gh in the current
# git repo root) if one exists, otherwise falls back to the running script path.
# This lets the globally-installed Homebrew binary correctly update the repo
# copy rather than trying to write to the read-only Cellar.
resolve_script_target() {
  # Returns the path to bin/commit_gh ONLY if it exists in the current git repo.
  # Returns empty string when not in the commit_gh_cli repo, to avoid accidentally
  # modifying the installed binary when releasing unrelated projects.
  local repo_root
  repo_root="$(git rev-parse --show-toplevel 2>/dev/null)" || return 0
  local candidate="$repo_root/bin/commit_gh"
  [[ -f "$candidate" ]] && resolve_realpath "$candidate" || true
}

update_self_version_constant() {
  local new_version="$1"
  local target_path
  target_path="$(resolve_script_target)"
  [[ -z "$target_path" ]] && return 0  # Not in the commit_gh_cli repo — skip silently

  if grep -qE '^VERSION="[^"]+"' "$target_path"; then
    if [[ "$DRY_RUN" == true ]]; then
      msg "DRY RUN: sed VERSION → $new_version in $target_path"
      return 0
    fi
    sed -i '' -E "s/^VERSION=\"[^\"]+\"/VERSION=\"${new_version}\"/" "$target_path"
    msg "✅ Updated VERSION constant in $(basename "$target_path") to $new_version"
  fi
}

get_self_version_constant() {
  local target_path
  target_path="$(resolve_script_target)"
  [[ -z "$target_path" ]] && return 0  # Not in the commit_gh_cli repo

  grep -E '^VERSION="[^"]+"' "$target_path" |
    head -n1 |
    sed -E 's/^VERSION="([^"]+)".*/\1/'
}

read_semver() {
  local v="$1"
  [[ "$v" =~ ^([0-9]+)\.([0-9]+)\.([0-9]+)$ ]] || return 1
  SEMVER_MAJOR="${BASH_REMATCH[1]}"
  SEMVER_MINOR="${BASH_REMATCH[2]}"
  SEMVER_PATCH="${BASH_REMATCH[3]}"
  return 0
}

bump_semver() {
  local bump="$1" major="$2" minor="$3" patch="$4"
  case "$bump" in
  patch) patch=$((patch + 1)) ;;
  minor)
    minor=$((minor + 1))
    patch=0
    ;;
  major)
    major=$((major + 1))
    minor=0
    patch=0
    ;;
  *) die "Unknown bump type: $bump" ;;
  esac
  echo "${major}.${minor}.${patch}"
}

ensure_version_file() {
  local vf="$1"
  if [[ ! -f "$vf" ]]; then
    msg "⚠️ Version file '$vf' not found. Creating with 0.0.0"
    if [[ "$DRY_RUN" == true ]]; then
      msg "DRY RUN: echo 0.0.0 > \"$vf\""
      return 0
    fi
    echo "0.0.0" >"$vf"
  fi
}

create_github_release() {
  local tag="$1"
  command -v gh >/dev/null 2>&1 || {
    msg "⚠️ gh not found. Skipping GitHub release."
    return 0
  }
  has_origin_remote || {
    msg "⚠️ No origin remote. Skipping GitHub release."
    return 0
  }

  local notes_flag="--notes \"Release $tag\""
  [[ "$RELEASE_GENERATE_NOTES" == true ]] && notes_flag="--generate-notes"

  if [[ "$DRY_RUN" == true ]]; then
    msg "DRY RUN: gh release create \"$tag\" --title \"$tag\" $notes_flag"
    return 0
  fi

  if gh release view "$tag" >/dev/null 2>&1; then
    if [[ "$RELEASE_FORCE" == true ]]; then
      msg "🗑️ Deleting existing GitHub release $tag (--force)..."
      gh release delete "$tag" --yes >/dev/null 2>&1 || true
    else
      msg "⚠️ GitHub release $tag already exists. Use --force to overwrite."
      return 0
    fi
  fi

  msg "📦 Creating GitHub release $tag..."
  if [[ "$RELEASE_GENERATE_NOTES" == true ]]; then
    local _release_url
    _release_url="$(gh release create "$tag" --title "$tag" --generate-notes)"
    msg "$_release_url"
    local _body
    _body="$(gh release view "$tag" --json body --jq '.body' 2>/dev/null || true)"
    if [[ -n "$_body" ]]; then
      msg ""
      msg "${BOLD}  📝 Generated release notes:${RESET}"
      while IFS= read -r _line; do
        msg "  ${DIM}${_line}${RESET}"
      done <<< "$_body"
    fi
  else
    gh release create "$tag" --title "$tag" --notes "Release $tag"
  fi
}

publish_image() {
  local tag="$1"
  command -v docker >/dev/null 2>&1 || {
    msg "⚠️ docker not found. Skipping image publish."
    return 0
  }
  command -v gh >/dev/null 2>&1 || {
    msg "⚠️ gh not found. Skipping image publish."
    return 0
  }
  has_origin_remote || {
    msg "⚠️ No origin remote. Skipping image publish."
    return 0
  }

  local dockerfile="${IMAGE_CONTEXT%/}/Dockerfile"
  [[ -f "$dockerfile" ]] || {
    msg "⚠️ No Dockerfile at $dockerfile. Skipping image publish."
    return 0
  }

  local name_with_owner owner repo image_name image_ref
  name_with_owner="$(gh repo view --json nameWithOwner --jq '.nameWithOwner' 2>/dev/null || true)"
  [[ -n "$name_with_owner" ]] || {
    msg "⚠️ Could not resolve repo owner via gh. Skipping image publish."
    return 0
  }
  owner="${name_with_owner%%/*}"
  repo="${name_with_owner##*/}"
  image_name="${IMAGE_NAME:-$repo}"
  image_ref="${IMAGE_REGISTRY}/${owner}/${image_name}"

  if [[ "$IMAGE_REGISTRY" == "ghcr.io" ]]; then
    if [[ "$DRY_RUN" == true ]]; then
      msg "  DRY RUN: gh auth token | docker login ghcr.io -u $owner --password-stdin"
    else
      gh auth token 2>/dev/null | docker login ghcr.io -u "$owner" --password-stdin >/dev/null 2>&1 \
        || { msg "⚠️ docker login to ghcr.io failed. Skipping image publish."; return 0; }
    fi
  else
    msg "⚠️ Registry '$IMAGE_REGISTRY' has no built-in auth — assuming you're already logged in."
  fi

  msg "📦 Building $image_ref:$tag (context: $IMAGE_CONTEXT)..."
  if [[ "$DRY_RUN" == true ]]; then
    msg "  DRY RUN: docker build -t $image_ref:$tag -t $image_ref:latest $IMAGE_CONTEXT"
    msg "  DRY RUN: docker push $image_ref:$tag"
    msg "  DRY RUN: docker push $image_ref:latest"
    return 0
  fi

  docker build -t "$image_ref:$tag" -t "$image_ref:latest" "$IMAGE_CONTEXT" \
    || { msg "⚠️ docker build failed. Skipping image publish."; return 0; }

  docker push "$image_ref:$tag" || { msg "⚠️ docker push $tag failed."; return 0; }
  docker push "$image_ref:latest" || { msg "⚠️ docker push latest failed."; return 0; }

  msg "  ${GREEN}✓${RESET} Published $image_ref:$tag and $image_ref:latest"
}

run_read_version() {
  in_git_repo || die "Not inside a git repository."
  cd "$(git rev-parse --show-toplevel)" || exit 1

  local repo_name vf_version script_version latest_tag tag_version consistent=true
  repo_name="$(basename "$(pwd)")"

  vf_version="$([ -f "$VERSION_FILE" ] && cat "$VERSION_FILE" || echo "missing")"
  script_version="n/a"
  if [[ -f "bin/commit_gh" ]]; then
    script_version="$(grep -E '^VERSION="[^"]+"' "bin/commit_gh" | head -n1 | sed -E 's/^VERSION="([^"]+)".*/\1/')"
  fi
  latest_tag="$(git tag --sort=-v:refname | grep -E '^v[0-9]+\.[0-9]+\.[0-9]+$' | head -n1 || true)"
  [[ -z "$latest_tag" ]] && latest_tag="none"
  tag_version="${latest_tag#v}"
  [[ "$latest_tag" == "none" ]] && tag_version="none"

  always_msg ""
  always_msg "${BOLD}${CYAN}── Version inventory: ${repo_name}${RESET}"
  always_msg "${DIM}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
  printf "  %-30s ${BOLD}%s${RESET}\n" "$VERSION_FILE" "$vf_version"
  [[ "$script_version" != "n/a" ]] && printf "  %-30s ${BOLD}%s${RESET}\n" "bin/commit_gh VERSION=" "$script_version"
  printf "  %-30s ${BOLD}%s${RESET}\n" "Latest git tag" "$latest_tag"
  always_msg "${DIM}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"

  if [[ "$vf_version" == "missing" ]]; then
    always_msg "  ${RED}✗ $VERSION_FILE not found${RESET}"
    consistent=false
  elif [[ "$latest_tag" == "none" ]]; then
    always_msg "  ${YELLOW}⚠ No tags yet — next release will create v$vf_version${RESET}"
  elif [[ "$vf_version" != "$tag_version" ]]; then
    always_msg "  ${RED}✗ VERSION ($vf_version) does not match latest tag ($latest_tag)${RESET}"
    consistent=false
  else
    always_msg "  ${GREEN}✓ VERSION and latest tag aligned at $vf_version${RESET}"
  fi

  if [[ "$script_version" != "n/a" && "$script_version" != "$vf_version" ]]; then
    always_msg "  ${YELLOW}⚠ bin/commit_gh VERSION= ($script_version) ≠ VERSION file ($vf_version)${RESET}"
    consistent=false
  fi

  always_msg ""
  if [[ "$consistent" == true ]]; then
    always_msg "  ${GREEN}${BOLD}✓ Version sources consistent.${RESET}"
  else
    always_msg "  ${RED}${BOLD}✗ Version sources inconsistent.${RESET}"
    exit 1
  fi
  always_msg ""
}

run_doctor() {
  local issues=0
  local sep="${DIM}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"

  always_msg ""
  always_msg "${BOLD}🩺 commit_gh doctor${RESET}"
  always_msg "$sep"

  # bash version (needs 4+; macOS ships with 3)
  local _bash_ver _bash_major
  _bash_ver="$(bash --version 2>/dev/null | head -n1 | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -n1)"
  _bash_major="${_bash_ver%%.*}"
  if [[ "${_bash_major:-0}" -ge 4 ]]; then
    always_msg "  ${GREEN}✅${RESET}  bash                     ${_bash_ver}  ${DIM}($(command -v bash))${RESET}"
  else
    always_msg "  ${RED}❌${RESET}  bash                     ${_bash_ver:-unknown}  ${DIM}needs 4+ → brew install bash${RESET}"
    issues=$((issues + 1))
  fi

  # git
  if command -v git >/dev/null 2>&1; then
    local _git_ver
    _git_ver="$(git --version 2>/dev/null | grep -oE '[0-9]+\.[0-9]+\.[0-9]+')"
    always_msg "  ${GREEN}✅${RESET}  git                      ${_git_ver}  ${DIM}($(command -v git))${RESET}"
    local _git_name _git_email
    _git_name="$(git config --global user.name 2>/dev/null || echo "")"
    _git_email="$(git config --global user.email 2>/dev/null || echo "")"
    if [[ -n "$_git_name" && -n "$_git_email" ]]; then
      always_msg "  ${GREEN}✅${RESET}  git user                 ${_git_name} <${_git_email}>"
    else
      always_msg "  ${RED}❌${RESET}  git user                 not configured  ${DIM}→ git config --global user.name / user.email${RESET}"
      issues=$((issues + 1))
    fi
  else
    always_msg "  ${RED}❌${RESET}  git                      not found"
    issues=$((issues + 1))
  fi

  # gitleaks
  if command -v gitleaks >/dev/null 2>&1; then
    local _gl_ver
    _gl_ver="$(gitleaks version 2>/dev/null | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -n1 || echo "?")"
    always_msg "  ${GREEN}✅${RESET}  gitleaks                 v${_gl_ver}  ${DIM}($(command -v gitleaks))${RESET}"
  else
    always_msg "  ${RED}❌${RESET}  gitleaks                 not installed  ${DIM}→ brew install gitleaks${RESET}"
    issues=$((issues + 1))
  fi

  # gh CLI + auth
  if command -v gh >/dev/null 2>&1; then
    local _gh_ver
    _gh_ver="$(gh --version 2>/dev/null | head -n1 | grep -oE '[0-9]+\.[0-9]+\.[0-9]+')"
    always_msg "  ${GREEN}✅${RESET}  gh CLI                   v${_gh_ver}  ${DIM}($(command -v gh))${RESET}"
    local _gh_user
    _gh_user="$(gh api user --jq '.login' 2>/dev/null || echo "")"
    if [[ -n "$_gh_user" ]]; then
      always_msg "  ${GREEN}✅${RESET}  gh auth                  authenticated as ${BOLD}${_gh_user}${RESET}"
    else
      always_msg "  ${RED}❌${RESET}  gh auth                  not authenticated  ${DIM}→ gh auth login${RESET}"
      issues=$((issues + 1))
    fi
  else
    always_msg "  ${RED}❌${RESET}  gh CLI                   not installed  ${DIM}→ brew install gh${RESET}"
    issues=$((issues + 1))
  fi

  # SSH agent
  if [[ -n "${SSH_AUTH_SOCK:-}" ]]; then
    local _key_count
    _key_count="$(ssh-add -l 2>/dev/null | grep -c 'SHA256' || true)"
    if [[ "$_key_count" -gt 0 ]]; then
      always_msg "  ${GREEN}✅${RESET}  SSH agent                running  ${DIM}(${_key_count} key(s) loaded)${RESET}"
    else
      always_msg "  ${YELLOW}⚠️${RESET}   SSH agent                running but no keys loaded  ${DIM}→ ssh-add ~/.ssh/id_ed25519${RESET}"
    fi
  else
    always_msg "  ${YELLOW}⚠️${RESET}   SSH agent                not running  ${DIM}→ eval \"\$(ssh-agent -s)\" && ssh-add${RESET}"
  fi

  always_msg "$sep"
  if [[ $issues -eq 0 ]]; then
    always_msg "  ${GREEN}${BOLD}Environment ready.${RESET} 🩺"
  else
    always_msg "  ${YELLOW}${BOLD}${issues} issue(s) found.${RESET}  Fix above to use all commit_gh features."
  fi
  always_msg ""
}

do_rollback() {
  local tag="${1:-latest}"
  local sep="${DIM}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"

  if [[ "$tag" == "latest" ]]; then
    tag="$(git tag --sort=-v:refname | grep -E '^v[0-9]+\.[0-9]+\.[0-9]+$' | head -n1 || true)"
    [[ -z "$tag" ]] && die "No release tags found to roll back."
  fi
  [[ "$tag" =~ ^v ]] || tag="v$tag"

  git rev-parse "$tag" >/dev/null 2>&1 || die "Tag $tag does not exist locally."

  always_msg ""
  always_msg "${BOLD}🔄 commit_gh rollback — undoing release $tag${RESET}"
  always_msg "$sep"

  # 1. Delete GitHub release
  if command -v gh >/dev/null 2>&1 && has_origin_remote; then
    local remote_url repo_slug
    remote_url="$(git remote get-url origin 2>/dev/null || echo "")"
    repo_slug="$(echo "$remote_url" | sed -E 's|.*github\.com[:/]([^/]+/[^/.]+)(\.git)?$|\1|')"
    if [[ -n "$repo_slug" && "$repo_slug" != "$remote_url" ]]; then
      if gh release view "$tag" --repo "$repo_slug" >/dev/null 2>&1; then
        if [[ "$DRY_RUN" == true ]]; then
          msg "  DRY RUN: gh release delete $tag --repo $repo_slug --yes"
        else
          if gh release delete "$tag" --repo "$repo_slug" --yes 2>/dev/null; then
            always_msg "  ${GREEN}✓${RESET} Deleted GitHub release $tag"
          else
            always_msg "  ${YELLOW}⚠${RESET}  Could not delete GitHub release (check admin access)"
          fi
        fi
      else
        always_msg "  ${DIM}No GitHub release found for $tag${RESET}"
      fi
    fi
  fi

  # 2. Delete remote tag
  if has_origin_remote; then
    if git ls-remote --tags origin "refs/tags/$tag" 2>/dev/null | grep -q "$tag"; then
      if [[ "$DRY_RUN" == true ]]; then
        msg "  DRY RUN: git push origin --delete $tag"
      else
        if git push origin --delete "$tag" >/dev/null 2>&1; then
          always_msg "  ${GREEN}✓${RESET} Deleted remote tag $tag"
        else
          always_msg "  ${YELLOW}⚠${RESET}  Could not delete remote tag (check push permissions)"
        fi
      fi
    else
      always_msg "  ${DIM}Remote tag $tag not found${RESET}"
    fi
  fi

  # 3. Delete local tag
  if [[ "$DRY_RUN" == true ]]; then
    msg "  DRY RUN: git tag -d $tag"
  else
    git tag -d "$tag" >/dev/null 2>&1 && always_msg "  ${GREEN}✓${RESET} Deleted local tag $tag"
  fi

  # 4. Revert release commit if it is HEAD and matches this tag
  local head_msg tag_version
  head_msg="$(git log -1 --pretty=format:"%s" 2>/dev/null || echo "")"
  tag_version="${tag#v}"
  if [[ "$head_msg" == "chore: release v${tag_version}" ]]; then
    always_msg "  ${DIM}Release commit detected at HEAD: ${head_msg}${RESET}"
    if [[ "$DRY_RUN" == true ]]; then
      msg "  DRY RUN: git revert HEAD --no-edit"
      msg "  DRY RUN: git push origin $(detect_branch)"
    else
      if git revert HEAD --no-edit >/dev/null 2>&1; then
        always_msg "  ${GREEN}✓${RESET} Reverted release commit (VERSION restored)"
        if has_origin_remote; then
          git push origin "$(detect_branch)" >/dev/null 2>&1 && \
            always_msg "  ${GREEN}✓${RESET} Pushed revert to origin"
        fi
      else
        always_msg "  ${YELLOW}⚠${RESET}  Auto-revert failed — revert manually: ${DIM}git revert HEAD${RESET}"
      fi
    fi
  else
    always_msg "  ${DIM}HEAD is not the release commit — VERSION file not auto-reverted${RESET}"
  fi

  always_msg "$sep"
  always_msg "  ${GREEN}${BOLD}Rollback of $tag complete.${RESET} 🔄"
  always_msg ""
}

setup_signing() {
  local sep="${DIM}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
  local issues=0

  always_msg ""
  always_msg "${BOLD}🔏 commit_gh sign — commit signing setup${RESET}"
  always_msg "$sep"

  # Detect GPG key
  local gpg_key_id=""
  if command -v gpg >/dev/null 2>&1; then
    gpg_key_id="$(gpg --list-secret-keys --keyid-format LONG 2>/dev/null \
      | grep '^sec' | head -n1 \
      | grep -oE '[A-F0-9]{16}' | head -n1 || true)"
  fi

  # Detect SSH public key
  local ssh_pub_key=""
  if [[ -n "${SSH_AUTH_SOCK:-}" ]]; then
    ssh_pub_key="$(ssh-add -L 2>/dev/null | head -n1 || true)"
  fi

  local current_gpgsign gpg_format current_sigkey
  current_gpgsign="$(git config --global --get commit.gpgsign 2>/dev/null || echo "false")"
  gpg_format="$(git config --global --get gpg.format 2>/dev/null || echo "openpgp")"
  current_sigkey="$(git config --global --get user.signingkey 2>/dev/null || echo "")"

  if [[ -n "$gpg_key_id" ]]; then
    always_msg "  ${GREEN}✅${RESET}  GPG key              ${BOLD}${gpg_key_id}${RESET}"
    if [[ "$current_gpgsign" == "true" && "$gpg_format" == "openpgp" ]]; then
      always_msg "  ${GREEN}✅${RESET}  GPG signing          already enabled"
    else
      if [[ "$DRY_RUN" == true ]]; then
        msg "  DRY RUN: git config --global commit.gpgsign true"
        msg "  DRY RUN: git config --global gpg.format openpgp"
        msg "  DRY RUN: git config --global user.signingkey $gpg_key_id"
      else
        git config --global commit.gpgsign true
        git config --global gpg.format openpgp
        [[ -z "$current_sigkey" ]] && git config --global user.signingkey "$gpg_key_id"
        always_msg "  ${GREEN}✅${RESET}  GPG signing          enabled  ${DIM}(commit.gpgsign=true, key=$gpg_key_id)${RESET}"
      fi
    fi
  elif [[ -n "$ssh_pub_key" ]]; then
    always_msg "  ${GREEN}✅${RESET}  SSH key              found in agent"
    if [[ "$current_gpgsign" == "true" && "$gpg_format" == "ssh" ]]; then
      always_msg "  ${GREEN}✅${RESET}  SSH signing          already enabled"
    else
      if [[ "$DRY_RUN" == true ]]; then
        msg "  DRY RUN: git config --global gpg.format ssh"
        msg "  DRY RUN: git config --global user.signingkey \"<ssh-pub-key>\""
        msg "  DRY RUN: git config --global commit.gpgsign true"
      else
        git config --global gpg.format ssh
        git config --global user.signingkey "$ssh_pub_key"
        git config --global commit.gpgsign true
        always_msg "  ${GREEN}✅${RESET}  SSH signing          enabled  ${DIM}(gpg.format=ssh)${RESET}"
        always_msg "  ${DIM}  Tip: add your public key to ~/.ssh/allowed_signers for local verification${RESET}"
        always_msg "       ${DIM}echo \"\$(git config user.email) $ssh_pub_key\" >> ~/.ssh/allowed_signers${RESET}"
        always_msg "       ${DIM}git config --global gpg.ssh.allowedSignersFile ~/.ssh/allowed_signers${RESET}"
      fi
    fi
  else
    always_msg "  ${RED}❌${RESET}  No signing key found"
    always_msg "     ${DIM}GPG:  gpg --gen-key${RESET}"
    always_msg "     ${DIM}SSH:  ssh-keygen -t ed25519 -C \"$(git config --global user.email 2>/dev/null || echo "you@example.com")\"${RESET}"
    issues=$((issues + 1))
  fi

  # Add CI workflow to current repo
  if in_git_repo && [[ $issues -eq 0 ]]; then
    local wf_dir wf_file repo_root
    repo_root="$(git rev-parse --show-toplevel)"
    wf_dir="$repo_root/.github/workflows"
    wf_file="$wf_dir/signed-commits.yml"
    if [[ ! -f "$wf_file" ]]; then
      if [[ "$DRY_RUN" == true ]]; then
        msg "  DRY RUN: create .github/workflows/signed-commits.yml"
      else
        mkdir -p "$wf_dir"
        cat > "$wf_file" <<'SIGN_WF'
name: Verify signed commits
on:
  push:
    branches: [main]
  pull_request:
    branches: [main]

permissions:
  contents: read

jobs:
  signed-commits:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@11bd71901bbe5b1630ceea73d27597364c9af683  # v4.2.2
        with:
          fetch-depth: 0
      - name: Check commit signatures
        run: |
          COMMITS=$(git log --pretty="%G?" origin/main..HEAD 2>/dev/null || true)
          if [[ -z "$COMMITS" ]]; then
            echo "No commits to verify."
            exit 0
          fi
          if echo "$COMMITS" | grep -qvE '^[GU]$'; then
            echo "Unsigned or invalid commits detected."
            exit 1
          fi
          echo "All commits signed."
SIGN_WF
        always_msg "  ${GREEN}✅${RESET}  CI workflow          .github/workflows/signed-commits.yml created"
      fi
    else
      always_msg "  ${GREEN}✅${RESET}  CI workflow          signed-commits.yml already present"
    fi
    always_msg "  ${DIM}  Remember to upload your public key to GitHub → Settings → SSH and GPG keys${RESET}"
  fi

  always_msg "$sep"
  if [[ $issues -eq 0 ]]; then
    always_msg "  ${GREEN}${BOLD}Commit signing configured.${RESET} 🔏"
  else
    always_msg "  ${YELLOW}${BOLD}${issues} issue(s) found.${RESET}  Set up a signing key, then re-run ${CYAN}commit_gh --sign${RESET}."
  fi
  always_msg ""
}

setup_labels() {
  command -v gh >/dev/null 2>&1 || die "gh CLI not found. Install with: brew install gh"
  has_origin_remote || die "No origin remote found. Run --init-remote first."

  local remote_url repo_slug
  remote_url="$(git remote get-url origin 2>/dev/null || echo "")"
  repo_slug="$(echo "$remote_url" | sed -E 's|.*github\.com[:/]([^/]+/[^/.]+)(\.git)?$|\1|')"
  [[ -z "$repo_slug" || "$repo_slug" == "$remote_url" ]] && die "Could not determine repo slug from origin URL."

  local sep="${DIM}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
  always_msg ""
  always_msg "${BOLD}🏷️  commit_gh labels — GitHub label setup${RESET}"
  always_msg "$sep"
  always_msg "  Repo: ${BOLD}${repo_slug}${RESET}"
  always_msg ""

  # name|hex-color|description  (no colons in description)
  local -a label_defs=(
    "bug|d73a4a|Something isn't working"
    "enhancement|a2eeef|New feature or request"
    "security|e4e669|Security vulnerability or hardening"
    "breaking|b60205|Breaking change — requires consumer action"
    "documentation|0075ca|Improvements or additions to documentation"
    "good first issue|7057ff|Good for newcomers"
    "help wanted|008672|Extra attention is needed"
    "question|d876e3|Further information is requested"
    "wontfix|ffffff|This will not be worked on"
    "duplicate|cfd3d7|This issue or pull request already exists"
    "dependencies|0366d6|Dependency update"
    "ci/cd|f9d0c4|Continuous integration and deployment"
  )

  local created=0 failed=0 lname lcolor ldesc
  for def in "${label_defs[@]}"; do
    IFS='|' read -r lname lcolor ldesc <<< "$def"
    if [[ "$DRY_RUN" == true ]]; then
      msg "  DRY RUN: gh label create \"$lname\" --color \"$lcolor\" --description \"$ldesc\" --force"
      continue
    fi
    if gh label create "$lname" \
        --color "$lcolor" \
        --description "$ldesc" \
        --repo "$repo_slug" \
        --force 2>/dev/null; then
      always_msg "  ${GREEN}✓${RESET}  ${BOLD}${lname}${RESET}  ${DIM}#${lcolor}${RESET}"
      created=$((created + 1))
    else
      always_msg "  ${RED}✗${RESET}  ${lname}  ${DIM}(failed — check admin access)${RESET}"
      failed=$((failed + 1))
    fi
  done

  always_msg ""
  always_msg "$sep"
  if [[ "$DRY_RUN" == true ]]; then
    always_msg "  ${DIM}DRY RUN: would create/update ${#label_defs[@]} labels on ${repo_slug}${RESET}"
  elif [[ $failed -eq 0 ]]; then
    always_msg "  ${GREEN}${BOLD}${created} labels configured.${RESET} 🏷️"
    always_msg "  ${DIM}View: https://github.com/${repo_slug}/labels${RESET}"
  else
    always_msg "  ${YELLOW}${BOLD}${created} created, ${failed} failed.${RESET}  Check admin access on ${repo_slug}."
  fi
  always_msg ""
}

create_pr() {
  local head_branch="$1"
  local pr_title="${2:-}"

  command -v gh >/dev/null 2>&1 || die "gh CLI not found. Install with: brew install gh"
  has_origin_remote || die "No origin remote found. Run --init-remote first."

  local base_branch
  base_branch="$(gh repo view --json defaultBranchRef --jq '.defaultBranchRef.name' 2>/dev/null || echo "main")"

  if [[ "$head_branch" == "$base_branch" ]]; then
    die "Cannot create a PR from '${head_branch}' into itself. Use --branch <feature> or --message to auto-derive a branch name."
  fi

  local sep="${DIM}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"

  # Guard: GitHub rejects PRs when there are no commits between branches.
  local _ahead=0
  _ahead="$(git rev-list --count "${head_branch}" "^origin/${base_branch}" 2>/dev/null \
           || git rev-list --count "${head_branch}" "^${base_branch}" 2>/dev/null \
           || echo "0")"
  if [[ "$_ahead" -eq 0 && "$DRY_RUN" != true ]]; then
    always_msg ""
    always_msg "${BOLD}🔀 commit_gh pull request${RESET}"
    always_msg "$sep"
    always_msg "  ${YELLOW}⚠️${RESET}  ${BOLD}${head_branch}${RESET} has no commits ahead of ${BOLD}${base_branch}${RESET}"
    always_msg "  ${DIM}Make your changes, then re-run:${RESET}"
    always_msg "  ${DIM}  commit_gh --pr --message \"your change\"${RESET}"
    always_msg ""
    always_msg "$sep"
    always_msg ""
    return 0
  fi

  # Ensure branch exists on remote — try_push skips when there's nothing new to push.
  if [[ "$DRY_RUN" != true ]]; then
    if ! git ls-remote --exit-code --heads origin "$head_branch" >/dev/null 2>&1; then
      msg "🌱 Publishing branch ${CYAN}${head_branch}${RESET} to origin..."
      git push -u origin "$head_branch" >/dev/null 2>&1 \
        || die "Failed to push branch '$head_branch' to origin. Check permissions."
    fi
  fi

  [[ -z "$pr_title" ]] && \
    pr_title="$(git log -1 --pretty=format:"%s" 2>/dev/null || echo "PR from ${head_branch}")"

  local draft_label=""
  [[ "$PR_DRAFT" == true ]] && draft_label="  ${DIM}(draft)${RESET}"

  always_msg ""
  always_msg "${BOLD}🔀 commit_gh pull request${RESET}"
  always_msg "$sep"
  always_msg "  ${BOLD}${head_branch}${RESET}  →  ${BOLD}${base_branch}${RESET}${draft_label}"
  always_msg "  Title: ${BOLD}${pr_title}${RESET}"
  always_msg ""

  if [[ "$DRY_RUN" == true ]]; then
    local _draft_flag=""
    [[ "$PR_DRAFT" == true ]] && _draft_flag=" --draft"
    msg "  DRY RUN: gh pr create --base \"$base_branch\" --head \"$head_branch\" --title \"$pr_title\" --body \"\"${_draft_flag}"
    always_msg "$sep"
    always_msg "  ${DIM}DRY RUN: no PR created${RESET}"
    always_msg ""
    return 0
  fi

  local _pr_body=""
  [[ -f ".github/pull_request_template.md" ]] && _pr_body="$(<.github/pull_request_template.md)"

  local _pr_args=(--base "$base_branch" --head "$head_branch" --title "$pr_title" --body "$_pr_body")
  [[ "$PR_DRAFT" == true ]] && _pr_args+=(--draft)

  local _gh_out _gh_exit=0
  _gh_out="$(gh pr create "${_pr_args[@]}" 2>&1)" || _gh_exit=$?

  if [[ $_gh_exit -eq 0 ]]; then
    always_msg "  ${GREEN}✅${RESET}  PR created${draft_label}"
    always_msg "  ${DIM}${_gh_out}${RESET}"
  else
    local existing
    existing="$(gh pr view --json url --jq '.url' 2>/dev/null || true)"
    if [[ -n "$existing" ]]; then
      always_msg "  ${YELLOW}⚠️${RESET}  PR already exists"
      always_msg "  ${DIM}${existing}${RESET}"
    else
      always_msg "  ${RED}❌${RESET}  PR creation failed"
      [[ -n "$_gh_out" ]] && always_msg "  ${DIM}${_gh_out}${RESET}"
    fi
  fi

  always_msg ""
  always_msg "$sep"
  always_msg ""
}

preview_changelog() {
  local bump="${1:-patch}"
  in_git_repo || die "Not inside a git repository."
  cd "$(git rev-parse --show-toplevel)" || exit 1

  local vf_version new_version
  vf_version="$([[ -f "$VERSION_FILE" ]] && cat "$VERSION_FILE" || echo "0.0.0")"
  read_semver "$vf_version" || die "Invalid VERSION '$vf_version'. Expected X.Y.Z"

  if [[ "$bump" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
    new_version="$bump"
  else
    new_version="$(bump_semver "$bump" "$SEMVER_MAJOR" "$SEMVER_MINOR" "$SEMVER_PATCH")"
  fi

  local date_str prev_tag log_range
  date_str="$(date +%Y-%m-%d)"
  prev_tag="$(git tag --sort=-v:refname | grep -E '^v[0-9]+\.[0-9]+\.[0-9]+$' | head -n1 2>/dev/null || true)"
  [[ -n "$prev_tag" ]] && log_range="${prev_tag}..HEAD" || log_range="HEAD"

  local -a _added=() _fixed=() _changed=() _security=()
  while IFS= read -r _subj; do
    [[ -z "$_subj" ]] && continue
    [[ "$_subj" =~ ^Merge[[:space:]] ]] && continue
    [[ "$_subj" =~ ^chore:[[:space:]]release ]] && continue
    case "$_subj" in
      feat:*|feat\(*\):*)     _added+=("${_subj#*: }") ;;
      fix:*|fix\(*\):*)       _fixed+=("${_subj#*: }") ;;
      security:*)             _security+=("${_subj#*: }") ;;
      chore:*|refactor:*|perf:*|build:*|ci:*|docs:*)
                              _changed+=("${_subj#*: }") ;;
    esac
  done < <(git log --pretty=format:"%s" $log_range 2>/dev/null || true)

  local sep="${DIM}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
  always_msg ""
  always_msg "${BOLD}📋 commit_gh changelog preview${RESET}"
  always_msg "$sep"
  [[ -n "$prev_tag" ]] && always_msg "  ${DIM}Since: ${prev_tag}..HEAD${RESET}" \
                       || always_msg "  ${DIM}Since: beginning of history${RESET}"
  always_msg ""
  always_msg "## [${new_version}] - ${date_str}"

  if [[ ${#_added[@]} -eq 0 && ${#_fixed[@]} -eq 0 && \
        ${#_changed[@]} -eq 0 && ${#_security[@]} -eq 0 ]]; then
    always_msg ""
    always_msg "  ${YELLOW}(no conventional commits found — nothing to add to CHANGELOG)${RESET}"
    always_msg "  ${DIM}Tip: use feat:, fix:, security:, chore:, docs: prefixes${RESET}"
  else
    if [[ ${#_added[@]} -gt 0 ]]; then
      always_msg ""; always_msg "### Added"; always_msg ""
      for _item in "${_added[@]}"; do always_msg "- ${_item}"; done
    fi
    if [[ ${#_fixed[@]} -gt 0 ]]; then
      always_msg ""; always_msg "### Fixed"; always_msg ""
      for _item in "${_fixed[@]}"; do always_msg "- ${_item}"; done
    fi
    if [[ ${#_changed[@]} -gt 0 ]]; then
      always_msg ""; always_msg "### Changed"; always_msg ""
      for _item in "${_changed[@]}"; do always_msg "- ${_item}"; done
    fi
    if [[ ${#_security[@]} -gt 0 ]]; then
      always_msg ""; always_msg "### Security"; always_msg ""
      for _item in "${_security[@]}"; do always_msg "- ${_item}"; done
    fi
  fi

  always_msg ""
  always_msg "$sep"
  always_msg "  ${DIM}Preview only — no files modified.${RESET}"
  always_msg "  ${DIM}Run ${CYAN}commit_gh --release ${bump}${RESET}${DIM} to generate the actual release.${RESET}"
  always_msg ""
}

setup_milestone() {
  local bump="${1:-patch}"
  command -v gh >/dev/null 2>&1 || die "gh CLI not found. Install with: brew install gh"
  in_git_repo || die "Not inside a git repository."
  cd "$(git rev-parse --show-toplevel)" || exit 1
  has_origin_remote || die "No origin remote found. Run --init-remote first."

  local remote_url repo_slug
  remote_url="$(git remote get-url origin 2>/dev/null || echo "")"
  repo_slug="$(echo "$remote_url" | sed -E 's|.*github\.com[:/]([^/]+/[^/.]+)(\.git)?$|\1|')"
  [[ -z "$repo_slug" || "$repo_slug" == "$remote_url" ]] && die "Could not determine repo slug from origin URL."

  local vf_version new_version
  vf_version="$([[ -f "$VERSION_FILE" ]] && cat "$VERSION_FILE" || echo "0.0.0")"
  read_semver "$vf_version" || die "Invalid VERSION '$vf_version'. Expected X.Y.Z"

  if [[ "$bump" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
    new_version="$bump"
  else
    new_version="$(bump_semver "$bump" "$SEMVER_MAJOR" "$SEMVER_MINOR" "$SEMVER_PATCH")"
  fi

  local milestone_title="v${new_version}"
  local sep="${DIM}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"

  always_msg ""
  always_msg "${BOLD}🎯 commit_gh milestone${RESET}"
  always_msg "$sep"
  always_msg "  Repo:      ${BOLD}${repo_slug}${RESET}"
  always_msg "  Milestone: ${BOLD}${milestone_title}${RESET}"
  always_msg ""

  if [[ "$DRY_RUN" == true ]]; then
    msg "  DRY RUN: gh api repos/$repo_slug/milestones --method POST --field title=\"$milestone_title\""
    always_msg "$sep"
    always_msg "  ${DIM}DRY RUN: would create milestone ${milestone_title} on ${repo_slug}${RESET}"
    always_msg ""
    return 0
  fi

  local ms_url
  if ms_url="$(gh api "repos/$repo_slug/milestones" \
    --method POST \
    --field "title=$milestone_title" \
    --field "description=Tracks work for release $milestone_title" \
    --jq '.html_url' 2>/dev/null)"; then
    always_msg "  ${GREEN}✅${RESET}  Milestone created"
    always_msg "  ${DIM}${ms_url}${RESET}"
  else
    local existing
    existing="$(gh api "repos/$repo_slug/milestones" \
      --jq ".[] | select(.title == \"$milestone_title\") | .html_url" 2>/dev/null || true)"
    if [[ -n "$existing" ]]; then
      always_msg "  ${YELLOW}⚠️${RESET}   Milestone ${milestone_title} already exists"
      always_msg "  ${DIM}${existing}${RESET}"
    else
      always_msg "  ${RED}❌${RESET}  Failed to create milestone  ${DIM}(check admin access on ${repo_slug})${RESET}"
    fi
  fi

  always_msg ""
  always_msg "$sep"
  always_msg ""
}

generate_contributors() {
  in_git_repo || die "Not inside a git repository."
  cd "$(git rev-parse --show-toplevel)" || exit 1

  local sep="${DIM}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
  local out_file="CONTRIBUTORS.md"

  always_msg ""
  always_msg "${BOLD}👥 commit_gh contributors${RESET}"
  always_msg "$sep"

  if ! git rev-parse HEAD >/dev/null 2>&1; then
    always_msg "  ${YELLOW}⚠️${RESET}  No commits yet in this repository."
    always_msg ""
    return 0
  fi

  local -a _names=() _counts=()
  while IFS=$'\t' read -r _count _name; do
    _count="${_count// /}"
    _names+=("$_name")
    _counts+=("$_count")
  done < <(git shortlog -sn HEAD 2>/dev/null || true)

  local _total="${#_names[@]}"
  if [[ $_total -eq 0 ]]; then
    always_msg "  ${YELLOW}⚠️${RESET}  No contributors found."
    always_msg ""
    return 0
  fi

  if [[ "$DRY_RUN" == true ]]; then
    msg "  DRY RUN: would write $out_file (${_total} contributor(s))"
    always_msg ""
    for (( i=0; i<_total; i++ )); do
      always_msg "  ${DIM}${_counts[$i]} commits${RESET}  ${BOLD}${_names[$i]}${RESET}"
    done
    always_msg ""
    always_msg "$sep"
    always_msg "  ${DIM}DRY RUN: no files written${RESET}"
    always_msg ""
    return 0
  fi

  local _action="Updated"
  [[ ! -f "$out_file" ]] && _action="Created"

  {
    printf '# Contributors\n\n'
    printf 'Thank you to everyone who has contributed to this project!\n\n'
    printf '| Commits | Name |\n'
    printf '| ------- | ---- |\n'
    for (( i=0; i<_total; i++ )); do
      printf '| %s | %s |\n' "${_counts[$i]}" "${_names[$i]}"
    done
    printf '\n'
    printf '_Generated by [commit_gh](https://github.com/raymonepping/homebrew-commit-gh-cli) on %s._\n' \
      "$(date +%Y-%m-%d)"
  } > "$out_file"

  always_msg "  ${GREEN}✅${RESET}  ${_action} ${out_file}  ${DIM}(${_total} contributor(s))${RESET}"
  always_msg ""
  for (( i=0; i<_total; i++ )); do
    always_msg "  ${DIM}${_counts[$i]} commits${RESET}  ${BOLD}${_names[$i]}${RESET}"
  done

  always_msg ""
  always_msg "$sep"
  always_msg "  ${GREEN}${BOLD}${_total} contributor(s) written to ${out_file}.${RESET} 👥"
  always_msg ""
}

show_history() {
  local json_mode="${1:-false}"

  in_git_repo || die "Not inside a git repository."
  cd "$(git rev-parse --show-toplevel)" || exit 1
  command -v gh >/dev/null 2>&1 || die "gh CLI not found. Install with: brew install gh"
  has_origin_remote || die "No origin remote found. Run --init-remote first."

  local repo_slug generated
  repo_slug="$(gh repo view --json nameWithOwner --jq '.nameWithOwner' 2>/dev/null || echo "unknown")"
  generated="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"

  local -a tags=()
  mapfile -t tags < <(git tag --sort=-version:refname 2>/dev/null \
                      | grep -E '^v?[0-9]+\.[0-9]+\.[0-9]+' | head -20 || true)

  # Pre-fetch all GH release metadata in one API call
  local _releases_json
  _releases_json="$(gh release list --limit 50 --json tagName,createdAt 2>/dev/null || echo "[]")"

  local -A _rd=() _rp=()
  while IFS='|' read -r _tn _dt; do
    [[ -z "$_tn" ]] && continue
    _rd["$_tn"]="$_dt"
    _rp["$_tn"]="true"
  done < <(printf '%s' "$_releases_json" | jq -r '.[] | "\(.tagName)|\(.createdAt[:10])"' 2>/dev/null || true)

  # JSON-escape a string (backslash + double-quote only — sufficient for commit messages)
  _je() { local s="${1//\\/\\\\}"; s="${s//\"/\\\"}"; printf '%s' "$s"; }

  # Detect semver bump type between two tags
  _bt() {
    local _cm _cp _pm _pp
    _cm="$(printf '%s' "$1" | sed 's/v//' | cut -d. -f1)"
    _cp="$(printf '%s' "$1" | sed 's/v//' | cut -d. -f2)"
    _pm="$(printf '%s' "$2" | sed 's/v//' | cut -d. -f1)"
    _pp="$(printf '%s' "$2" | sed 's/v//' | cut -d. -f2)"
    if   [[ "$_cm" != "$_pm" ]]; then printf 'major'
    elif [[ "$_cp" != "$_pp" ]]; then printf 'minor'
    else printf 'patch'
    fi
  }

  local sep="${DIM}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"

  if [[ ${#tags[@]} -eq 0 ]]; then
    always_msg ""
    always_msg "${BOLD}📦 ${repo_slug} — history${RESET}"
    always_msg "$sep"
    always_msg "  ${DIM}No semver tags found in this repository.${RESET}"
    always_msg ""
    return 0
  fi

  if [[ "$json_mode" == true ]]; then
    printf '{\n'
    printf '  "repo": "%s",\n' "$(_je "$repo_slug")"
    printf '  "generated": "%s",\n' "$generated"
    printf '  "releases": ['

    local _first=true

    # Unreleased commits (HEAD since latest tag)
    local -a _uc=()
    mapfile -t _uc < <(git log --pretty=format:"%h|%as|%an|%s" "${tags[0]}..HEAD" 2>/dev/null || true)
    if [[ ${#_uc[@]} -gt 0 ]]; then
      printf '\n    {"tag":null,"name":"Unreleased","date":null,"bump":null,"published":false,"commits":['
      local _cf=true _l
      for _l in "${_uc[@]}"; do
        IFS='|' read -r _h _d _a _m <<< "$_l"
        [[ "$_cf" == true ]] || printf ','
        _cf=false
        printf '\n      {"hash":"%s","date":"%s","author":"%s","message":"%s"}' \
          "$_h" "$_d" "$(_je "$_a")" "$(_je "$_m")"
      done
      [[ "$_cf" == false ]] && printf '\n    '
      printf ']}'
      _first=false
    fi

    local i
    for (( i=0; i<${#tags[@]}; i++ )); do
      local _t="${tags[$i]}" _p="${tags[$((i+1))]:-}"
      local _bump="" _rng
      [[ -n "$_p" ]] && _bump="$(_bt "$_t" "$_p")"
      local _date="${_rd[$_t]:-$(git log -1 --pretty=format:"%as" "$_t" 2>/dev/null || echo "")}"
      local _pub="${_rp[$_t]:-false}"
      [[ -n "$_p" ]] && _rng="${_p}..${_t}" || _rng="$_t"

      [[ "$_first" == true ]] || printf ','
      _first=false
      printf '\n    {"tag":"%s","name":"%s","date":"%s","bump":"%s","published":%s,"commits":[' \
        "$(_je "$_t")" "$(_je "$_t")" "$_date" "$_bump" "$_pub"

      local _cf=true
      while IFS='|' read -r _h _d _a _m; do
        [[ "$_cf" == true ]] || printf ','
        _cf=false
        printf '\n      {"hash":"%s","date":"%s","author":"%s","message":"%s"}' \
          "$_h" "$_d" "$(_je "$_a")" "$(_je "$_m")"
      done < <(git log --pretty=format:"%h|%as|%an|%s" "$_rng" 2>/dev/null || true)

      [[ "$_cf" == false ]] && printf '\n    '
      printf ']}'
    done

    printf '\n  ]\n}\n'

  else
    always_msg ""
    always_msg "${BOLD}📦 ${repo_slug} — history${RESET}"
    always_msg "$sep"

    # Unreleased commits at the top
    local -a _uc=()
    mapfile -t _uc < <(git log --pretty=format:"%h  %as  %s" "${tags[0]}..HEAD" 2>/dev/null || true)
    if [[ ${#_uc[@]} -gt 0 ]]; then
      always_msg ""
      always_msg "  ${BOLD}${YELLOW}Unreleased${RESET}  ${DIM}(${#_uc[@]} commit(s) since ${tags[0]})${RESET}"
      local j
      for (( j=0; j<${#_uc[@]}; j++ )); do
        local _br="├──"; [[ $j -eq $((${#_uc[@]}-1)) ]] && _br="└──"
        always_msg "  ${DIM}${_br}${RESET} ${_uc[$j]}"
      done
    fi

    local i
    for (( i=0; i<${#tags[@]}; i++ )); do
      local _t="${tags[$i]}" _p="${tags[$((i+1))]:-}"
      local _bump_label=""
      [[ -n "$_p" ]] && _bump_label="  ${DIM}·  $(_bt "$_t" "$_p") release${RESET}"
      local _date="${_rd[$_t]:-$(git log -1 --pretty=format:"%as" "$_t" 2>/dev/null || echo "")}"
      local _pub_badge=""
      [[ "${_rp[$_t]:-false}" == "true" ]] && _pub_badge="  ${DIM}📦${RESET}"
      local _rng
      [[ -n "$_p" ]] && _rng="${_p}..${_t}" || _rng="$_t"

      always_msg ""
      always_msg "  ${BOLD}${GREEN}${_t}${RESET}  ${DIM}·  ${_date}${RESET}${_bump_label}${_pub_badge}"

      local -a _coms=()
      mapfile -t _coms < <(git log --pretty=format:"%h  %as  %s" "$_rng" 2>/dev/null || true)
      local j
      for (( j=0; j<${#_coms[@]}; j++ )); do
        local _br="├──"; [[ $j -eq $((${#_coms[@]}-1)) ]] && _br="└──"
        always_msg "  ${DIM}${_br}${RESET} ${_coms[$j]}"
      done
    done

    always_msg ""
    always_msg "$sep"
    always_msg ""
  fi
}

# ----------------------------
# Standalone modes — combinable flags run in sequence, then exit.
# Exclusive flags (rollback, read-version-only, scan) exit immediately.
# Harden always runs before audit when both are given.
# ----------------------------
_ran_standalone=false
_audit_exit=0

if [[ "$HARDEN_MODE" == true ]]; then
  in_git_repo || die "Not inside a git repository. --harden requires an existing repo."
  cd "$(git rev-parse --show-toplevel)" || exit 1
  msg "🛡️ Hardening repo: $(basename "$(pwd)")"
  setup_security_files
  [[ "$AUDIT_MODE" != true ]] && always_msg "  Run ${CYAN}commit_gh --audit${RESET} to verify."
  _ran_standalone=true
fi

if [[ "$AUDIT_MODE" == true ]]; then
  run_audit || _audit_exit=$?
  _ran_standalone=true
fi

# Exclusive standalone modes — exit immediately, cannot be combined
if [[ "$READ_VERSION_ONLY" == true ]]; then
  run_read_version
  exit 0
fi

if [[ "$SCAN_MODE" == true ]]; then
  gitleaks_available || die "gitleaks not found. Install with: brew install gitleaks"
  run_gitleaks_scan "source"
  always_msg "🎉 Done."
  exit 0
fi

if [[ -n "$ROLLBACK_TAG" ]]; then
  in_git_repo || die "Not inside a git repository. --rollback requires an existing repo."
  cd "$(git rev-parse --show-toplevel)" || exit 1
  do_rollback "$ROLLBACK_TAG"
  exit 0
fi

if [[ -n "$CHANGELOG_PREVIEW_BUMP" ]]; then
  preview_changelog "$CHANGELOG_PREVIEW_BUMP"
  exit 0
fi

# Combinable standalone modes
if [[ "$PROTECT_MODE" == true ]]; then
  in_git_repo || die "Not inside a git repository. --protect requires an existing repo."
  cd "$(git rev-parse --show-toplevel)" || exit 1
  enable_branch_protection "$(detect_branch)"
  _ran_standalone=true
fi

if [[ "$DOCTOR_MODE" == true ]]; then
  run_doctor
  _ran_standalone=true
fi

if [[ "$SIGN_MODE" == true ]]; then
  setup_signing
  _ran_standalone=true
fi

if [[ "$LABELS_MODE" == true ]]; then
  in_git_repo || die "Not inside a git repository. --labels requires an existing repo."
  cd "$(git rev-parse --show-toplevel)" || exit 1
  setup_labels
  _ran_standalone=true
fi

if [[ -n "$MILESTONE_BUMP" ]]; then
  setup_milestone "$MILESTONE_BUMP"
  _ran_standalone=true
fi

if [[ "$CONTRIBUTORS_MODE" == true ]]; then
  in_git_repo || die "Not inside a git repository. --contributors requires an existing repo."
  cd "$(git rev-parse --show-toplevel)" || exit 1
  generate_contributors
  _ran_standalone=true
fi

if [[ "$HISTORY_MODE" == true ]]; then
  show_history "$JSON_OUTPUT"
  exit 0
fi

if [[ "$_ran_standalone" == true ]]; then
  exit "$_audit_exit"
fi

# Catch release-only modifiers used without --release
if [[ "$RELEASE_GENERATE_NOTES" == true && -z "$RELEASE_BUMP" ]]; then
  always_msg "⚠️  --generate-notes is a modifier for --release and has no effect on its own."
  always_msg "   To release with auto-generated notes: ${CYAN}commit_gh --release patch --generate-notes${RESET}"
  always_msg "   To preview the CHANGELOG entry first: ${CYAN}commit_gh --changelog${RESET}"
  exit 1
fi

if [[ "$RELEASE_NO_RELEASE" == true && -z "$RELEASE_BUMP" ]]; then
  always_msg "⚠️  --no-release is a modifier for --release and has no effect on its own."
  always_msg "   Usage: ${CYAN}commit_gh --release patch --no-release${RESET}"
  exit 1
fi

if [[ "$RELEASE_FORCE" == true && -z "$RELEASE_BUMP" ]]; then
  always_msg "⚠️  --force is a modifier for --release and has no effect on its own."
  always_msg "   Usage: ${CYAN}commit_gh --release patch --force${RESET}"
  exit 1
fi

if [[ "$PUBLISH_IMAGE" == true && -z "$RELEASE_BUMP" ]]; then
  always_msg "⚠️  --publish-image is a modifier for --release and has no effect on its own."
  always_msg "   Usage: ${CYAN}commit_gh --release patch --publish-image${RESET}"
  exit 1
fi

if [[ "$PR_DRAFT" == true && "$PR_MODE" != true ]]; then
  always_msg "⚠️  --draft is a modifier for --pr and has no effect on its own."
  always_msg "   Usage: ${CYAN}commit_gh --pr --draft${RESET}"
  exit 1
fi

if [[ "$JSON_OUTPUT" == true && "$HISTORY_MODE" != true ]]; then
  always_msg "⚠️  --json is a modifier for --history and has no effect on its own."
  always_msg "   Usage: ${CYAN}commit_gh --history --json${RESET}"
  exit 1
fi

# ----------------------------
# Start
# ----------------------------
ensure_repo
ensure_no_rebase_or_merge
ensure_ssh_agent

branch="$(detect_branch)"

# Optional: remove tracked FOLDER_TREE.md if ignored
if in_git_repo && git ls-files --error-unmatch FOLDER_TREE.md &>/dev/null; then
  if [[ -f .gitignore ]] && grep -qF "FOLDER_TREE.md" .gitignore; then
    msg "🧹 Removing FOLDER_TREE.md from Git tracking..."
    if [[ "$DRY_RUN" == true ]]; then
      msg "DRY RUN: git rm --cached FOLDER_TREE.md"
    else
      git rm --cached FOLDER_TREE.md >/dev/null
    fi
  fi
fi

ensure_origin_remote || true

# Enable GitHub security features if requested (after remote exists)
if [[ "$ENABLE_SECRET_SCANNING" == true ]]; then
  enable_dependabot_alerts
  enable_github_secret_scanning
fi

# Decide commit message
if [[ -n "$COMMIT_MESSAGE_OVERRIDE" ]]; then
  COMMIT_MESSAGE="$COMMIT_MESSAGE_OVERRIDE"
else
  DD=$(date +'%d')
  MM=$(date +'%m')
  YYYY=$(date +'%Y')
  COMMIT_MESSAGE="$DD/$MM/$YYYY - Updated configuration and fixed bugs"
fi

# --pr on the default branch with no explicit --branch: auto-create a feature branch
if [[ "$PR_MODE" == true && -z "$RELEASE_BUMP" && -z "$BRANCH" ]]; then
  _pr_default="$(gh repo view --json defaultBranchRef --jq '.defaultBranchRef.name' 2>/dev/null || echo "main")"
  if [[ "$branch" == "$_pr_default" ]]; then
    if [[ -n "$COMMIT_MESSAGE_OVERRIDE" ]]; then
      _pr_slug="${COMMIT_MESSAGE_OVERRIDE#*: }"   # strip conventional-commit prefix
    else
      _pr_slug="update-$(date +%Y%m%d)"
    fi
    _auto_branch="feature/$(echo "$_pr_slug" \
      | tr '[:upper:]' '[:lower:]' \
      | tr -cs 'a-z0-9' '-' \
      | sed -E 's/-+/-/g;s/^-//;s/-$//' \
      | cut -c1-50)"
    msg "🌿 --pr on ${_pr_default}: auto-creating branch ${CYAN}${_auto_branch}${RESET}"
    if [[ "$DRY_RUN" == true ]]; then
      msg "DRY RUN: git checkout -b \"$_auto_branch\""
    else
      git checkout -b "$_auto_branch" >/dev/null 2>&1 \
        || die "Branch '$_auto_branch' already exists. Check it out first or use --branch <name>."
    fi
    branch="$_auto_branch"
  fi
fi

# ----------------------------
# RELEASE FLOW (VERSION-file based)
# ----------------------------
if [[ -n "$RELEASE_BUMP" ]]; then
  vf_path="$VERSION_FILE"
  [[ "$vf_path" != /* ]] && vf_path="$(pwd)/$vf_path"

  ensure_version_file "$vf_path"
  current_version="$(<"$vf_path")"
  read_semver "$current_version" || die "Invalid VERSION '$current_version'. Expected X.Y.Z"

  # Explicit x.y.z or bump type
  if [[ "$RELEASE_BUMP" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
    new_version="$RELEASE_BUMP"
  else
    new_version="$(bump_semver "$RELEASE_BUMP" "$SEMVER_MAJOR" "$SEMVER_MINOR" "$SEMVER_PATCH")"
  fi
  new_tag="v${new_version}"

  # Default commit message
  release_commit_msg="${COMMIT_MESSAGE_OVERRIDE:-chore: release ${new_tag}}"

  # ── Pre-flight checks ──────────────────────────────────────────
  msg ""
  msg "${BOLD}── Pre-flight checks ────────────────────────────────────────────${RESET}"
  in_git_repo && msg "  ${GREEN}✓${RESET} git repository" || die "Not inside a git repository."
  if has_origin_remote; then
    msg "  ${GREEN}✓${RESET} origin remote: $(git remote get-url origin)"
  else
    msg "  ${YELLOW}⚠${RESET} no origin remote — push and GitHub release will be skipped"
  fi
  if command -v gh >/dev/null 2>&1; then
    msg "  ${GREEN}✓${RESET} gh CLI available"
  else
    msg "  ${YELLOW}⚠${RESET} gh CLI not found — GitHub release will be skipped"
  fi
  if [[ "$RELEASE_FORCE" != true ]] && git rev-parse "$new_tag" >/dev/null 2>&1; then
    die "Tag $new_tag already exists. Use --force to overwrite."
  fi
  msg ""

  # ── Release plan ───────────────────────────────────────────────
  msg "${BOLD}── Release plan ─────────────────────────────────────────────────${RESET}"
  msg "  Version       : ${BOLD}$current_version → $new_version${RESET}"
  msg "  Tag           : ${BOLD}$new_tag${RESET}"
  msg "  Branch        : $branch"
  msg "  Commit msg    : $release_commit_msg"
  msg "  GitHub release: $([ "$RELEASE_NO_RELEASE" = true ] && echo "skipped (--no-release)" || ([ "$RELEASE_GENERATE_NOTES" = true ] && echo "yes (--generate-notes)" || echo "yes"))"
  msg "  Force         : $([ "$RELEASE_FORCE" = true ] && echo "${YELLOW}yes — will overwrite existing tag + release${RESET}" || echo "no")"
  if [[ "$PUBLISH_IMAGE" == true ]]; then
    msg "  Publish image : yes (${IMAGE_REGISTRY}, context: ${IMAGE_CONTEXT})"
  fi
  if [[ "$DRY_RUN" == true ]]; then
    msg ""
    msg "  ${YELLOW}${BOLD}DRY RUN — no changes will be made${RESET}"
    msg ""
  fi
  msg ""

  # Sync first (avoid stash eating our edits)
  sync_with_remote_rebase "$branch"

  # Update the script's VERSION constant (repo copy); dies if target not writable
  update_self_version_constant "$new_version"

  # Guard: only when releasing commit_gh itself (current repo has bin/commit_gh)
  if [[ "$DRY_RUN" != true ]]; then
    self_version="$(get_self_version_constant)"
    if [[ -n "$self_version" && "$self_version" != "$new_version" ]]; then
      die "Refusing to tag: bin/commit_gh VERSION is $self_version but release version is $new_version"
    fi
  fi

  # ── 1/4 Update VERSION file + CHANGELOG ───────────────────────
  msg "${BOLD}── 1/4  Update VERSION file ─────────────────────────────────────${RESET}"
  if [[ "$DRY_RUN" == true ]]; then
    msg "  DRY RUN: echo \"$new_version\" > \"$vf_path\""
  else
    echo "$new_version" >"$vf_path"
    msg "  ${GREEN}✓${RESET} $VERSION_FILE → $new_version"
  fi
  populate_changelog "$new_version"

  # ── 2/4 Commit ────────────────────────────────────────────────
  msg "${BOLD}── 2/4  Commit ──────────────────────────────────────────────────${RESET}"
  if [[ "$DRY_RUN" == true ]]; then
    msg "  DRY RUN: git add . && git commit -m \"$release_commit_msg\""
  else
    git add "$vf_path" >/dev/null
    git add . >/dev/null
    if git diff --cached --quiet; then
      msg "  ${YELLOW}⚠${RESET} Nothing to commit (working tree already clean)"
    else
      git commit -m "$release_commit_msg" >/dev/null
      msg "  ${GREEN}✓${RESET} Committed: $release_commit_msg"
    fi
  fi

  # ── 3/4 Tag ───────────────────────────────────────────────────
  msg "${BOLD}── 3/4  Tag ─────────────────────────────────────────────────────${RESET}"
  if git rev-parse "$new_tag" >/dev/null 2>&1 && [[ "$RELEASE_FORCE" == true ]]; then
    if [[ "$DRY_RUN" != true ]]; then
      git tag -d "$new_tag" >/dev/null
      git push origin ":refs/tags/$new_tag" >/dev/null 2>&1 || true
      msg "  ${YELLOW}⚠${RESET} Deleted existing tag $new_tag (--force)"
    fi
  fi
  if [[ "$DRY_RUN" == true ]]; then
    msg "  DRY RUN: git tag -a \"$new_tag\" -m \"$release_commit_msg\""
  else
    git tag -a "$new_tag" -m "$release_commit_msg" >/dev/null
    msg "  ${GREEN}✓${RESET} Tagged $new_tag"
  fi

  # Push branch and tag
  if has_origin_remote; then
    if [[ "$DRY_RUN" == true ]]; then
      msg "  DRY RUN: git push origin \"$branch\" && git push origin \"$new_tag\""
    else
      git push origin "$branch" >/dev/null 2>&1 || die "Push branch failed."
      git push origin "$new_tag" >/dev/null 2>&1 || die "Push tag failed."
      msg "  ${GREEN}✓${RESET} Pushed $branch and $new_tag to origin"
    fi
  else
    msg "  ${YELLOW}⚠${RESET} No origin remote — push skipped"
  fi

  # ── 4/4 GitHub release ────────────────────────────────────────
  msg "${BOLD}── 4/4  GitHub release ──────────────────────────────────────────${RESET}"
  if [[ "$RELEASE_NO_RELEASE" == true ]]; then
    msg "  ${YELLOW}⚠${RESET} Skipped (--no-release)"
  else
    create_github_release "$new_tag"
  fi

  # ── 5/5 Publish image (optional) ───────────────────────────────
  if [[ "$PUBLISH_IMAGE" == true ]]; then
    msg "${BOLD}── 5/5  Publish image ───────────────────────────────────────────${RESET}"
    publish_image "$new_tag"
  fi

  msg ""
  msg "${GREEN}${BOLD}✅ Release complete: $new_tag${RESET}"
  msg ""
fi

# ----------------------------
# ORIGINAL COMMIT FLOW (kept)
# ----------------------------
if [[ "$DRY_RUN" == true ]]; then
  msg "DRY RUN: git add ."
else
  git add . >/dev/null
fi

# Remove any gitignored files that were already in the index before .gitignore was updated
if [[ "$DRY_RUN" != true ]]; then
  unstage_gitignored_files
fi

# Auto-unstage sensitive filenames before secret scan
if [[ "$DRY_RUN" != true ]]; then
  unstage_blocked_files
fi

# Gitleaks staged scan before commit (skippable with --no-scan)
if [[ "$NO_SCAN" != true ]]; then
  run_gitleaks_scan "staged"
fi

DID_COMMIT=0
if ! git diff --cached --quiet; then
  msg "📦 Committing staged changes..."
  if [[ "$DRY_RUN" == true ]]; then
    msg "DRY RUN: git commit -m \"$COMMIT_MESSAGE\""
  else
    git commit -m "$COMMIT_MESSAGE" >/dev/null
  fi
  DID_COMMIT=1
fi

sync_with_remote_rebase "$branch"

if [[ "$DRY_RUN" == true ]]; then
  msg "DRY RUN: git add ."
else
  git add . >/dev/null
fi

if ! git diff --cached --quiet; then
  msg "📦 Committing new staged changes..."
  if [[ "$DRY_RUN" == true ]]; then
    msg "DRY RUN: git commit -m \"$COMMIT_MESSAGE\""
  else
    git commit -m "$COMMIT_MESSAGE" >/dev/null
  fi
  DID_COMMIT=1
fi

# Smart push logic
DID_PUSH=0
try_push() {
  local max_attempts=2
  local attempt=1

  if ! has_origin_remote; then
    msg "⚠️ No origin remote. Skipping push."
    return 0
  fi

  while [[ $attempt -le $max_attempts ]]; do
    if [[ $(git log "origin/$branch..HEAD" --oneline 2>/dev/null | wc -l | tr -d ' ') -gt 0 ]]; then
      if [[ "$DRY_RUN" == true ]]; then
        msg "DRY RUN: git push origin \"$branch\""
        DID_PUSH=1
        return 0
      fi

      if git push origin "$branch" >/dev/null 2>&1; then
        DID_PUSH=1
        msg "🚀 Successfully pushed to origin/$branch."
        return 0
      else
        msg "⚠️ Push failed. Trying pull --rebase and re-push..."
        if ! git pull --rebase origin "$branch" >/dev/null 2>&1; then
          die "Pull/rebase failed. Resolve manually."
        fi
        attempt=$((attempt + 1))
      fi
    else
      return 0
    fi
  done

  die "Push failed after retry. Resolve manually."
}
try_push

if [[ "$PR_MODE" == true ]]; then
  _pr_title="${COMMIT_MESSAGE_OVERRIDE:-}"
  create_pr "$branch" "$_pr_title"
fi

# Verification layer
if [[ "$VERIFY_MODE" == true ]]; then
  msg "🧪 Running commit_gh verification..."

  if ! git diff --quiet || ! git diff --cached --quiet; then
    die "Working tree is dirty."
  fi
  msg "✅ Working tree is clean."

  current_branch="$(git rev-parse --abbrev-ref HEAD)"
  if [[ "$current_branch" != "$branch" ]]; then
    die "Not on '$branch' branch (current: $current_branch)"
  fi
  msg "✅ On branch: $branch"

  if [[ ! -f .version ]]; then
    latest_tag=$(git tag --sort=-v:refname | grep -E '^v[0-9]+\.[0-9]+\.[0-9]+$' | head -n1 || echo "v0.0.0")
    if [[ "$DRY_RUN" == true ]]; then
      msg "DRY RUN: echo \"$latest_tag\" > .version"
    else
      echo "$latest_tag" >.version
    fi
    version_file="$latest_tag"
    msg "🆕 .version file created with: $latest_tag"
  else
    version_file=$(<.version)
    msg "✅ .version file found: $version_file"
  fi

  latest_tag=$(git tag --sort=-v:refname | grep -E '^v[0-9]+\.[0-9]+\.[0-9]+$' | head -n1 || echo "v0.0.0")
  if [[ "$version_file" != "$latest_tag" ]]; then
    die ".version ($version_file) does not match latest tag ($latest_tag)"
  fi
  msg "🎯 All verification checks passed."
fi

if [[ $DID_COMMIT -eq 0 && $DID_PUSH -eq 0 ]]; then
  current_branch="$(git rev-parse --abbrev-ref HEAD)"
  always_msg "✅ Current branch $current_branch is up to date."
  always_msg "🟢 No changes to commit."
fi

if [[ -f .github/dependabot.yml ]]; then
  msg "🔐 Dependabot is enabled. Base image CVEs will be monitored automatically by GitHub."
fi

if [[ $GENERATE_TREE -eq 1 ]]; then
  if command -v folder_tree &>/dev/null; then
    msg "🌳 Generating updated folder tree..."
    if [[ "$DRY_RUN" == true ]]; then
      msg "DRY RUN: folder_tree --preset terraform,github --output markdown"
    else
      folder_tree --preset terraform,github --output markdown >/dev/null
    fi
  else
    msg "⚠️ 'folder_tree' command not found. Skipping tree update."
  fi
fi

# Existing tag bump behavior
if [[ -n "$BUMP_TYPE" || "$PREVIEW_MODE" == true ]]; then
  latest_tag=$(git tag --sort=-v:refname | grep -E '^v[0-9]+\.[0-9]+\.[0-9]+$' | head -n1 || echo "v0.0.0")
  IFS='.' read -r major minor patch <<<"${latest_tag#v}"

  msg "🔍 Latest tag: $latest_tag"

  if [[ -z "$BUMP_TYPE" ]]; then
    msg "🕵️ No bump type specified."
    exit 0
  fi

  case "$BUMP_TYPE" in
  patch) ((patch++)) ;;
  minor)
    ((minor++))
    patch=0
    ;;
  major)
    ((major++))
    minor=0
    patch=0
    ;;
  esac

  new_tag="v$major.$minor.$patch"

  if [[ "$PREVIEW_MODE" == true ]]; then
    msg "🔼 Requested bump: $BUMP_TYPE"
    msg "🎯 Next tag would be: $new_tag"
    exit 0
  fi

  if git rev-parse "$new_tag" >/dev/null 2>&1; then
    die "Tag $new_tag already exists. Aborting."
  fi

  msg "🏷️ Creating new tag: $new_tag"
  if [[ "$DRY_RUN" == true ]]; then
    msg "DRY RUN: git tag -a \"$new_tag\" -m \"Release $new_tag\""
    msg "DRY RUN: git push origin \"$new_tag\""
    msg "DRY RUN: echo \"$new_tag\" > .version"
  else
    git tag -a "$new_tag" -m "Release $new_tag" >/dev/null
    if has_origin_remote; then
      git push origin "$new_tag" >/dev/null
      msg "✅ Pushed tag $new_tag successfully."
    else
      msg "⚠️ No origin remote. Tag exists only locally."
    fi
    echo "$new_tag" >.version
    msg "📝 Wrote version to .version"
  fi
fi
always_msg "🎉 Done."
