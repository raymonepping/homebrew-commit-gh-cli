write_io_gitkeeps() {
  local _dir
  for _dir in input output; do
    if [[ -d "$_dir" ]]; then
      if [[ ! -f "$_dir/.gitkeep" ]]; then
        msg "📄 Creating $_dir/.gitkeep (keeps empty dir tracked by git)..."
        [[ "$DRY_RUN" != true ]] && touch "$_dir/.gitkeep"
      else
        msg "✅ $_dir/.gitkeep already exists. Skipping."
      fi
    fi
  done
}

